---
import '../styles/global.css';
import { buildLoginUrl } from '../lib/auth-redirect.js';
import { SESSION_HINT_KEY } from '../lib/login-page-state.js';
import { getPrivatePageStatusCopy } from '../lib/private-page-auth.js';

const {
  title = '搜比价',
  description = '日本本地药店比价应用，支持扫码查价、附近价格对比、模糊搜索和个人价格记录。',
  bodyClass = '',
} = Astro.props;

const base = import.meta.env.BASE_URL || '/';
const current = Astro.url.pathname;
const shellCopy = {
  guestNav: getPrivatePageStatusCopy('shell', 'guestNav'),
  guestChip: getPrivatePageStatusCopy('shell', 'guestChip'),
  guestTitle: getPrivatePageStatusCopy('shell', 'guestTitle'),
};

const loginPath = new URL(`${base}login/`, Astro.url.origin).pathname;
const loginHref = buildLoginUrl({
  origin: Astro.url.origin,
  loginHref: `${base}login/`,
  currentUrl: `${Astro.url.pathname}${Astro.url.search}${Astro.url.hash}`,
  basePath: new URL(base, Astro.url.origin).pathname,
  loginPath,
});
const nav = [
  { href: `${base}`, label: '首页' },
  { href: `${base}scan/`, label: '扫码' },
  { href: `${base}me/`, label: '我的' },
  { href: loginHref, label: shellCopy.guestNav, auth: true, activePath: loginPath },
];

const footerLinks = [
  { href: `${base}`, label: '首页' },
  { href: `${base}scan/`, label: '扫码' },
  { href: `${base}me/`, label: '我的' },
];

const currentYear = new Date().getFullYear();

function isCurrentNavItem(item: { href: string; activePath?: string }) {
  return item.activePath ? current === item.activePath : current === item.href;
}
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f9fc" />
    <meta name="application-name" content="搜比价" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="shortcut icon" href={`${base}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}favicon.svg`} />
    <title>{title}</title>
    <script is:inline>
      // 先在 documentElement 上打一个轻量标记，避免顶栏在已登录切页时闪回错误状态。
      try {
        if (window.localStorage.getItem('aprice:session-hint') === 'signed-in') {
          document.documentElement.dataset.authPending = 'signed-in';
        }
      } catch {}
    </script>
    <style is:inline>
      html[data-auth-pending='signed-in'] #session-chip,
      html[data-auth-pending='signed-in'] [data-auth-nav='true'] {
        visibility: hidden;
      }
      html[data-auth-pending='signed-in'] #auth-form-shell,
      html[data-auth-pending='signed-in'] #session-state {
        visibility: hidden;
      }
    </style>
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main-content">跳到主要内容</a>
    <header class="topbar">
      <div class="topbar__inner">
        <a class="brand" href={base} aria-label="搜比价 首页">
          <span class="brand__mark" aria-hidden="true">
            <svg viewBox="0 0 48 48" role="presentation" focusable="false" aria-hidden="true">
              <path d="M15 36.5L24 14.5L33 36.5" fill="none" stroke="#08101b" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M19.5 25H28.5" fill="none" stroke="#08101b" stroke-width="5.5" stroke-linecap="round" />
              <path d="M31.5 16.5V35.5" fill="none" stroke="#08101b" stroke-width="4.5" stroke-linecap="round" />
              <path d="M28.5 25.5H36" fill="none" stroke="#08101b" stroke-width="4.5" stroke-linecap="round" />
            </svg>
          </span>
          <span class="brand__copy">
            <span class="brand__name">搜比价</span>
            <span class="brand__tag">日本药店比价</span>
          </span>
        </a>
        <button class="chip nav-toggle" id="nav-toggle" type="button" aria-expanded="false" aria-controls="mobile-nav" aria-label="菜单">
          <span class="nav-toggle__icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
          <span class="sr-only">菜单</span>
        </button>
        <nav class="nav" aria-label="主导航">
          {nav.map((item) => (
            <a href={item.href} data-auth-nav={item.auth ? 'true' : undefined} aria-current={isCurrentNavItem(item) ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
        <a class="chip session-chip" id="session-chip" href={loginHref}>{shellCopy.guestChip}</a>
      </div>
      <div class="shell mobile-nav" id="mobile-nav" hidden>
        <nav class="mobile-nav__links" aria-label="移动导航">
          {nav.map((item) => (
            <a href={item.href} data-auth-nav-mobile={item.auth ? 'true' : undefined} aria-current={isCurrentNavItem(item) ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <script is:inline define:vars={{ baseUrl: base, supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL || '', supabaseAnonKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '', sessionHintKey: SESSION_HINT_KEY }}>
      window.__APriceConfig = { baseUrl, supabaseUrl, supabaseAnonKey };
      window.__APriceConfig.browserJsUrl = `${baseUrl}browser.js`;
      window.__APriceConfig.browserAuthJsUrl = `${baseUrl}browser-auth.js`;
      window.__APriceConfig.supabaseRestJsUrl = `${baseUrl}supabase-rest.js`;
      window.__APriceConfig.authRedirectJsUrl = `${baseUrl}auth-redirect.js`;
      window.__APriceConfig.loginPageStateJsUrl = `${baseUrl}login-page-state.js`;
      window.__APriceConfig.privatePageAuthJsUrl = `${baseUrl}private-page-auth.js`;
      window.__APriceConfig.sessionHintKey = sessionHintKey;
    </script>

    <main class="page" id="main-content">
      <slot />
    </main>
    <footer class="footer" aria-label="站点页脚">
      <div class="shell footer__inner">
        <div class="footer__brand">
          <div class="footer__name">搜比价</div>
          <div class="footer__kicker">继续使用</div>
        </div>
        <nav class="footer__links" aria-label="页脚导航">
          {footerLinks.map((item) => (
            <a
              href={item.href}
              aria-current={current === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
        <div class="footer__meta">
          <span>© {currentYear} 搜比价</span>
          <span>搜索 · 扫码 · 我的</span>
        </div>
      </div>
    </footer>
    <script type="module" is:inline>
      const runtimeBase = window.__APriceConfig?.baseUrl || '/';
      const { resolveBase } = await import(window.__APriceConfig?.browserJsUrl || `${runtimeBase}browser.js`);
      const authRedirectUrl = window.__APriceConfig?.authRedirectJsUrl || `${runtimeBase}auth-redirect.js`;
      const { buildLoginUrl } = await import(authRedirectUrl);
      const loginStateUrl = window.__APriceConfig?.loginPageStateJsUrl || `${runtimeBase}login-page-state.js`;
      const { readSessionHint } = await import(loginStateUrl);
      const privatePageAuthUrl = window.__APriceConfig?.privatePageAuthJsUrl || `${runtimeBase}private-page-auth.js`;
      const { getPrivatePageStatusCopy } = await import(privatePageAuthUrl);
      const chip = document.querySelector('#session-chip');
      const authNav = document.querySelector('[data-auth-nav]');
      const authNavMobile = document.querySelector('[data-auth-nav-mobile]');
      const authFooter = document.querySelector('[data-auth-footer]');
      const navToggle = document.querySelector('#nav-toggle');
      const mobileNav = document.querySelector('#mobile-nav');
      let unsubscribeAuth = null;
      let authModulePromise = null;
      let sessionSyncStarted = false;
      let sessionRefreshTimer = null;
      const loginPath = resolveBase('login/');
      const basePath = new URL(resolveBase(''), window.location.origin).pathname;
      const loginUrl = buildLoginUrl({
        origin: window.location.origin,
        loginHref: loginPath,
        currentUrl: `${window.location.pathname}${window.location.search}${window.location.hash}`,
        basePath,
        loginPath: new URL(loginPath, window.location.origin).pathname,
      });

      // 顶栏会话徽章既要显示当前用户，也要跟随 Supabase 的 auth state 变化刷新。
      function loadAuthModule() {
        authModulePromise ??= import(window.__APriceConfig?.browserAuthJsUrl || `${runtimeBase}browser-auth.js`);
        return authModulePromise;
      }

      function clearSessionRefreshTimer() {
        if (sessionRefreshTimer) {
          window.clearTimeout(sessionRefreshTimer);
          sessionRefreshTimer = null;
        }
      }

      async function refreshSessionChip() {
        if (!chip) return;
        try {
          const { fetchCurrentProfile, getCurrentUser } = await loadAuthModule();
          const user = await getCurrentUser();
          if (!user) {
            chip.textContent = getPrivatePageStatusCopy('shell', 'guestChip');
            chip.href = loginUrl;
            chip.className = 'chip session-chip session-chip--guest';
            chip.title = getPrivatePageStatusCopy('shell', 'guestTitle');
            if (authNav) {
              authNav.textContent = getPrivatePageStatusCopy('shell', 'guestNav');
              authNav.href = loginUrl;
              authNav.dataset.authState = 'guest';
              if (window.location.pathname.endsWith('/login/')) {
                authNav.setAttribute('aria-current', 'page');
              } else {
                authNav.removeAttribute('aria-current');
              }
            }
            if (authNavMobile) {
              authNavMobile.textContent = getPrivatePageStatusCopy('shell', 'guestNav');
              authNavMobile.href = loginUrl;
              authNavMobile.dataset.authState = 'guest';
              if (window.location.pathname.endsWith('/login/')) {
                authNavMobile.setAttribute('aria-current', 'page');
              } else {
                authNavMobile.removeAttribute('aria-current');
              }
            }
            if (authFooter) {
              authFooter.textContent = getPrivatePageStatusCopy('shell', 'guestFooter');
              authFooter.href = loginUrl;
              authFooter.dataset.authState = 'guest';
              if (window.location.pathname.endsWith('/login/')) {
                authFooter.setAttribute('aria-current', 'page');
              } else {
                authFooter.removeAttribute('aria-current');
              }
            }
            return;
          }

          const profile = await fetchCurrentProfile();
          const isAdmin = profile?.role === 'admin';
          const isMobile = window.matchMedia('(max-width: 720px)').matches;
          const label = getPrivatePageStatusCopy('shell', 'signedInChip', { isAdmin, isMobile, email: user.email });
          chip.textContent = label;
          chip.href = isAdmin ? resolveBase('admin/') : resolveBase('me/');
          chip.className = isAdmin ? 'chip session-chip session-chip--admin' : 'chip session-chip session-chip--member';
          chip.title = user.email || label;
          if (authNav) {
            authNav.textContent = getPrivatePageStatusCopy('shell', 'signedInNav');
            authNav.href = '#';
            authNav.dataset.authState = 'signed-in';
            authNav.removeAttribute('aria-current');
          }
          if (authNavMobile) {
            authNavMobile.textContent = getPrivatePageStatusCopy('shell', 'signedInNav');
            authNavMobile.href = '#';
            authNavMobile.dataset.authState = 'signed-in';
            authNavMobile.removeAttribute('aria-current');
          }
          if (authFooter) {
            authFooter.textContent = getPrivatePageStatusCopy('shell', 'signedInFooter');
            authFooter.href = '#';
            authFooter.dataset.authState = 'signed-in';
            authFooter.removeAttribute('aria-current');
          }
        } catch {
          chip.textContent = getPrivatePageStatusCopy('shell', 'fallbackChip');
          chip.href = loginUrl;
          chip.className = 'chip session-chip session-chip--guest';
          chip.title = getPrivatePageStatusCopy('shell', 'fallbackChip');
          if (authNav) {
            authNav.textContent = getPrivatePageStatusCopy('shell', 'guestNav');
            authNav.href = loginUrl;
            authNav.dataset.authState = 'guest';
            if (window.location.pathname.endsWith('/login/')) {
              authNav.setAttribute('aria-current', 'page');
            } else {
              authNav.removeAttribute('aria-current');
            }
          }
          if (authNavMobile) {
            authNavMobile.textContent = getPrivatePageStatusCopy('shell', 'guestNav');
            authNavMobile.href = loginUrl;
            authNavMobile.dataset.authState = 'guest';
            if (window.location.pathname.endsWith('/login/')) {
              authNavMobile.setAttribute('aria-current', 'page');
            } else {
              authNavMobile.removeAttribute('aria-current');
            }
          }
          if (authFooter) {
            authFooter.textContent = getPrivatePageStatusCopy('shell', 'guestFooter');
            authFooter.href = loginUrl;
            authFooter.dataset.authState = 'guest';
            if (window.location.pathname.endsWith('/login/')) {
              authFooter.setAttribute('aria-current', 'page');
            } else {
              authFooter.removeAttribute('aria-current');
            }
          }
        }
      }

      async function signOutAndReset() {
        const { signOut } = await loadAuthModule();
        await signOut();
        await refreshSessionChip();
        window.location.assign(loginUrl);
      }

      // 顶栏登录入口会根据登录状态在“登录”和“退出”之间切换，避免已登录时还看到登录按钮。
      authNav?.addEventListener('click', async (event) => {
        if (authNav.dataset.authState !== 'signed-in') return;
        event.preventDefault();
        await signOutAndReset();
      });

      authNavMobile?.addEventListener('click', async (event) => {
        if (authNavMobile.dataset.authState !== 'signed-in') return;
        event.preventDefault();
        await signOutAndReset();
      });

      authFooter?.addEventListener('click', async (event) => {
        if (authFooter.dataset.authState !== 'signed-in') return;
        event.preventDefault();
        await signOutAndReset();
      });

      async function startSessionRefresh() {
        if (sessionSyncStarted) return;
        sessionSyncStarted = true;
        clearSessionRefreshTimer();
        try {
          await refreshSessionChip();
          loadAuthModule()
            .then(({ subscribeAuthState }) => {
              if (unsubscribeAuth) return;
              return subscribeAuthState(() => {
                refreshSessionChip();
              }).then((unsubscribe) => {
                unsubscribeAuth = unsubscribe;
              });
            })
            .catch(() => {});
        } finally {
          document.documentElement.removeAttribute('data-auth-pending');
        }
      }

      function armSessionRefresh() {
        if (sessionSyncStarted) return;
        if (readSessionHint() === 'signed-in') {
          // 已登录用户优先在页面加载后同步顶栏，避免跨页面时先看到“未登录”。
          startSessionRefresh();
          return;
        }
        sessionRefreshTimer = window.setTimeout(startSessionRefresh, 1400);
        // 顶栏会话状态不是首屏必需内容，先等用户第一次交互再加载 auth 模块，减少首页关键路径请求。
        window.addEventListener('pointerdown', startSessionRefresh, { once: true, passive: true });
        window.addEventListener('keydown', startSessionRefresh, { once: true });
      }

      armSessionRefresh();
      navToggle?.addEventListener('click', () => {
        if (!mobileNav || !navToggle) return;
        const nextExpanded = navToggle.getAttribute('aria-expanded') !== 'true';
        navToggle.setAttribute('aria-expanded', nextExpanded ? 'true' : 'false');
        mobileNav.hidden = !nextExpanded;
      });
      window.addEventListener('beforeunload', () => {
        unsubscribeAuth?.();
        clearSessionRefreshTimer();
      });
    </script>
  </body>
</html>
