---
import '../styles/global.css';

const {
  title = 'Aprice',
  description = '日本本地药店比价应用，支持扫码查价、附近价格对比、模糊搜索和个人价格记录。',
} = Astro.props;

const base = import.meta.env.BASE_URL || '/';
const current = Astro.url.pathname;
const nav = [
  { href: `${base}`, label: '首页' },
  { href: `${base}scan/`, label: '扫码' },
  { href: `${base}me/`, label: '我的' },
  { href: `${base}login/`, label: '登录', auth: true },
];
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b1020" />
    <meta name="application-name" content="Aprice" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="shortcut icon" href={`${base}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar__inner">
        <a class="brand" href={base} aria-label="Aprice 首页">
          <span class="brand__mark" aria-hidden="true">
            <svg viewBox="0 0 48 48" role="presentation" focusable="false" aria-hidden="true">
              <defs>
                <linearGradient id="aprice-brand-gradient" x1="8" y1="6" x2="40" y2="42" gradientUnits="userSpaceOnUse">
                  <stop offset="0%" stop-color="#78f0c2" />
                  <stop offset="100%" stop-color="#76b7ff" />
                </linearGradient>
              </defs>
              <path d="M12 14.5C12 11.4624 14.4624 9 17.5 9H30.5C35.7467 9 40 13.2533 40 18.5V29.5C40 34.7467 35.7467 39 30.5 39H17.5C14.4624 39 12 36.5376 12 33.5V14.5Z" fill="url(#aprice-brand-gradient)" />
              <path d="M17 30.5C18.986 24.5 21.966 18.5 24 18.5C26.034 18.5 29.014 24.5 31 30.5" stroke="#08101b" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M17.5 21H30.5" stroke="#08101b" stroke-width="4" stroke-linecap="round" />
              <path d="M20.5 26H27.5" stroke="#08101b" stroke-width="4" stroke-linecap="round" />
            </svg>
          </span>
          <span class="brand__copy">
            <span class="brand__name">Aprice</span>
            <span class="brand__tag">日本药店比价</span>
          </span>
        </a>
        <nav class="nav" aria-label="Primary">
          {nav.map((item) => (
            <a href={item.href} data-auth-nav={item.auth ? 'true' : undefined} aria-current={current === item.href ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
        <a class="chip session-chip" id="session-chip" href={`${base}login/`}>未登录</a>
      </div>
    </header>
    <script is:inline define:vars={{ baseUrl: base, supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL || '', supabaseAnonKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '' }}>
      window.__APriceConfig = { baseUrl, supabaseUrl, supabaseAnonKey };
    </script>
    <main class="page">
      <slot />
    </main>
    <script type="module" is:inline>
      import { fetchCurrentProfile, getCurrentUser, resolveBase, signOut, subscribeAuthState } from '/aprice/browser.js';

      const chip = document.querySelector('#session-chip');
      const authNav = document.querySelector('[data-auth-nav]');
      let unsubscribeAuth = null;

      // 顶栏会话徽章既要显示当前用户，也要跟随 Supabase 的 auth state 变化实时刷新。
      async function refreshSessionChip() {
        if (!chip) return;
        try {
          const user = await getCurrentUser();
          if (!user) {
            chip.textContent = '未登录';
            chip.href = resolveBase('login/');
            chip.className = 'chip session-chip session-chip--guest';
            if (authNav) {
              authNav.textContent = '登录';
              authNav.href = resolveBase('login/');
              authNav.dataset.authState = 'guest';
              if (window.location.pathname.endsWith('/login/')) {
                authNav.setAttribute('aria-current', 'page');
              } else {
                authNav.removeAttribute('aria-current');
              }
            }
            return;
          }

          const profile = await fetchCurrentProfile();
          const isAdmin = profile?.role === 'admin';
          const label = isAdmin ? '管理员' : (user.email || '已登录');
          chip.textContent = label;
          chip.href = isAdmin ? resolveBase('admin/') : resolveBase('me/');
          chip.className = isAdmin ? 'chip session-chip session-chip--admin' : 'chip session-chip session-chip--member';
          if (authNav) {
            authNav.textContent = '退出登录';
            authNav.href = '#';
            authNav.dataset.authState = 'signed-in';
            authNav.removeAttribute('aria-current');
          }
        } catch {
          chip.textContent = '会话';
          chip.href = resolveBase('login/');
          chip.className = 'chip session-chip session-chip--guest';
          if (authNav) {
            authNav.textContent = '登录';
            authNav.href = resolveBase('login/');
            authNav.dataset.authState = 'guest';
            if (window.location.pathname.endsWith('/login/')) {
              authNav.setAttribute('aria-current', 'page');
            } else {
              authNav.removeAttribute('aria-current');
            }
          }
        }
      }

      // 顶栏登录入口会根据登录状态在“登录”和“退出”之间切换，避免已登录时还看到登录按钮。
      authNav?.addEventListener('click', async (event) => {
        if (authNav.dataset.authState !== 'signed-in') return;
        event.preventDefault();
        await signOut();
        await refreshSessionChip();
        window.location.assign(resolveBase('login/'));
      });

      // 订阅 auth state change，保证登录、登出和恢复密码后的 UI 不会停留在旧状态。
      unsubscribeAuth = await subscribeAuthState(() => {
        refreshSessionChip();
      });

      refreshSessionChip();
      window.addEventListener('beforeunload', () => {
        unsubscribeAuth?.();
      });
    </script>
  </body>
</html>



