---
import '../styles/global.css';

const {
  title = 'Aprice',
  description = '日本本地药店比价应用，支持扫码查价、附近价格对比、模糊搜索和个人价格记录。',
} = Astro.props;

const base = import.meta.env.BASE_URL || '/';
const current = Astro.url.pathname;
const nav = [
  { href: `${base}`, label: '首页' },
  { href: `${base}scan/`, label: '扫码' },
  { href: `${base}me/`, label: '我的' },
  { href: `${base}login/`, label: '登录', auth: true },
];
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b1020" />
    <meta name="application-name" content="Aprice" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="shortcut icon" href={`${base}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}favicon.svg`} />
    <title>{title}</title>
    <script is:inline>
      // 先在 documentElement 上打一个轻量标记，避免顶栏在已登录切页时闪回错误状态。
      try {
        if (window.localStorage.getItem('aprice:session-hint') === 'signed-in') {
          document.documentElement.dataset.authPending = 'signed-in';
        }
      } catch {}
    </script>
    <style is:inline>
      html[data-auth-pending='signed-in'] #session-chip,
      html[data-auth-pending='signed-in'] [data-auth-nav='true'] {
        visibility: hidden;
      }
      html[data-auth-pending='signed-in'] #auth-form-shell,
      html[data-auth-pending='signed-in'] #session-state {
        visibility: hidden;
      }
    </style>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar__inner">
        <a class="brand" href={base} aria-label="Aprice 首页">
          <span class="brand__mark" aria-hidden="true">
            <svg viewBox="0 0 48 48" role="presentation" focusable="false" aria-hidden="true">
              <path d="M15 36.5L24 14.5L33 36.5" fill="none" stroke="#08101b" stroke-width="5.5" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M19.5 25H28.5" fill="none" stroke="#08101b" stroke-width="5.5" stroke-linecap="round" />
              <path d="M31.5 16.5V35.5" fill="none" stroke="#08101b" stroke-width="4.5" stroke-linecap="round" />
              <path d="M28.5 25.5H36" fill="none" stroke="#08101b" stroke-width="4.5" stroke-linecap="round" />
            </svg>
          </span>
          <span class="brand__copy">
            <span class="brand__name">Aprice</span>
            <span class="brand__tag">日本药店比价</span>
          </span>
        </a>
        <nav class="nav" aria-label="Primary">
          {nav.map((item) => (
            <a href={item.href} data-auth-nav={item.auth ? 'true' : undefined} aria-current={current === item.href ? 'page' : undefined}>
              {item.label}
            </a>
          ))}
        </nav>
        <a class="chip session-chip" id="session-chip" href={`${base}login/`}>未登录</a>
      </div>
    </header>
    <script is:inline define:vars={{ baseUrl: base, supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL || '', supabaseAnonKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY || '' }}>
      window.__APriceConfig = { baseUrl, supabaseUrl, supabaseAnonKey };
    </script>

    <main class="page">
      <slot />
    </main>
        <script type="module" is:inline>
      const runtimeBase = window.__APriceConfig?.baseUrl || '/';
      function resolveBase(pathname = '') {
        const base = runtimeBase.endsWith('/') ? runtimeBase : runtimeBase + '/';
        const cleanPath = String(pathname || '').replace(/^\/+/, '');
        if (!cleanPath) return base;
        return base + cleanPath;
      }
      const chip = document.querySelector('#session-chip');
      const authNav = document.querySelector('[data-auth-nav]');
      const sessionHintKey = 'aprice:session-hint';
      let unsubscribeAuth = null;
      let authModulePromise = null;
      let sessionSyncStarted = false;

      // 顶栏会话徽章既要显示当前用户，也要跟随 Supabase 的 auth state 变化刷新。
      function loadAuthModule() {
        authModulePromise ??= import('/aprice/browser-auth.js');
        return authModulePromise;
      }

      function readSessionHint() {
        try {
          return window.localStorage.getItem(sessionHintKey);
        } catch {
          return null;
        }
      }

      async function refreshSessionChip() {
        if (!chip) return;
        try {
          const { fetchCurrentProfile, getCurrentUser } = await loadAuthModule();
          const user = await getCurrentUser();
          if (!user) {
            chip.textContent = '未登录';
            chip.href = resolveBase('login/');
            chip.className = 'chip session-chip session-chip--guest';
            if (authNav) {
              authNav.textContent = '登录';
              authNav.href = resolveBase('login/');
              authNav.dataset.authState = 'guest';
              if (window.location.pathname.endsWith('/login/')) {
                authNav.setAttribute('aria-current', 'page');
              } else {
                authNav.removeAttribute('aria-current');
              }
            }
            return;
          }

          const profile = await fetchCurrentProfile();
          const isAdmin = profile?.role === 'admin';
          const label = isAdmin ? '管理员' : (user.email || '已登录');
          chip.textContent = label;
          chip.href = isAdmin ? resolveBase('admin/') : resolveBase('me/');
          chip.className = isAdmin ? 'chip session-chip session-chip--admin' : 'chip session-chip session-chip--member';
          if (authNav) {
            authNav.textContent = '退出登录';
            authNav.href = '#';
            authNav.dataset.authState = 'signed-in';
            authNav.removeAttribute('aria-current');
          }
        } catch {
          chip.textContent = '会话';
          chip.href = resolveBase('login/');
          chip.className = 'chip session-chip session-chip--guest';
          if (authNav) {
            authNav.textContent = '登录';
            authNav.href = resolveBase('login/');
            authNav.dataset.authState = 'guest';
            if (window.location.pathname.endsWith('/login/')) {
              authNav.setAttribute('aria-current', 'page');
            } else {
              authNav.removeAttribute('aria-current');
            }
          }
        }
      }

      async function signOutAndReset() {
        const { signOut } = await loadAuthModule();
        await signOut();
        await refreshSessionChip();
        window.location.assign(resolveBase('login/'));
      }

      // 顶栏登录入口会根据登录状态在“登录”和“退出”之间切换，避免已登录时还看到登录按钮。
      authNav?.addEventListener('click', async (event) => {
        if (authNav.dataset.authState !== 'signed-in') return;
        event.preventDefault();
        await signOutAndReset();
      });

      async function startSessionRefresh() {
        if (sessionSyncStarted) return;
        sessionSyncStarted = true;
        try {
          await refreshSessionChip();
          loadAuthModule()
            .then(({ subscribeAuthState }) => {
              if (unsubscribeAuth) return;
              return subscribeAuthState(() => {
                refreshSessionChip();
              }).then((unsubscribe) => {
                unsubscribeAuth = unsubscribe;
              });
            })
            .catch(() => {});
        } finally {
          document.documentElement.removeAttribute('data-auth-pending');
        }
      }

      function armSessionRefresh() {
        if (sessionSyncStarted) return;
        if (readSessionHint() === 'signed-in') {
          // 已登录用户优先在页面加载后同步顶栏，避免跨页面时先看到“未登录”。
          startSessionRefresh();
          return;
        }
        // 顶栏会话状态不是首屏必需内容，先等用户第一次交互再加载 auth 模块，减少首页关键路径请求。
        window.addEventListener('pointerdown', startSessionRefresh, { once: true, passive: true });
        window.addEventListener('keydown', startSessionRefresh, { once: true });
      }

      armSessionRefresh();
      window.addEventListener('beforeunload', () => {
        unsubscribeAuth?.();
      });
    </script>
  </body>
</html>











