---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;

Astro.response.status = 404;
const base = import.meta.env.BASE_URL || '/';
---
<BaseLayout title="404 - 搜比价" description="页面不存在。返回首页、扫码或打开个人页继续操作。" bodyClass="error-page">
  <style is:inline>
    html[data-product-fallback-loading='true'] body {
      visibility: hidden;
    }
  </style>
  <script is:inline define:vars={{ base }}>
    const current = new URL(window.location.href);
    const basePath = new URL(base, window.location.origin).pathname.replace(/\/$/, '');
    const pathname = current.pathname;

    const escapedBase = basePath.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    const pattern = new RegExp(`^${escapedBase ? `${escapedBase}\\/` : '/'}product\\/([^/]+)\\/?$`);
    const matched = pathname.match(pattern);
    if (matched?.[1]) {
      document.documentElement.dataset.productFallbackLoading = 'true';
      const target = new URL(`${base}product-runtime/`, window.location.origin);

      const withTargetBase = (value) => {
        if (!value) return value;
        return new URL(value, target).toString();
      };

      const copyAttributes = (source, destination) => {
        for (const { name, value } of source.attributes) {
          destination.setAttribute(name, (name === 'href' || name === 'src') ? withTargetBase(value) : value);
        }
      };

      const waitForStylesheet = (link) => new Promise((resolve) => {
        const href = withTargetBase(link.getAttribute('href'));
        if (!href) {
          resolve();
          return;
        }

        const existing = [...document.querySelectorAll('link[rel="stylesheet"]')]
          .find((item) => item.href === href);
        if (existing) {
          if (existing.sheet) {
            resolve();
            return;
          }
          existing.addEventListener('load', resolve, { once: true });
          existing.addEventListener('error', resolve, { once: true });
          return;
        }

        const next = document.createElement('link');
        copyAttributes(link, next);
        next.href = href;
        next.addEventListener('load', resolve, { once: true });
        next.addEventListener('error', resolve, { once: true });
        document.head.appendChild(next);
      });

      const runInsertedScripts = (root) => {
        for (const script of root.querySelectorAll('script')) {
          const next = document.createElement('script');
          copyAttributes(script, next);
          next.textContent = script.textContent;
          script.replaceWith(next);
        }
      };

      fetch(target.toString(), { credentials: 'same-origin' })
        .then((response) => {
          if (!response.ok) throw new Error(`商品页加载失败: ${response.status}`);
          return response.text();
        })
        .then(async (html) => {
          const nextDocument = new DOMParser().parseFromString(html, 'text/html');
          const nextMain = nextDocument.querySelector('#main-content');
          const currentMain = document.querySelector('#main-content');
          if (!nextMain || !currentMain) throw new Error('商品页内容缺失');

          document.title = nextDocument.title || document.title;
          await Promise.all([...nextDocument.querySelectorAll('link[rel="stylesheet"]')].map(waitForStylesheet));

          document.body.className = nextDocument.body.className || 'product-page';
          currentMain.innerHTML = nextMain.innerHTML;
          runInsertedScripts(currentMain);
          delete document.documentElement.dataset.productFallbackLoading;
        })
        .catch((error) => {
          delete document.documentElement.dataset.productFallbackLoading;
          console.error(error);
        });
    }
  </script>
  <section class="hero hero--tight">
    <div class="shell hero__grid hero__grid--tight">
      <div class="hero__panel hero__panel--tight">
        <div class="hero__copy hero__copy--tight">
          <div class="eyebrow">搜比价 · 404</div>
          <h1 class="headline">这个页面不在当前路径里。</h1>
          <p class="lead">
            你可以回首页继续搜索，去扫码查价，或者直接打开个人页。
          </p>
          <div class="hero__actions hero__actions--tight">
            <a class="button" href={`${base}`}>返回首页</a>
            <a class="button button--ghost" href={`${base}scan/`}>去扫码</a>
            <a class="button button--ghost" href={`${base}me/`}>打开个人页</a>
          </div>
        </div>
      </div>

      <div class="stack">
        <div class="home-links" aria-label="可继续的入口">
          <a class="home-link" href={`${base}`}>首页搜索</a>
          <a class="home-link" href={`${base}scan/`}>扫码查价</a>
          <a class="home-link" href={`${base}login/`}>账号入口</a>
        </div>
        <div class="notice notice--compact">
          路径未命中时，先回首页或直接扫码继续。
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
