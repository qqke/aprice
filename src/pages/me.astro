---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildPrivatePageLoginUrl, getPrivatePageGateCopy, getPrivatePageStatusCopy } from '../lib/private-page-auth.js';

export const prerender = true;

const base = import.meta.env.BASE_URL || '/';
const loginUrl = buildPrivatePageLoginUrl({
  origin: Astro.url.origin,
  baseUrl: base,
  currentUrl: `${Astro.url.pathname}${Astro.url.search}${Astro.url.hash}`,
});
const meGateCopy = getPrivatePageGateCopy('me');
---
<BaseLayout title="我的 - 搜比价" description="查看个人价格记录、收藏和最近查看的药店商品。" bodyClass="me-page">
  <section class="section section--first-workspace">
    <div class="shell">
      <div class="eyebrow">个人</div>
      <div class="section__header section__header--tight">
        <div>
          <h1 class="product-title">你的价格决策中心。</h1>
          <p class="product-sub">{getPrivatePageStatusCopy('me', 'pageSub')}</p>
        </div>
      </div>

      <div class="notice notice--warning" id="me-auth-gate">
        <div class="stack">
          <strong>{meGateCopy.title}</strong>
          <small>{meGateCopy.description}</small>
        </div>
        <a class="button" id="me-login-link" href={loginUrl}>{meGateCopy.primaryButtonLabel}</a>
      </div>

      <div class="grid">
        <section class="tile tile--wide">
          <div class="section__header section__header--tight">
            <div>
              <h3>快速记录</h3>
              <p>把刚看到的价格立即入库。</p>
            </div>
          </div>
          <form class="form me-log-form" id="log-form">
            <label class="field">
                <input id="log-product-search" placeholder="搜索商品（名称 / 条码）" aria-label="搜索商品" />
              </label>
              <label class="field">
                <select id="log-product" aria-label="商品">
                  <option value="">加载商品...</option>
                </select>
              </label>
              <button class="button button--ghost" id="load-more-products" type="button" hidden>加载更多商品</button>
              <div class="grid grid--two">
                <label class="field">
                  <input id="log-store-search" placeholder="搜索门店（名称 / 编号）" aria-label="搜索门店" />
                </label>
                <label class="field">
                  <select id="log-store" aria-label="门店">
                    <option value="">加载门店...</option>
                  </select>
                </label>
                <button class="button button--ghost" id="load-more-stores" type="button" hidden>加载更多门店</button>
                <label class="field">
                  <input id="log-price" type="number" inputmode="numeric" placeholder="价格（円）" aria-label="价格（日元）" />
                </label>
              </div>
              <label class="field">
                <input id="log-note" placeholder="备注，例如会员价 / 促销 / 税后" aria-label="备注" />
              </label>
            <div class="pillrow me-log-actions">
              <button class="button" type="submit">保存价格记录</button>
              <button class="button button--ghost" id="favorite-product-button" type="button">添加商品收藏</button>
              <button class="button button--ghost" id="favorite-store-button" type="button">添加门店收藏</button>
            </div>
            <div class="notice notice--compact" id="log-status">{getPrivatePageStatusCopy('me', 'loggedOutStatus')}</div>
          </form>
        </section>

        <details class="tile tile--flow me-panel" id="me-panel-favorites">
          <summary class="me-panel__summary">
            <span class="me-panel__chevron" aria-hidden="true"></span>
            <span class="me-panel__title">
              <strong>收藏</strong>
              <small id="favorites-panel-summary">读取收藏中...</small>
            </span>
          </summary>
          <div class="me-panel__body">
            <div class="section__header section__header--tight">
              <div>
                <small class="muted" id="favorites-summary">读取收藏中...</small>
              </div>
              <div class="pillrow me-favorites-filter" aria-label="收藏筛选">
                <button class="button button--ghost button--active" type="button" data-favorite-filter="all">全部</button>
                <button class="button button--ghost" type="button" data-favorite-filter="product">商品</button>
                <button class="button button--ghost" type="button" data-favorite-filter="store">门店</button>
              </div>
              <div class="pillrow me-favorites-sort" aria-label="收藏排序">
                <button class="button button--ghost button--active" type="button" data-favorite-sort="recent">最新添加</button>
                <button class="button button--ghost" type="button" data-favorite-sort="oldest">最早添加</button>
              </div>
            </div>
            <div class="feed" id="my-favorites">
              <div class="notice notice--compact">{getPrivatePageStatusCopy('me', 'loggedOutFavoritesDescription')}</div>
            </div>
          </div>
        </details>

        <details class="tile tile--wide me-panel" id="me-panel-logs">
          <summary class="me-panel__summary">
            <span class="me-panel__chevron" aria-hidden="true"></span>
            <span class="me-panel__title">
              <strong>个人价格记录</strong>
              <small id="logs-panel-summary">价格记录 · 0 条</small>
            </span>
          </summary>
          <div class="me-panel__body">
            <div class="list" id="my-logs">
              <div class="list__item">
                <div>
                  <strong>{getPrivatePageStatusCopy('me', 'loggedOutTitle')}</strong>
                  <small>{getPrivatePageStatusCopy('me', 'loggedOutDescription')}</small>
                </div>
                <span class="meta">me</span>
              </div>
            </div>
          </div>
        </details>

        <details class="tile tile--flow me-panel" id="me-panel-recent">
          <summary class="me-panel__summary">
            <span class="me-panel__chevron" aria-hidden="true"></span>
            <span class="me-panel__title">
              <strong>最近浏览</strong>
              <small id="recent-panel-summary">最近浏览 · 0 条</small>
            </span>
          </summary>
          <div class="me-panel__body">
            <div class="section__header section__header--tight">
              <div></div>
              <button class="button button--ghost" id="clear-recent-views" type="button">清空</button>
            </div>
            <div class="feed" id="recent-views">
              <div class="notice notice--compact">最近浏览。</div>
            </div>
          </div>
        </details>
      </div>
    </div>
  </section>

  <script type="module" is:inline define:vars={{ loginUrl }}>
    const { clearRecentViews, escapeAttribute, escapeHtml, fetchProductsPage, fetchRecentViews, fetchStoresPage, formatDateTime, formatYen, resolveBase } = await import(window.__APriceConfig?.browserJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'browser.js');
    const { fetchFavorites, fetchPersonalLogs, formatDataError, getCurrentUser, savePersonalLog, toggleFavorite } = await import(window.__APriceConfig?.browserAuthJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'browser-auth.js');
    const { getPrivatePageStatusCopy, redirectToLogin, syncPrivatePageGate } = await import(window.__APriceConfig?.privatePageAuthJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'private-page-auth.js');
    const { validatePositiveYen } = await import(window.__APriceConfig?.formValidationJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'form-validation.js');

    const loginLink = document.querySelector('#me-login-link');
    const authGate = document.querySelector('#me-auth-gate');
    const logsEl = document.querySelector('#my-logs');
    const recentViewsEl = document.querySelector('#recent-views');
    const recentPanelSummary = document.querySelector('#recent-panel-summary');
    const clearRecentViewsButton = document.querySelector('#clear-recent-views');
    const favsEl = document.querySelector('#my-favorites');
    const favoritesSummary = document.querySelector('#favorites-summary');
    const favoritesPanelSummary = document.querySelector('#favorites-panel-summary');
    const logsPanelSummary = document.querySelector('#logs-panel-summary');
    const favoriteFilterButtons = document.querySelectorAll('[data-favorite-filter]');
    const favoriteSortButtons = document.querySelectorAll('[data-favorite-sort]');
    const form = document.querySelector('#log-form');
    const saveLogButton = form?.querySelector('button[type="submit"]');
    const status = document.querySelector('#log-status');
    const productSearchInput = document.querySelector('#log-product-search');
    const productInput = document.querySelector('#log-product');
    const loadMoreProductsButton = document.querySelector('#load-more-products');
    const storeSearchInput = document.querySelector('#log-store-search');
    const storeInput = document.querySelector('#log-store');
    const loadMoreStoresButton = document.querySelector('#load-more-stores');
    const priceInput = document.querySelector('#log-price');
    const noteInput = document.querySelector('#log-note');
    const favoriteProductButton = document.querySelector('#favorite-product-button');
    const favoriteStoreButton = document.querySelector('#favorite-store-button');

    const formControls = [productSearchInput, productInput, loadMoreProductsButton, storeSearchInput, storeInput, loadMoreStoresButton, priceInput, noteInput, favoriteProductButton, favoriteStoreButton];
    let products = [];
    let stores = [];
    let favorites = [];
    let favoriteFilter = 'all';
    let favoriteSort = 'recent';
    const PAGE_SIZE = 20;
    let productSearchToken = 0;
    let storeSearchToken = 0;
    let productPager = { rows: [], offset: 0, hasMore: false, term: '' };
    let storePager = { rows: [], offset: 0, hasMore: false, term: '' };

    function setControlsDisabled(disabled) {
      formControls.forEach((control) => {
        if (!control) return;
        control.disabled = disabled;
      });
    }

    function lookupName(items, id) {
      return items.find((item) => item.id === id)?.name || id;
    }

    function compareFavoriteDates(a, b) {
      const left = new Date(a.created_at || 0).getTime();
      const right = new Date(b.created_at || 0).getTime();
      return favoriteSort === 'oldest' ? left - right : right - left;
    }

    function renderRecentViews(rows) {
      if (!recentViewsEl) return;
      if (recentPanelSummary) {
        recentPanelSummary.textContent = `最近浏览 · ${rows.length} 条`;
      }
      recentViewsEl.innerHTML = rows.length
        ? rows.map((item) => `
          <a class="feed__item" href="${escapeAttribute(resolveBase(`product/${item.id}/`))}">
            <div>
              <strong>${escapeHtml(item.name || 'Unknown product')}</strong>
              <small>${escapeHtml(item.brand || '品牌未知')} · ${escapeHtml(item.pack || '')} · ${escapeHtml(item.barcode || '')}</small>
            </div>
            <div class="feed__meta">
              <span class="price">查看</span>
              <small>${item.viewed_at ? formatDateTime(item.viewed_at) : ''}</small>
            </div>
          </a>
        `).join('')
        : `
          <div class="feed__item">
            <div>
              <strong>暂无浏览记录</strong>
              <small>最近浏览。</small>
            </div>
            <span class="price">recent</span>
          </div>
        `;
    }

    function renderFavorites(favoritesList) {
      if (!favsEl) return;
      const filtered = favoritesList
        .filter((fav) => favoriteFilter === 'all' || fav.entity_type === favoriteFilter)
        .slice()
        .sort(compareFavoriteDates);

      if (favoritesSummary) {
        favoritesSummary.textContent = favoritesList.length
          ? `共 ${favoritesList.length} 项收藏，当前显示 ${filtered.length} 项，按${favoriteSort === 'recent' ? '最新添加' : '最早添加'}排序。`
          : getPrivatePageStatusCopy('me', 'loggedOutFavoritesDescription');
      }
      if (favoritesPanelSummary) {
        favoritesPanelSummary.textContent = `收藏 · ${favoritesList.length} 项`;
      }
      favsEl.innerHTML = filtered.length
        ? filtered.map((fav) => `
            <div class="feed__item me-favorites__item">
            <div>
              <strong>${escapeHtml(fav.entity_type === 'product' ? lookupName(products, fav.entity_id) : lookupName(stores, fav.entity_id))}</strong>
              <small>${fav.entity_type === 'product' ? '商品' : '门店'} · ${escapeHtml(fav.entity_id)}</small>
            </div>
            <div class="feed__meta me-favorites__meta">
              <span class="price">收藏</span>
              <small>${fav.created_at ? formatDateTime(fav.created_at) : ''}</small>
              <button class="button button--ghost" type="button" data-remove-favorite="${escapeAttribute(fav.id)}" data-remove-favorite-type="${escapeAttribute(fav.entity_type)}" data-remove-favorite-entity="${escapeAttribute(fav.entity_id)}">取消</button>
            </div>
          </div>
        `).join('')
        : `
          <div class="feed__item">
            <div>
              <strong>${favoritesList.length ? '当前筛选下没有收藏' : '暂无收藏'}</strong>
              <small>${favoritesList.length ? '换个筛选条件看看，或者添加收藏。' : '添加后可见。'}</small>
            </div>
            <span class="price">暂无</span>
          </div>
        `;
    }

    function applyFavoriteFilter(nextFilter) {
      favoriteFilter = nextFilter;
      favoriteFilterButtons.forEach((button) => {
        const selected = button.dataset.favoriteFilter === favoriteFilter;
        button.classList.toggle('button--active', selected);
        button.setAttribute('aria-pressed', selected ? 'true' : 'false');
      });
      renderFavorites(favorites);
    }

    function applyFavoriteSort(nextSort) {
      favoriteSort = nextSort;
      favoriteSortButtons.forEach((button) => {
        const selected = button.dataset.favoriteSort === favoriteSort;
        button.classList.toggle('button--active', selected);
        button.setAttribute('aria-pressed', selected ? 'true' : 'false');
      });
      renderFavorites(favorites);
    }

    function renderLogs(logs) {
      if (!logsEl) return;
      if (logsPanelSummary) {
        logsPanelSummary.textContent = `价格记录 · ${logs.length} 条`;
      }
      logsEl.innerHTML = logs.length
        ? logs.map((log) => `
          <div class="list__item">
            <div>
              <strong>${escapeHtml(log?.products?.name || lookupName(products, log.product_id))}</strong>
              <small>${formatDateTime(log.created_at || log.purchased_at || new Date())} · ${escapeHtml(log?.stores?.name || lookupName(stores, log.store_id))} · ${escapeHtml(log.note || '无备注')}</small>
            </div>
            <span class="price">${formatYen(log.price_yen)}</span>
          </div>
        `).join('')
        : `
          <div class="list__item">
            <div>
              <strong>还没有记录</strong>
              <small>现在就把第一笔价格记下来。</small>
            </div>
            <span class="meta">暂无</span>
          </div>
        `;
    }

    function renderLoggedOutState() {
      syncPrivatePageGate({ gateEl: authGate, loginLinkEl: loginLink, loginUrl, visible: true });
      logsEl.innerHTML = `
        <div class="list__item">
          <div>
            <strong>${getPrivatePageStatusCopy('me', 'loggedOutTitle')}</strong>
            <small>${getPrivatePageStatusCopy('me', 'loggedOutDescription')}</small>
          </div>
          <span class="meta">offline</span>
        </div>
      `;
      favsEl.innerHTML = `
        <div class="feed__item">
          <div>
            <strong>${getPrivatePageStatusCopy('me', 'loggedOutFavoritesTitle')}</strong>
            <small>${getPrivatePageStatusCopy('me', 'loggedOutFavoritesDescription')}</small>
          </div>
          <span class="price">offline</span>
        </div>
      `;
      if (favoritesPanelSummary) favoritesPanelSummary.textContent = '收藏 · 0 项';
      if (logsPanelSummary) logsPanelSummary.textContent = '价格记录 · 0 条';
      status.textContent = getPrivatePageStatusCopy('me', 'loggedOutStatus');
      setControlsDisabled(true);
    }

    function renderProductOptions({ keepCurrent = true } = {}) {
      if (!productInput) return;
      const currentValue = keepCurrent ? productInput.value : '';
      const options = productPager.rows.length
        ? productPager.rows.map((item) => `<option value="${escapeAttribute(item.id)}">${escapeHtml(item.name)}${item.barcode ? ` · ${escapeHtml(item.barcode)}` : ''}</option>`)
        : [];
      const placeholder = productSearchInput?.value?.trim() ? '暂无匹配商品' : '请选择商品';
      productInput.innerHTML = [`<option value="">${placeholder}</option>`, ...options].join('');
      const fallbackValue = productPager.rows[0]?.id || '';
      productInput.value = productPager.rows.some((item) => item.id === currentValue) ? currentValue : fallbackValue;
      products = productPager.rows.slice();
      if (loadMoreProductsButton) {
        loadMoreProductsButton.hidden = !productPager.hasMore;
        loadMoreProductsButton.disabled = false;
      }
    }

    function renderStoreOptions({ keepCurrent = true } = {}) {
      if (!storeInput) return;
      const currentValue = keepCurrent ? storeInput.value : '';
      const options = storePager.rows.length
        ? storePager.rows.map((item) => `<option value="${escapeAttribute(item.id)}">${escapeHtml(item.name)}</option>`)
        : [];
      const placeholder = storeSearchInput?.value?.trim() ? '暂无匹配门店' : '请选择门店';
      storeInput.innerHTML = [`<option value="">${placeholder}</option>`, ...options].join('');
      const fallbackValue = storePager.rows[0]?.id || '';
      storeInput.value = storePager.rows.some((item) => item.id === currentValue) ? currentValue : fallbackValue;
      stores = storePager.rows.slice();
      if (loadMoreStoresButton) {
        loadMoreStoresButton.hidden = !storePager.hasMore;
        loadMoreStoresButton.disabled = false;
      }
    }

    async function loadProductsPage({ reset = false } = {}) {
      const token = ++productSearchToken;
      const term = String(productSearchInput?.value || '').trim();
      const offset = reset ? 0 : productPager.offset;
      if (loadMoreProductsButton) loadMoreProductsButton.disabled = true;
      const page = await fetchProductsPage({ term, limit: PAGE_SIZE, offset });
      if (token !== productSearchToken) return;
      const mergedRows = reset ? page.rows : [...productPager.rows, ...page.rows.filter((row) => !productPager.rows.some((existing) => existing.id === row.id))];
      productPager = {
        rows: mergedRows,
        offset: page.nextOffset,
        hasMore: page.hasMore,
        term,
      };
      renderProductOptions({ keepCurrent: !reset });
    }

    async function loadStoresPage({ reset = false } = {}) {
      const token = ++storeSearchToken;
      const term = String(storeSearchInput?.value || '').trim();
      const offset = reset ? 0 : storePager.offset;
      if (loadMoreStoresButton) loadMoreStoresButton.disabled = true;
      const page = await fetchStoresPage({ term, limit: PAGE_SIZE, offset });
      if (token !== storeSearchToken) return;
      const mergedRows = reset ? page.rows : [...storePager.rows, ...page.rows.filter((row) => !storePager.rows.some((existing) => existing.id === row.id))];
      storePager = {
        rows: mergedRows,
        offset: page.nextOffset,
        hasMore: page.hasMore,
        term,
      };
      renderStoreOptions({ keepCurrent: !reset });
    }

    async function refresh() {
      renderRecentViews(fetchRecentViews());
      const user = await getCurrentUser();
      if (!user) {
        renderLoggedOutState();
        return;
      }

      syncPrivatePageGate({ gateEl: authGate, loginLinkEl: loginLink, loginUrl, visible: false });
      status.textContent = getPrivatePageStatusCopy('me', 'loading');
      setControlsDisabled(false);

      let logs;
      let loadedFavorites;
      try {
        [logs, loadedFavorites] = await Promise.all([
          fetchPersonalLogs(user.id),
          fetchFavorites(user.id),
        ]);
        await Promise.all([
          loadProductsPage({ reset: true }),
          loadStoresPage({ reset: true }),
        ]);
      } catch (error) {
        products = [];
        stores = [];
        favorites = [];
        productPager = { rows: [], offset: 0, hasMore: false, term: '' };
        storePager = { rows: [], offset: 0, hasMore: false, term: '' };
        renderProductOptions({ keepCurrent: false });
        renderStoreOptions({ keepCurrent: false });
        renderLogs([]);
        renderFavorites([]);
        setControlsDisabled(true);
        status.textContent = getPrivatePageStatusCopy('me', 'saveFailure', { message: formatDataError(error) });
        return;
      }
      favorites = loadedFavorites;

      renderLogs(logs);
      renderFavorites(favorites);
      status.textContent = getPrivatePageStatusCopy('me', 'syncSummary', { logsCount: logs.length, favoritesCount: favorites.length });
    }

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      status.textContent = '保存中...';
      const priceValue = validatePositiveYen(priceInput.value);
      if (!priceValue.ok) {
        status.textContent = priceValue.message;
        return;
      }
      try {
        const user = await getCurrentUser();
        if (!user) {
          syncPrivatePageGate({ gateEl: authGate, loginLinkEl: loginLink, loginUrl, visible: true });
          status.textContent = getPrivatePageStatusCopy('me', 'saveRequired');
          redirectToLogin(loginUrl, authGate);
          return;
        }
        if (!productInput?.value) {
          status.textContent = getPrivatePageStatusCopy('me', 'saveSelectionRequired');
          return;
        }
        await savePersonalLog({
          product_id: productInput.value,
          store_id: storeInput.value || null,
          price_yen: priceValue.value,
          note: noteInput.value.trim(),
          purchased_at: new Date().toISOString().slice(0, 10),
        });
        status.textContent = getPrivatePageStatusCopy('me', 'saveSuccess');
        priceInput.value = '';
        noteInput.value = '';
        await refresh();
      } catch (error) {
        status.textContent = getPrivatePageStatusCopy('me', 'saveFailure', { message: formatDataError(error) });
      }
    });

    saveLogButton?.addEventListener('click', (event) => {
      const priceValue = validatePositiveYen(priceInput.value);
      if (!priceValue.ok) {
        event.preventDefault();
        status.textContent = priceValue.message;
      }
    });

    favoriteProductButton?.addEventListener('click', async () => {
      if (!productInput?.value) {
        status.textContent = getPrivatePageStatusCopy('me', 'favoriteProductRequired');
        return;
      }
      const user = await getCurrentUser();
      if (!user) {
        syncPrivatePageGate({ gateEl: authGate, loginLinkEl: loginLink, loginUrl, visible: true });
        status.textContent = getPrivatePageStatusCopy('me', 'favoriteProductRequired');
        redirectToLogin(loginUrl, authGate);
        return;
      }
      try {
        await toggleFavorite('product', productInput.value);
        status.textContent = getPrivatePageStatusCopy('me', 'favoriteProductSuccess');
        await refresh();
      } catch (error) {
        status.textContent = getPrivatePageStatusCopy('me', 'favoriteFailure', { message: error.message });
      }
    });

    favoriteStoreButton?.addEventListener('click', async () => {
      if (!storeInput?.value) {
        status.textContent = getPrivatePageStatusCopy('me', 'favoriteStoreRequired');
        return;
      }
      const user = await getCurrentUser();
      if (!user) {
        syncPrivatePageGate({ gateEl: authGate, loginLinkEl: loginLink, loginUrl, visible: true });
        status.textContent = getPrivatePageStatusCopy('me', 'favoriteStoreRequired');
        redirectToLogin(loginUrl, authGate);
        return;
      }
      try {
        await toggleFavorite('store', storeInput.value);
        status.textContent = getPrivatePageStatusCopy('me', 'favoriteStoreSuccess');
        await refresh();
      } catch (error) {
        status.textContent = getPrivatePageStatusCopy('me', 'favoriteFailure', { message: error.message });
      }
    });

    clearRecentViewsButton?.addEventListener('click', () => {
      clearRecentViews();
      renderRecentViews(fetchRecentViews());
      status.textContent = getPrivatePageStatusCopy('me', 'recentViewsCleared');
    });

    favsEl?.addEventListener('click', async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const favoriteId = target.dataset.removeFavorite;
      const favoriteType = target.dataset.removeFavoriteType;
      const favoriteEntity = target.dataset.removeFavoriteEntity;
      if (!favoriteId || !favoriteType || !favoriteEntity) return;
      const user = await getCurrentUser();
      if (!user) {
        syncPrivatePageGate({ gateEl: authGate, loginLinkEl: loginLink, loginUrl, visible: true });
        status.textContent = getPrivatePageStatusCopy('me', 'removeFavoriteRequired');
        redirectToLogin(loginUrl, authGate);
        return;
      }

      try {
        await toggleFavorite(favoriteType, favoriteEntity);
        status.textContent = getPrivatePageStatusCopy('me', 'favoriteSaved');
        await refresh();
      } catch (error) {
        status.textContent = getPrivatePageStatusCopy('me', 'favoriteFailure', { message: error.message });
      }
    });

    favoriteFilterButtons.forEach((button) => {
      button.addEventListener('click', () => {
        applyFavoriteFilter(button.dataset.favoriteFilter || 'all');
      });
    });

    favoriteSortButtons.forEach((button) => {
      button.addEventListener('click', () => {
        applyFavoriteSort(button.dataset.favoriteSort || 'recent');
      });
    });

    productSearchInput?.addEventListener('input', async () => {
      try {
        await loadProductsPage({ reset: true });
      } catch (error) {
        status.textContent = `商品加载失败：${formatDataError(error)}`;
      }
    });

    storeSearchInput?.addEventListener('input', async () => {
      try {
        await loadStoresPage({ reset: true });
      } catch (error) {
        status.textContent = `门店加载失败：${formatDataError(error)}`;
      }
    });

    loadMoreProductsButton?.addEventListener('click', async () => {
      try {
        await loadProductsPage({ reset: false });
      } catch (error) {
        status.textContent = `商品加载失败：${formatDataError(error)}`;
      }
    });

    loadMoreStoresButton?.addEventListener('click', async () => {
      try {
        await loadStoresPage({ reset: false });
      } catch (error) {
        status.textContent = `门店加载失败：${formatDataError(error)}`;
      }
    });

    refresh();
  </script>
</BaseLayout>
