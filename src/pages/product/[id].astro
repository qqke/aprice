---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { buildPrivatePageLoginUrl, getPrivatePageGateCopy, getPrivatePageStatusCopy } from '../../lib/private-page-auth.js';
import { restGet } from '../../lib/supabase-rest.js';

type Product = {
  id: string;
  barcode: string;
  name: string;
  brand: string;
  pack: string;
  category: string;
  tone?: string;
  description: string;
  image_url?: string;
};

export const prerender = false;

const productId = String(Astro.params.id || '').trim();
const productRows = productId
  ? (await restGet('products', {
      query: {
        select: '*',
        id: `eq.${productId}`,
        limit: 1,
      },
    })) as Product[]
  : [];
const product = productRows?.[0] ?? {
  id: productId,
  barcode: productId,
  name: '商品不存在',
  brand: '',
  pack: '',
  category: '',
  tone: 'sunset',
  description: '',
};

if (!productRows?.[0]) {
  Astro.response.status = 404;
}

const base = import.meta.env.BASE_URL || '/';
const loginUrl = buildPrivatePageLoginUrl({
  origin: Astro.url.origin,
  baseUrl: base,
  currentUrl: `${Astro.url.pathname}${Astro.url.search}${Astro.url.hash}`,
});
const productGateCopy = getPrivatePageGateCopy('product');
const productLogPrompt = getPrivatePageStatusCopy('product', 'logPrompt');
---
<BaseLayout title={`${product.name} - 搜比价`} description={`${product.name} 的门店价格、附近比价和个人记录。`} bodyClass="product-page">
  <section class="section section--first-workspace" id="product-page" data-product-id={product.id} data-product-name={product.name} data-product-brand={product.brand} data-product-pack={product.pack} data-product-barcode={product.barcode} data-product-tone={product.tone}>
    <div class="shell">
      <div class={`product-hero tone-${product.tone || 'sunset'}`} >
        <div class="product-hero__overlay" >
          {product.image_url && (
            <div class="product-hero__media">
              <img class="product-hero__image" src={product.image_url} alt={product.name} loading="eager" decoding="async" referrerpolicy="no-referrer" />
            </div>
          )}
          <div class="pillrow product-hero__meta">
            <span class="pill product-hero__barcode">JAN {product.barcode}</span>
            {product.brand && <span class="pill product-hero__brand" title={product.brand}>{product.brand}</span>}
          </div>
          <h1 class="product-title" >{product.name}</h1>
          <p class="product-sub" >{product.description}</p>
          <div class="product-hero__actions" aria-label="商品页主要操作">
            <button class="button" id="hero-geo-sort" type="button">按当前位置排序</button>
            <a class="button button--ghost" href="#product-personal-record">记录店头价</a>
          </div>
        </div>
      </div>

      <div class="notice notice--warning" id="product-auth-gate">
        <div class="stack">
          <strong>{productGateCopy.title}</strong>
          <small>{productGateCopy.description}</small>
        </div>
        <a class="button" id="product-login-link" href={loginUrl}>{productGateCopy.primaryButtonLabel}</a>
      </div>

      <div class="grid product-grid-top">
        <section class="tile tile--wide tile--flow" id="product-price-flow">
          <div class="section__header section__header--tight">
            <div>
              <h2>价格流</h2>
              <p>先看可买到的最低价，再比较门店差异。</p>
            </div>
            <button class="button button--ghost" id="geo-sort" type="button">按当前位置排序</button>
          </div>
          <div class="product-price-flow__lead" aria-label="价格流摘要">
            <div class="product-price-flow__lead-copy">
              <span class="product-price-flow__lead-label">当前最低价</span>
              <strong id="price-flow-min-price">同步中</strong>
              <small id="price-flow-store">等待价格数据</small>
            </div>
            <div class="product-price-flow__lead-aside">
              <span class="pill" id="price-flow-gap-pill">等待价格</span>
              <small id="price-flow-gap-note">补上第一组门店价格后，会显示最低价和次低价差。</small>
            </div>
          </div>
          <div class="notice notice--compact" id="geo-status">{getPrivatePageStatusCopy('product', 'geoStatus')}</div>
          <div class="feed" id="price-list">
            <div class="notice notice--compact">价格结果。</div>
          </div>
        </section>

        <section class="tile tile--flow" id="product-nearby-stores">
          <div class="section__header section__header--tight">
            <div>
              <h3>附近门店</h3>
              <p>快速查看附近门店价格分布。</p>
            </div>
          </div>
          <div class="store-map-card">
            <div class="store-map-card__header">
              <strong>门店分布图</strong>
              <small id="nearby-map-status">加载中：等待门店数据。</small>
            </div>
            <div class="store-map" id="nearby-store-map" aria-live="polite">
              <div class="notice notice--compact">附近门店地图会显示在这里。</div>
            </div>
          </div>
          <div class="notice notice--compact" id="nearby-status">门店价格会显示在这里。</div>
          <div class="feed" id="nearby-store-list">
            <div class="notice notice--compact">随价格更新。</div>
          </div>
        </section>
      </div>

      <section class="section">
        <div class="grid">
          <section class="tile tile--wide" id="product-summary">
            <div class="section__header section__header--tight">
              <h3>价格洞察</h3>
              <p>汇总最低价、门店覆盖和近7天变化。</p>
            </div>
            <div class="feed">
              <div class="feed__item feed__item--featured product-summary__item">
                <div class="feed__copy">
                  <div class="feed__kicker">价格结论</div>
                  <div class="product-summary__lead">
                    <span class="product-summary__lead-label">当前最低价</span>
                    <strong id="summary-min-price">同步中</strong>
                    <small id="summary-gain-label">等待价格数据</small>
                  </div>
                  <div class="product-summary__stats" aria-label="摘要数据">
                    <div class="product-summary__stat">
                      <small>门店数</small>
                      <strong id="summary-store-count">同步中</strong>
                    </div>
                    <div class="product-summary__stat">
                      <small>最新采样</small>
                      <strong id="summary-latest-store">同步中</strong>
                    </div>
                    <div class="product-summary__stat">
                      <small>近7天变化</small>
                      <strong id="summary-trend-label">同步中</strong>
                    </div>
                  </div>
                  <div class="pillrow" id="insight-pills">
                    <span class="pill">摘要读取中...</span>
                  </div>
                </div>
              </div>
            </div>
          </section>
        </div>
      </section>

      <section class="section">
        <div class="grid">
          <section class="tile" id="product-personal-record">
            <div class="section__header section__header--tight">
              <h3>记录店头价格</h3>
              <p>记录你在门店看到的价格，可选择提交公共比价。</p>
            </div>
            <div class="pillrow product-secondary-actions" aria-label="收藏操作">
              <button class="button button--ghost" id="favorite-product-button" type="button">添加商品收藏</button>
              <button class="button button--ghost" id="favorite-store-button" type="button">添加门店收藏</button>
            </div>
            <div class="personal-record-layout">
              <div class="personal-store-panel">
                <div class="store-search">
                  <label class="field store-search__input">
                    <input id="personal-store-search" name="personal-store-search" type="search" inputmode="search" placeholder="搜索店名或连锁名" autocomplete="off" spellcheck="false" aria-label="搜索门店" />
                  </label>
                  <button class="button button--ghost store-search__clear" id="personal-store-search-clear" type="button" hidden>清空</button>
                </div>
                <div class="store-map-card">
                  <div class="store-map-card__header">
                    <strong>选店地图</strong>
                    <small id="store-picker-map-status">加载中：等待门店数据。</small>
                  </div>
                  <div class="store-map" id="personal-store-map" aria-live="polite">
                    <div class="notice notice--compact">可选门店地图会显示在这里。</div>
                  </div>
                </div>
                <div class="notice notice--compact" id="personal-store-status">按店名、连锁名或当前位置筛选门店。</div>
                <div class="feed" id="personal-store-list">
                  <div class="notice notice--compact">正在加载门店...</div>
                </div>
                <button class="button button--ghost store-search__load-more" id="personal-store-load-more" type="button" hidden>加载更多</button>
              </div>
              <form class="form personal-log-form" id="personal-log-form">
                <input id="personal-store" type="hidden" value="" />
                <div class="personal-log-form__selected">
                  <span>当前门店</span>
                  <strong id="personal-selected-store-label">未选择门店</strong>
                </div>
                <div class="personal-log-form__action">
                  <label class="field">
                    <input id="personal-price" name="personal-price" type="number" inputmode="numeric" placeholder="你的购买价" />
                  </label>
                  <button class="button" type="submit" disabled>提交店头价格</button>
                </div>
                <div class="personal-log-form__secondary">
                  <label class="field">
                    <input id="personal-note" name="personal-note" placeholder="备注" />
                  </label>
                  <label class="field">
                    <input id="personal-evidence-url" name="personal-evidence-url" type="url" placeholder="价签或小票图片链接（可选）" />
                  </label>
                  <label class="field field--inline">
                    <input id="personal-share-public" type="checkbox" checked />
                    <span>参与公共比价（提交后由管理员审核）</span>
                  </label>
                </div>
                <div class="notice notice--compact" id="personal-status">{productLogPrompt}</div>
              </form>
            </div>
          </section>
        </div>
      </section>

      <section class="section">
        <div class="grid">
          <section class="tile tile--wide tile--flow" id="product-trend">
            <div class="section__header section__header--tight">
              <div>
                <h3>近期变化</h3>
                <p>最近几条采样按时间排。</p>
              </div>
            </div>
            <div class="feed" id="trend-list">
              <div class="notice notice--compact">最近变化会显示在这里。</div>
            </div>
            <div class="pillrow">
              <button class="button button--ghost" id="trend-load-more" type="button" hidden>加载更多历史</button>
            </div>
          </section>
        </div>
      </section>


    <script type="module" is:inline define:vars={{ loginUrl }}>
    const { initProductPage } = await import(window.__APriceConfig?.productPageRuntimeJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'product-page-runtime.js');
    await initProductPage({ loginUrl });
  </script>
</BaseLayout>
