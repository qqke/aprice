---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { demoProducts, demoStores, demoPrices } from '../../lib/catalog.js';

export function getStaticPaths() {
  return demoProducts.map((product) => ({ params: { id: product.id }, props: { product } }));
}

const { product } = Astro.props;
const base = import.meta.env.BASE_URL || '/';
const prices = demoPrices.filter((price) => price.product_id === product.id);
const sortedStores = prices
  .map((price) => ({
    ...price,
    store: demoStores.find((store) => store.id === price.store_id) ?? null,
  }))
  .sort((a, b) => a.price_yen - b.price_yen);
const nearestStore = demoStores.find((store) => store.id === prices[0]?.store_id) || demoStores[0];
---
<BaseLayout title={`${product.name} - Aprice`} description={`${product.name} 的门店价格、附近比价和个人记录。`}>
  <section class="section">
    <div class="shell">
      <div class={`product-hero tone-${product.tone}`}>
        <div class="product-hero__overlay">
          <div class="pillrow">
            <span class="pill">{product.category}</span>
            <span class="pill">JAN {product.barcode}</span>
            <span class="pill">{product.brand}</span>
          </div>
          <h1 class="product-title">{product.name}</h1>
          <p class="product-sub">{product.description}</p>
        </div>
      </div>

      <div class="grid" style="margin-top:18px;">
        <section class="tile tile--wide">
          <div class="section__header">
            <div>
              <h2>价格列表</h2>
              <p>同一商品在不同门店和会员条件下的参考价。</p>
            </div>
            <button class="button button--ghost" id="geo-sort" type="button">按当前位置重排</button>
          </div>
          <div class="notice" id="geo-status" style="margin-bottom:12px;">默认按价格显示。点击按钮后会请求定位并按附近门店重排。</div>
          <div class="list" id="price-list">
            {sortedStores.map((row) => (
              <div class="list__item">
                <div>
                  <strong>{row.store?.name}</strong>
                  <small>{row.store?.address} · {row.store?.hours} · {row.is_member_price ? '会员价' : '公开价'}</small>
                </div>
                <div style="text-align:right;">
                  <div class="price">¥{row.price_yen}</div>
                  <small>{row.source}</small>
                </div>
              </div>
            ))}
          </div>
        </section>
        <section class="tile">
          <div class="section__header">
            <h3>附近门店</h3>
            <p>后续可以接入定位排序。</p>
          </div>
          <div class="list">
            <div class="list__item">
              <div>
                <strong>{nearestStore?.name}</strong>
                <small>{nearestStore?.city} · {nearestStore?.pref}</small>
              </div>
              <span class="meta">closest</span>
            </div>
            {demoStores.slice(0, 3).map((store) => (
              <div class="list__item">
                <div>
                  <strong>{store.chain_name}</strong>
                  <small>{store.address}</small>
                </div>
                <span class="meta">{store.hours}</span>
              </div>
            ))}
          </div>
        </section>
      </div>

      <section class="section">
        <div class="grid">
          <section class="tile">
            <div class="section__header">
              <h3>个人记录</h3>
              <p>在这里记录你自己的买入价。</p>
            </div>
            <form class="form" id="personal-log-form">
              <label class="field">
                <select id="personal-store">
                  {demoStores.map((store) => <option value={store.id}>{store.name}</option>)}
                </select>
              </label>
              <label class="field">
                <input id="personal-price" type="number" inputmode="numeric" placeholder="你的购买价" />
              </label>
              <label class="field">
                <input id="personal-note" placeholder="备注" />
              </label>
              <button class="button" type="submit">保存到我的价格</button>
              <div class="notice" id="personal-status">登录后即可保存。</div>
            </form>
          </section>
          <section class="tile tile--wide">
            <div class="section__header">
              <h3>价格洞察</h3>
              <p>最便宜价格、门店数量和当前参考。</p>
            </div>
            <div class="hero-banner">
              <div class="hero-banner__inner">
                <div class="pillrow">
                  <span class="pill">最低价 ¥{Math.min(...prices.map((row) => row.price_yen))}</span>
                  <span class="pill">{prices.length} 家门店</span>
                  <span class="pill">最常见采样地点：东京</span>
                </div>
                <p class="product-sub">
                  在真实项目里，这块会按你的位置、收藏和历史记录做二次排序。当前版本已经保留完整的数据结构。
                </p>
              </div>
            </div>
          </section>
        </div>
      </section>
    </div>
  </section>

  <script type="module" define:vars={{ productId: product.id }}>
    import { getCurrentUser, savePersonalLog, formatYen, resolveBase, geolocate, fetchNearbyPrices, formatDistance } from '../../lib/browser.js';

    const form = document.querySelector('#personal-log-form');
    const store = document.querySelector('#personal-store');
    const price = document.querySelector('#personal-price');
    const note = document.querySelector('#personal-note');
    const status = document.querySelector('#personal-status');
    const geoButton = document.querySelector('#geo-sort');
    const geoStatus = document.querySelector('#geo-status');
    const priceList = document.querySelector('#price-list');

    function renderRows(rows) {
      if (!priceList) return;
      priceList.innerHTML = rows.map((row) => `
        <div class="list__item">
          <div>
            <strong>${row.store?.name || row.stores?.name || 'Unknown store'}</strong>
            <small>${row.store?.address || row.stores?.address || ''} · ${row.store?.hours || row.stores?.hours || ''} · ${row.is_member_price ? '会员价' : '公开价'}${row.distance_km !== null && row.distance_km !== undefined ? ` · ${formatDistance(row.distance_km)}` : ''}</small>
          </div>
          <div style="text-align:right;">
            <div class="price">¥${row.price_yen}</div>
            <small>${row.source || 'manual'}</small>
          </div>
        </div>
      `).join('');
    }

    geoButton?.addEventListener('click', async () => {
      if (!geoStatus) return;
      geoStatus.textContent = '正在获取位置...';
      try {
        const location = await geolocate();
        const rows = await fetchNearbyPrices({ productId, lat: location.lat, lng: location.lng, radiusKm: 20 });
        renderRows(rows);
        geoStatus.textContent = `已按当前位置重排，定位点：${location.lat.toFixed(4)}, ${location.lng.toFixed(4)}。`;
      } catch (error) {
        geoStatus.textContent = `定位失败：${error.message}`;
      }
    });

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const user = await getCurrentUser();
      if (!user) {
        status.textContent = '请先登录后再保存。';
        window.location.assign(resolveBase('login/'));
        return;
      }

      try {
        await savePersonalLog({
          product_id: productId,
          store_id: store.value,
          price_yen: Number(price.value),
          note: note.value.trim(),
          purchased_at: new Date().toISOString().slice(0, 10),
        });
        status.textContent = `已保存 ${formatYen(Number(price.value))}。`;
        price.value = '';
        note.value = '';
      } catch (error) {
        status.textContent = `保存失败：${error.message}`;
      }
    });
  </script>
</BaseLayout>
