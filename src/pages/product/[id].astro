---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { fetchPublicProducts } from '../../lib/supabase-rest.js';

type Product = {
  id: string;
  barcode: string;
  name: string;
  brand: string;
  pack: string;
  category: string;
  tone?: string;
  description: string;
};

export async function getStaticPaths() {
  const products = ((await fetchPublicProducts({ limit: 500, order: 'updated_at.desc' })) ?? []) as Product[];
  return products.map((product) => ({ params: { id: product.id }, props: { product } }));
}

const { product } = Astro.props as { product: Product };
---
<BaseLayout title={`${product.name} - Aprice`} description={`${product.name} 的门店价格、附近比价和个人记录。`}>
  <section class="section section--first-workspace" id="product-page" data-product-id={product.id} data-product-name={product.name} data-product-brand={product.brand} data-product-pack={product.pack} data-product-barcode={product.barcode} data-product-tone={product.tone}>
    <div class="shell">
      <div class="eyebrow">Product · 商品工作台</div>
      <div class={`product-hero tone-${product.tone || 'sunset'}`} style="min-height: 210px;">
        <div class="product-hero__overlay" style="gap: 10px; padding: 20px;">
          <div class="pillrow">
            <span class="pill">{product.category}</span>
            <span class="pill">JAN {product.barcode}</span>
            <span class="pill">{product.brand}</span>
          </div>
          <h1 class="product-title" style="font-size: clamp(1.8rem, 4vw, 3rem);">{product.name}</h1>
          <p class="product-sub" style="max-width: 58ch;">{product.description}</p>
          <div class="pillrow">
            <button class="button button--ghost" id="favorite-product-button" type="button">收藏当前商品</button>
            <button class="button button--ghost" id="favorite-store-button" type="button">收藏当前门店</button>
            <span class="pill" id="favorite-status">登录后可一键收藏。</span>
          </div>
        </div>
      </div>

      <div class="grid" style="margin-top:16px;">
        <section class="tile tile--wide tile--flow">
          <div class="section__header section__header--tight">
            <div>
              <h2>价格流</h2>
              <p>同一商品在不同门店和会员条件下的参考价，按当前位置可重排。</p>
            </div>
            <button class="button button--ghost" id="geo-sort" type="button">按当前位置重排</button>
          </div>
          <div class="notice notice--compact" id="geo-status" style="margin-bottom:12px;">正在读取 Supabase 价格。</div>
          <div class="feed" id="price-list">
            <div class="notice notice--compact">正在读取价格，结果会在这里显示。</div>
          </div>
        </section>

        <section class="tile tile--flow">
          <div class="section__header section__header--tight">
            <div>
              <h3>附近门店</h3>
              <p>价格流之外，也能快速扫到门店分布。</p>
            </div>
          </div>
          <div class="notice notice--compact" id="nearby-status" style="margin-bottom:12px;">门店列表会跟着价格一起出现。</div>
          <div class="feed" id="nearby-store-list">
            <div class="notice notice--compact">正在读取门店，价格加载后会同步显示。</div>
          </div>
        </section>
      </div>

      <section class="section">
        <div class="grid">
          <section class="tile">
            <div class="section__header section__header--tight">
              <h3>个人记录</h3>
              <p>把你真实买到的价格直接记下来。</p>
            </div>
            <form class="form" id="personal-log-form">
              <label class="field">
                <select id="personal-store">
                  <option value="">正在加载门店...</option>
                </select>
              </label>
              <div class="grid" style="grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px;">
                <label class="field">
                  <input id="personal-price" type="number" inputmode="numeric" placeholder="你的购买价" />
                </label>
                <label class="field">
                  <input id="personal-note" placeholder="备注" />
                </label>
              </div>
              <button class="button" type="submit">保存到我的价格</button>
              <div class="notice notice--compact" id="personal-status">登录后即可写入个人购买价。</div>
            </form>
          </section>

          <section class="tile tile--wide">
            <div class="section__header section__header--tight">
              <h3>价格摘要</h3>
              <p>最低价、门店数量和最新采样。</p>
            </div>
            <div class="feed">
              <div class="feed__item feed__item--featured" style="padding: 18px;">
                <div class="feed__copy">
                  <div class="feed__kicker">价格摘要</div>
                  <div class="pillrow" id="insight-pills">
                    <span class="pill">同步中</span>
                  </div>
                  <small>页面加载后会用真实 Supabase 价格刷新这里的摘要。</small>
                </div>
                <span class="price">live</span>
              </div>
            </div>
          </section>
        </div>
      </section>

      <section class="section">
        <div class="grid">
          <section class="tile tile--wide tile--flow">
            <div class="section__header section__header--tight">
              <div>
                <h3>近期变化</h3>
                <p>最近几条采样会按时间顺序显示，方便直接看涨跌。</p>
              </div>
            </div>
            <div class="feed" id="trend-list">
              <div class="notice notice--compact">近期价格采样会在这里显示。</div>
            </div>
          </section>
        </div>
      </section>


  <script type="module" is:inline>
    import {
      fetchAllStores,
      fetchNearbyPrices,
      fetchPricesForProduct,
      formatDistance,
      formatYen,
      geolocate,
      getCurrentUser,
      recordRecentView,
      resolveBase,
      savePersonalLog,
      toggleFavorite,
    } from '/aprice/browser.js';

    const page = document.querySelector('#product-page');
    const productId = page?.dataset.productId || '';
    const productName = page?.dataset.productName || '';
    const productBrand = page?.dataset.productBrand || '';
    const productPack = page?.dataset.productPack || '';
    const productBarcode = page?.dataset.productBarcode || '';
    const productTone = page?.dataset.productTone || 'sunset';

    recordRecentView({
      id: productId,
      name: productName,
      brand: productBrand,
      pack: productPack,
      barcode: productBarcode,
      tone: productTone,
    });

    const form = document.querySelector('#personal-log-form');
    const store = document.querySelector('#personal-store');
    const price = document.querySelector('#personal-price');
    const note = document.querySelector('#personal-note');
    const status = document.querySelector('#personal-status');
    const favoriteButton = document.querySelector('#favorite-product-button');
    const favoriteStoreButton = document.querySelector('#favorite-store-button');
    const favoriteStatus = document.querySelector('#favorite-status');
    const geoButton = document.querySelector('#geo-sort');
    const geoStatus = document.querySelector('#geo-status');
    const nearbyStatus = document.querySelector('#nearby-status');
    const priceList = document.querySelector('#price-list');
    const nearbyStoreList = document.querySelector('#nearby-store-list');
    const insightPills = document.querySelector('#insight-pills');
    const trendList = document.querySelector('#trend-list');

    let stores = [];
    let activeStoreId = '';

    function toTime(value) {
      const time = new Date(value || 0).getTime();
      return Number.isFinite(time) ? time : 0;
    }


    function trendMeta(delta) {
      if (delta === null) return { label: '最新', tone: 'trend--flat', arrow: '→' };
      if (delta === 0) return { label: '持平', tone: 'trend--flat', arrow: '→' };
      if (delta > 0) return { label: `上涨 ${formatYen(delta)}`, tone: 'trend--up', arrow: '↑' };
      return { label: `下跌 ${formatYen(Math.abs(delta))}`, tone: 'trend--down', arrow: '↓' };
    }

    function syncFavoriteStoreButton() {
      if (favoriteStoreButton) {
        favoriteStoreButton.disabled = !activeStoreId;
      }
    }

    function renderPrices(rows) {
      if (!priceList) return;
      if (!rows.length) {
        priceList.innerHTML = `
          <div class="feed__item">
            <div>
              <strong>暂无价格</strong>
              <small>这件商品还没有价格记录。</small>
            </div>
            <span class="price">暂无</span>
          </div>
        `;
        return;
      }

      const minPrice = Math.min(...rows.map((row) => row.price_yen));

      priceList.innerHTML = rows.map((row, index) => {
        const gap = row.price_yen - minPrice;
        const gapPercent = minPrice > 0 ? Math.round((gap / minPrice) * 100) : 0;
        const gapTier = gap === 0
          ? { tone: 'trend--flat', label: '最低价', percent: '0%', bar: 'gap--best', ratio: 1 }
          : gap <= 150
            ? { tone: 'trend--up', label: `高 ${formatYen(gap)}`, percent: `+${gapPercent}%`, bar: 'gap--near', ratio: 0.72 }
            : gap <= 400
              ? { tone: 'trend--down', label: `高 ${formatYen(gap)}`, percent: `+${gapPercent}%`, bar: 'gap--mid', ratio: 0.45 }
              : { tone: 'trend--down', label: `高 ${formatYen(gap)}`, percent: `+${gapPercent}%`, bar: 'gap--far', ratio: 0.22 };
        const priceHref = resolveBase(`product/${productId}/`);
        const distanceLabel = row.distance_km !== null && row.distance_km !== undefined ? ` · ${formatDistance(row.distance_km)}` : '';
        const barWidth = Math.max(12, Math.round(gapTier.ratio * 100));
        return index === 0 ? `
          <a class="feed__item feed__item--featured" href="${priceHref}">
            <div class="feed__copy">
              <div class="feed__kicker">最低价 · ${row.is_member_price ? '会员价' : '公开价'}</div>
              <strong>${row.stores?.name || 'Unknown store'}</strong>
              <small>${row.stores?.address || ''} · ${row.stores?.hours || ''}</small>
            </div>
            <div class="feed__meta">
              <div class="price">¥${row.price_yen}</div>
              <small>${row.stores?.city || ''}${distanceLabel}</small>
              <span class="pill ${gapTier.tone}">${gapTier.label}</span>
              <small class="trend__delta ${gapTier.tone}">${gapTier.percent} · ${gapPercent}%</small>
              <div class="price-gap">
                <span class="price-gap__label ${gapTier.bar}">${gapTier.label}</span>
                <span class="price-gap__percent ${gapTier.tone}">${gapTier.percent}</span>
                <span class="price-gap__track"><span class="price-gap__fill ${gapTier.bar}" style="width:${barWidth}%"></span></span>
              </div>
            </div>
          </a>
        ` : `
          <a class="feed__item" href="${priceHref}">
            <div>
              <strong>${row.stores?.name || 'Unknown store'}</strong>
              <small>${row.stores?.address || ''} · ${row.stores?.hours || ''} · ${row.is_member_price ? '会员价' : '公开价'}${distanceLabel}</small>
            </div>
            <div class="feed__meta">
              <span class="price">¥${row.price_yen}</span>
              <span class="pill ${gapTier.tone}">${gapTier.label}</span>
              <small class="trend__delta ${gapTier.tone}">${gapTier.percent} · ${gapPercent}%</small>
              <div class="price-gap">
                <span class="price-gap__track"><span class="price-gap__fill ${gapTier.bar}" style="width:${barWidth}%"></span></span>
              </div>
            </div>
          </a>
        `;
      }).join('');
    }
    function renderNearbyStores(rows) {
      if (!nearbyStoreList) return;
      activeStoreId = rows[0]?.store_id || '';
      syncFavoriteStoreButton();
      nearbyStoreList.innerHTML = rows.length
        ? rows.map((row, index) => index === 0 ? `
          <div class="feed__item feed__item--featured">
            <div class="feed__copy">
              <div class="feed__kicker">当前聚焦</div>
              <strong>${row.stores?.name || 'Unknown store'}</strong>
              <small>${row.stores?.city || ''} · ${row.stores?.pref || ''}</small>
            </div>
            <div class="feed__meta">
              <div class="price">¥${row.price_yen}</div>
              <small>${row.stores?.hours || ''}</small>
              <button class="button button--ghost" type="button" data-favorite-store="${row.store_id}">收藏门店</button>
            </div>
          </div>
        ` : `
          <div class="feed__item">
            <div>
              <strong>${row.stores?.name || 'Unknown store'}</strong>
              <small>${row.stores?.city || ''} · ${row.stores?.pref || ''}</small>
            </div>
            <div class="feed__meta">
              <span class="price">¥${row.price_yen}</span>
              <button class="button button--ghost" type="button" data-favorite-store="${row.store_id}">收藏门店</button>
            </div>
          </div>
        `).join('')
        : `
          <div class="feed__item">
            <div>
              <strong>没有附近数据</strong>
              <small>请先给门店补坐标和价格。</small>
            </div>
            <span class="price">暂无</span>
          </div>
        `;
    }

    function renderInsights(rows) {
      if (!insightPills) return;
      if (!rows.length) {
        insightPills.innerHTML = '<span class="pill">暂无价格数据</span>';
        if (trendList) {
          trendList.innerHTML = `
            <div class="feed__item">
              <div>
                <strong>暂无趋势</strong>
                <small>先插入几条价格记录，趋势会自动出现。</small>
              </div>
              <span class="price">暂无</span>
            </div>
          `;
        }
        return;
      }

      const latest = rows[0];
      const minPrice = Math.min(...rows.map((row) => row.price_yen));
      const maxPrice = Math.max(...rows.map((row) => row.price_yen));
      const storeCount = new Set(rows.map((row) => row.store_id)).size;
      const gapToMin = latest ? latest.price_yen - minPrice : 0;
      const older = rows[1];
      const latestTime = toTime(latest?.collected_at);
      const sevenDaysAgo = latestTime ? latestTime - 7 * 24 * 60 * 60 * 1000 : 0;
      const windowRows = latestTime
        ? rows.filter((row) => toTime(row.collected_at) >= sevenDaysAgo)
        : rows.slice(0, 1);
      const windowFirst = windowRows[windowRows.length - 1];
      const windowLast = windowRows[0];
      const windowDelta = windowFirst && windowLast ? windowLast.price_yen - windowFirst.price_yen : null;
      const windowLabel = windowDelta === null
        ? '近7天暂无趋势'
        : windowDelta === 0
          ? '近7天持平'
          : windowDelta > 0
            ? `近7天上涨 ${formatYen(windowDelta)}`
            : `近7天下降 ${formatYen(Math.abs(windowDelta))}`;
      const priceDelta = older ? latest.price_yen - older.price_yen : null;
      const priceTrend = trendMeta(priceDelta);
      const summaryTrend = trendMeta(windowDelta);
      const trend = gapToMin === 0 ? '当前就是最低价' : (gapToMin > 0 ? `比最低价高 ${formatYen(gapToMin)}` : `比最低价低 ${formatYen(Math.abs(gapToMin))}`);
      const gapLabel = gapToMin === 0
        ? '与最低价相同'
        : gapToMin > 0
          ? `比最低价高 ${formatYen(gapToMin)}`
          : `比最低价低 ${formatYen(Math.abs(gapToMin))}`;
      const change = priceDelta === null
        ? '暂无上次采样'
        : priceDelta === 0
          ? '较上次采样持平'
          : priceDelta > 0
            ? `较上次采样涨 ${formatYen(priceDelta)}`
            : `较上次采样降 ${formatYen(Math.abs(priceDelta))}`;

      insightPills.innerHTML = `
        <span class="pill">最低价 ¥${minPrice}</span>
        <span class="pill">最高价 ¥${maxPrice}</span>
        <span class="pill">${storeCount} 家门店</span>
        <span class="pill ${priceTrend.tone}">${priceTrend.arrow} ${trend}</span>
        <span class="pill ${priceTrend.tone}">${priceTrend.arrow} ${gapLabel}</span>
        <span class="pill ${priceTrend.tone}">${priceTrend.arrow} ${change}</span>
        <span class="pill ${priceTrend.tone}">${priceTrend.arrow} ${priceTrend.label}</span>
        <span class="pill ${summaryTrend.tone}">${summaryTrend.arrow} ${windowLabel}</span>
        <span class="pill">最新采样：${latest?.stores?.name || 'unknown'}</span>
      `;

      if (trendList) {
        trendList.innerHTML = rows.slice(0, 4).map((row, index) => {
          const nextRow = rows[index + 1];
          const delta = nextRow ? row.price_yen - nextRow.price_yen : null;
          const deltaLabel = delta === null
            ? '最新'
            : delta === 0
              ? '持平'
              : delta > 0
                ? `+${formatYen(delta)}`
                : `-${formatYen(Math.abs(delta))}`;
          return index === 0 ? `
            <div class="feed__item feed__item--featured">
              <div class="feed__copy">
                <div class="feed__kicker ${summaryTrend.tone}">${summaryTrend.arrow} ${windowLabel}</div>
                <strong>${row.stores?.name || 'Unknown store'}</strong>
                <small>${row.stores?.city || ''} · ${row.stores?.pref || ''} · ${row.is_member_price ? '会员价' : '公开价'}</small>
              </div>
              <div class="feed__meta">
                <div class="price">${formatYen(row.price_yen)}</div>
                <small class="trend__delta">${deltaLabel}</small>
              </div>
            </div>
          ` : `
            <div class="feed__item">
              <div>
                <strong>${row.stores?.name || 'Unknown store'}</strong>
                <small>${row.stores?.city || ''} · ${row.stores?.pref || ''} · ${row.is_member_price ? '会员价' : '公开价'}</small>
              </div>
              <div class="feed__meta">
                <span class="price">${formatYen(row.price_yen)}</span>
                <small class="trend__delta">${deltaLabel}</small>
              </div>
            </div>
          `;
        }).join('');
      }
    }

    async function loadPrices() {
      const rows = await fetchPricesForProduct(productId);
      renderPrices(rows);
      renderNearbyStores(rows);
      renderInsights(rows);
      if (store && stores.length) {
        store.innerHTML = stores.map((item) => `<option value="${item.id}">${item.name}</option>`).join('');
      }
      if (geoStatus) geoStatus.textContent = rows.length ? `已加载 ${rows.length} 条价格记录。` : `当前还没有 ${productName} 的价格记录。`;
      if (nearbyStatus) nearbyStatus.textContent = rows.length ? `已显示 ${rows.length} 条门店价格。` : '先补第一条价格，再看门店流。';
    }

    async function loadStores() {
      stores = await fetchAllStores();
      if (store) {
        store.innerHTML = stores.length
          ? stores.map((item) => `<option value="${item.id}">${item.name}</option>`).join('')
          : '<option value="">暂无门店</option>';
      }
    }

    favoriteButton?.addEventListener('click', async () => {
      const user = await getCurrentUser();
      if (!user) {
        if (favoriteStatus) favoriteStatus.textContent = '请先登录后再收藏。';
        window.location.assign(resolveBase('login/'));
        return;
      }

      try {
        const result = await toggleFavorite('product', productId);
        if (favoriteStatus) {
          favoriteStatus.textContent = result.action === 'added' ? '已收藏当前商品。' : '已取消收藏。';
        }
      } catch (error) {
        if (favoriteStatus) favoriteStatus.textContent = `收藏失败：${error.message}`;
      }
    });

    favoriteStoreButton?.addEventListener('click', async () => {
      const user = await getCurrentUser();
      if (!user) {
        if (favoriteStatus) favoriteStatus.textContent = '请先登录后再收藏门店。';
        window.location.assign(resolveBase('login/'));
        return;
      }

      if (!activeStoreId) {
        if (favoriteStatus) favoriteStatus.textContent = '当前还没有可收藏的门店。';
        return;
      }

      try {
        const result = await toggleFavorite('store', activeStoreId);
        if (favoriteStatus) {
          favoriteStatus.textContent = result.action === 'added' ? '已收藏当前门店。' : '已取消门店收藏。';
        }
      } catch (error) {
        if (favoriteStatus) favoriteStatus.textContent = `收藏失败：${error.message}`;
      }
    });

    nearbyStoreList?.addEventListener('click', async (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;
      const storeId = target.dataset.favoriteStore;
      if (!storeId) return;

      const user = await getCurrentUser();
      if (!user) {
        if (favoriteStatus) favoriteStatus.textContent = '请先登录后再收藏门店。';
        window.location.assign(resolveBase('login/'));
        return;
      }

      try {
        const result = await toggleFavorite('store', storeId);
        if (favoriteStatus) {
          favoriteStatus.textContent = result.action === 'added' ? '已收藏门店。' : '已取消门店收藏。';
        }
      } catch (error) {
        if (favoriteStatus) favoriteStatus.textContent = `收藏失败：${error.message}`;
      }
    });

    geoButton?.addEventListener('click', async () => {
      if (!geoStatus) return;
      geoStatus.textContent = '正在获取位置...';
      try {
        const location = await geolocate();
        const rows = await fetchNearbyPrices({ productId, lat: location.lat, lng: location.lng, radiusKm: 20 });
        renderPrices(rows);
        renderNearbyStores(rows);
        renderInsights(rows);
        geoStatus.textContent = `已按当前位置重排，定位点：${location.lat.toFixed(4)}, ${location.lng.toFixed(4)}。`;
        if (nearbyStatus) nearbyStatus.textContent = rows.length ? `已按当前位置筛出 ${rows.length} 条门店价格。` : '当前位置附近还没有可比价格。';
      } catch (error) {
        geoStatus.textContent = `定位失败：${error.message}`;
      }
    });

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const user = await getCurrentUser();
      if (!user) {
        status.textContent = '请先登录后再保存。';
        window.location.assign(resolveBase('login/'));
        return;
      }

      try {
        await savePersonalLog({
          product_id: productId,
          store_id: store.value,
          price_yen: Number(price.value),
          note: note.value.trim(),
          purchased_at: new Date().toISOString().slice(0, 10),
        });
        status.textContent = `已保存 ${formatYen(Number(price.value))}。`;
        price.value = '';
        note.value = '';
      } catch (error) {
        status.textContent = `保存失败：${error.message}`;
      }
    });

    Promise.all([loadStores(), loadPrices()]);
  </script>
</BaseLayout>











