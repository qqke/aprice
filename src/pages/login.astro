---
import BaseLayout from '../layouts/BaseLayout.astro';
import { resolveBase } from '../lib/browser.js';

export const prerender = true;
---
<BaseLayout title="登录 - 搜比价" description="邮箱密码登录、注册和重置密码。" bodyClass="login-page">
  <section class="section section--first-workspace">
    <div class="shell">
      <div class="section__header section__header--tight">
        <div>
          <div class="eyebrow">登录</div>
          <h1 class="product-title">邮箱密码登录后，个人数据可用。</h1>
          <p class="product-sub">本页提供邮箱密码注册、登录和找回密码。</p>
        </div>
        <div class="pillrow">
          <span class="pill">邮箱密码</span>
        </div>
      </div>

      <div class="grid">
        <section class="tile tile--wide tile--flow">
          <div class="section__header section__header--tight">
            <div>
              <h3 id="auth-panel-title">登录账号</h3>
              <p id="auth-panel-description">输入邮箱和密码即可登录，或切换到注册、找回密码。</p>
            </div>
            <span class="pill" id="auth-panel-pill">登录</span>
          </div>

          <div class="stack login-state" id="signed-in-state" hidden>
            <div class="notice notice--compact" id="signed-in-message" role="status" aria-live="polite" aria-atomic="true">账号已登录。</div>
            <div class="list__item login-state__card">
              <div>
                <strong id="signed-in-label">当前账号</strong>
                <small id="signed-in-subtitle">可打开个人页。</small>
              </div>
              <span class="meta" id="signed-in-role">member</span>
            </div>
            <div class="pillrow login-state__actions">
              <a class="button" id="signed-in-action" href={resolveBase('me/')}>打开个人页</a>
              <button class="button button--ghost" type="button" id="switch-account-button">切换账号</button>
            </div>
          </div>

          <div id="auth-form-shell">
            <form class="form auth-form" id="auth-form">
              <label class="field" for="email" id="email-field">
                <input id="email" type="email" placeholder="name@example.com" autocomplete="email" aria-label="邮箱地址" required />
              </label>
              <label class="field" for="password" id="password-field">
                <input id="password" type="password" placeholder="至少 8 位密码" autocomplete="current-password" aria-label="密码" required />
              </label>
              <label class="field" for="confirm-password" id="confirm-field" hidden>
                <input id="confirm-password" type="password" placeholder="再次输入密码" autocomplete="new-password" aria-label="确认密码" />
              </label>
              <div class="pillrow auth-form__actions">
                <button class="button" type="submit" id="auth-submit">登录</button>
                <button class="button button--ghost" type="button" id="mode-toggle">切换到注册</button>
                <button class="button button--ghost" type="button" id="forgot-toggle">忘记密码</button>
              </div>
              <div class="notice notice--compact" id="auth-status" role="status" aria-live="polite" aria-atomic="true">登录后保存价格与收藏。</div>
            </form>

            <div class="divider"></div>
            <div class="stack auth-form__footer">
              <div class="notice notice--compact" id="auth-hint" role="status" aria-live="polite" aria-atomic="true">登录状态已保留。</div>
              <a class="button button--ghost" href={resolveBase('')}>返回首页继续搜索</a>
            </div>
          </div>
        </section>

        <section class="tile tile--flow">
          <div class="section__header section__header--tight">
            <div>
              <h3>账号状态</h3>
              <p>当前账号状态。</p>
            </div>
          </div>

          <div class="list" id="session-state" role="status" aria-live="polite" aria-atomic="true">
            <div class="notice notice--compact">未登录，登录后可保存价格与收藏。</div>
          </div>

          <div class="divider"></div>
          <button class="button button--ghost" id="logout-button" type="button" hidden>退出登录</button>
        </section>
      </div>
    </div>
  </section>

  <script type="module" is:inline>
    const { resolveBase } = await import(window.__APriceConfig?.browserJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'browser.js');
    const { normalizeInternalRedirectTarget } = await import(window.__APriceConfig?.authRedirectJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'auth-redirect.js');
    const loginStateUrl = window.__APriceConfig?.loginPageStateJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'login-page-state.js';
    const {
      formatAuthError,
      getInitialLoginMode,
      getLoginPanelCopy,
      getPostLoginTarget,
      isSignedInSessionHint,
      readSessionHint,
      validateLoginInputs,
      writeSessionHint,
    } = await import(loginStateUrl);
    let authModulePromise = null;
    let unsubscribeAuth = null;
    let currentSession = null;
    let authRefreshStarted = false;
    let authRefreshTimer = null;
    const url = new URL(window.location.href);
    const basePath = new URL(resolveBase(''), window.location.origin).pathname;
    const loginPath = new URL(resolveBase('login/'), window.location.origin).pathname;
    const redirectTarget = normalizeInternalRedirectTarget(url.searchParams.get('redirect'), {
      origin: window.location.origin,
      basePath,
      loginPath,
    });

    function loadAuthModule() {
      authModulePromise ??= import(window.__APriceConfig?.browserAuthJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'browser-auth.js');
      return authModulePromise;
    }

    const form = document.querySelector('#auth-form');
    const emailInput = document.querySelector('#email');
    const passwordInput = document.querySelector('#password');
    const confirmPasswordInput = document.querySelector('#confirm-password');
    const status = document.querySelector('#auth-status');
    const hint = document.querySelector('#auth-hint');
    const sessionState = document.querySelector('#session-state');
    const logoutButton = document.querySelector('#logout-button');
    const modeToggle = document.querySelector('#mode-toggle');
    const forgotToggle = document.querySelector('#forgot-toggle');
    const submitButton = document.querySelector('#auth-submit');
    const panelTitle = document.querySelector('#auth-panel-title');
    const panelDescription = document.querySelector('#auth-panel-description');
    const panelPill = document.querySelector('#auth-panel-pill');
    const emailField = document.querySelector('#email-field');
    const passwordField = document.querySelector('#password-field');
    const confirmField = document.querySelector('#confirm-field');
    const authFormShell = document.querySelector('#auth-form-shell');
    const signedInState = document.querySelector('#signed-in-state');
    const signedInMessage = document.querySelector('#signed-in-message');
    const signedInLabel = document.querySelector('#signed-in-label');
    const signedInSubtitle = document.querySelector('#signed-in-subtitle');
    const signedInRole = document.querySelector('#signed-in-role');
    const signedInAction = document.querySelector('#signed-in-action');
    const switchAccountButton = document.querySelector('#switch-account-button');

    const initialMode = getInitialLoginMode(url);
    let mode = initialMode;
    const hasSessionHint = isSignedInSessionHint();

    // 根据当前模式切换表单字段、按钮文案和提示，保持一个页面覆盖注册、登录和找回密码。
    function setMode(nextMode) {
      mode = nextMode;
      const config = getLoginPanelCopy(mode, { redirectTarget });
      if (!config) return;

      if (panelTitle) panelTitle.textContent = config.title;
      if (panelDescription) panelDescription.textContent = config.description;
      if (panelPill) panelPill.textContent = config.pill;
      if (submitButton) submitButton.textContent = config.submit;
      if (modeToggle) modeToggle.textContent = config.modeToggle;
      if (forgotToggle) forgotToggle.textContent = config.forgotToggle;
      if (hint) hint.textContent = config.hint;
      if (status && !status.dataset.locked) {
        status.textContent = config.status;
      }

      const showPassword = mode !== 'request-reset';
      const showConfirm = mode === 'register' || mode === 'reset-password';

      if (emailField) emailField.hidden = false;
      if (emailInput) {
        emailInput.required = mode !== 'reset-password';
      }
      if (passwordField) passwordField.hidden = !showPassword;
      if (confirmField) confirmField.hidden = !showConfirm;

      if (passwordInput) {
        passwordInput.required = showPassword;
        passwordInput.autocomplete = mode === 'login' ? 'current-password' : 'new-password';
      }
      if (confirmPasswordInput) {
        confirmPasswordInput.required = showConfirm;
        confirmPasswordInput.value = '';
      }

      syncAuthPanels();
    }

    // 根据当前登录状态和当前模式，决定是展示邮箱密码表单还是已登录摘要。
    function syncAuthPanels() {
      const showForm = !currentSession || mode === 'reset-password';
      if (authFormShell) authFormShell.hidden = !showForm;
      if (signedInState) signedInState.hidden = showForm || !currentSession;
      if (logoutButton) logoutButton.hidden = !currentSession;
    }

    function showSignedInSkeleton() {
      if (mode !== 'login') return;
      if (authFormShell) authFormShell.hidden = true;
      if (signedInState) signedInState.hidden = false;
      if (sessionState) {
        sessionState.innerHTML = `
          <div class="list__item">
            <div>
              <strong>已登录</strong>
              <small>已登录。</small>
            </div>
            <span class="meta">member</span>
          </div>
        `;
      }
      if (panelTitle) panelTitle.textContent = '账号状态';
      if (panelDescription) panelDescription.textContent = '账号已登录。';
      if (panelPill) panelPill.textContent = '已登录';
      if (signedInMessage) signedInMessage.textContent = '账号已登录。';
      if (signedInLabel) signedInLabel.textContent = '当前账号';
      if (signedInSubtitle) signedInSubtitle.textContent = redirectTarget ? '可返回原页面。' : '可打开个人页。';
      if (signedInRole) signedInRole.textContent = 'member';
      if (signedInAction) {
        signedInAction.textContent = redirectTarget ? '继续访问' : '打开个人页';
        signedInAction.href = redirectTarget || resolveBase('me/');
      }
    }

    // 读取登录状态并渲染顶部状态卡，登录、登出和重置后都会自动刷新。
    async function refreshSession() {
      try {
        const { getSession, fetchCurrentProfile } = await loadAuthModule();
        const session = await getSession();
        currentSession = session ?? null;

        if (session?.user) {
          writeSessionHint('signed-in');
        } else {
          writeSessionHint(null);
        }

        if (!session?.user) {
          const config = getLoginPanelCopy(mode, { redirectTarget });
          sessionState.innerHTML = `
            <div class="list__item">
              <div>
                <strong>未登录</strong>
                <small>${mode === 'request-reset' ? '输入邮箱发送重置链接。' : '使用邮箱密码继续登录。'}</small>
              </div>
              <span class="meta">guest</span>
            </div>
          `;
          if (mode === 'login') {
            if (panelTitle) panelTitle.textContent = config.title;
            if (panelDescription) panelDescription.textContent = config.description;
            if (panelPill) panelPill.textContent = config.pill;
          }
          if (mode === 'reset-password' && status) {
            status.textContent = '请通过重置链接进入，再设置新密码。';
          }
          syncAuthPanels();
          return;
        }

        const profile = await fetchCurrentProfile();
        const role = profile?.role || 'member';
        const isAdmin = role === 'admin';
        const label = profile?.full_name || session.user.email || '已登录用户';
        const actionLabel = redirectTarget ? '继续访问' : isAdmin ? '打开管理页' : '打开个人页';
        const actionHref = getPostLoginTarget(redirectTarget, resolveBase(isAdmin ? 'admin/' : 'me/'));
        sessionState.innerHTML = `
          <div class="list__item">
            <div>
              <strong>${label}</strong>
              <small>可打开${isAdmin ? '管理页' : '个人页'}。</small>
            </div>
            <span class="meta">${role}</span>
          </div>
        `;
        if (mode === 'reset-password' && status) {
          status.textContent = '已获取重置会话，可直接更新新密码。';
        } else {
          if (panelTitle) panelTitle.textContent = '账号状态';
          if (panelDescription) panelDescription.textContent = redirectTarget ? '账号已登录，可返回原页面。' : `账号已登录，可打开${isAdmin ? '管理页' : '个人页'}。`;
          if (panelPill) panelPill.textContent = '已登录';
          if (signedInMessage) signedInMessage.textContent = '账号已登录。';
          if (signedInLabel) signedInLabel.textContent = label;
          if (signedInSubtitle) signedInSubtitle.textContent = redirectTarget ? '可返回原页面。' : `可打开${isAdmin ? '管理页' : '个人页'}。`;
          if (signedInRole) signedInRole.textContent = role;
          if (signedInAction) {
            signedInAction.textContent = actionLabel;
            signedInAction.href = actionHref;
          }
        }
        syncAuthPanels();
      } catch (error) {
        sessionState.innerHTML = `
          <div class="list__item">
            <div>
              <strong>无法读取会话</strong>
              <small>${error.message}</small>
            </div>
            <span class="meta">error</span>
          </div>
        `;
        currentSession = null;
        syncAuthPanels();
      }
    }

    async function handleSubmit(event) {
      event.preventDefault();
      const submitMode = mode;
      if (status) {
        status.dataset.locked = 'true';
        status.textContent = '处理中...';
      }

      const validationMessage = validateLoginInputs({
        mode: submitMode,
        email: emailInput?.value.trim() || '',
        password: passwordInput?.value || '',
        confirmPassword: confirmPasswordInput?.value || '',
      });
      if (validationMessage) {
        if (status) {
          status.textContent = validationMessage;
          delete status.dataset.locked;
        }
        return;
      }

      const email = emailInput?.value.trim() || '';
      const password = passwordInput?.value || '';

      try {
        if (submitMode === 'login') {
          const { signInWithEmailPassword } = await loadAuthModule();
          await signInWithEmailPassword({ email, password });
          writeSessionHint('signed-in');
          if (status) status.textContent = '登录成功。';
          window.location.assign(getPostLoginTarget(redirectTarget, resolveBase('')));
          return;
        } else if (submitMode === 'register') {
          const { signUpWithEmailPassword } = await loadAuthModule();
          const result = await signUpWithEmailPassword({ email, password, redirect: redirectTarget });
          if (emailInput) emailInput.value = email;
          if (passwordInput) passwordInput.value = '';
          if (confirmPasswordInput) confirmPasswordInput.value = '';
          setMode('login');
          if (result?.session) {
            writeSessionHint('signed-in');
            window.location.assign(getPostLoginTarget(redirectTarget, resolveBase('')));
            return;
          }
          if (status) {
            status.textContent = '注册成功，请检查邮箱。';
          }
        } else if (submitMode === 'request-reset') {
          const { sendPasswordResetEmail } = await loadAuthModule();
          await sendPasswordResetEmail({ email, redirect: redirectTarget });
          if (status) status.textContent = '重置链接已发送。';
        } else if (submitMode === 'reset-password') {
          const { updatePassword } = await loadAuthModule();
          await updatePassword(password);
          writeSessionHint('signed-in');
          setMode('login');
          if (passwordInput) passwordInput.value = '';
          if (confirmPasswordInput) confirmPasswordInput.value = '';
          if (status) status.textContent = '密码已更新。';
          window.location.assign(getPostLoginTarget(redirectTarget, resolveBase('')));
          return;
        }
      } catch (error) {
        if (status) status.textContent = `操作失败：${formatAuthError(error, submitMode)}`;
      } finally {
        if (status) delete status.dataset.locked;
        if (submitMode !== 'reset-password') {
          await refreshSession();
        }
      }
    }

    modeToggle?.addEventListener('click', () => {
      if (mode === 'request-reset' || mode === 'reset-password') {
        setMode('login');
        return;
      }
      setMode(mode === 'login' ? 'register' : 'login');
    });

    forgotToggle?.addEventListener('click', () => {
      if (mode === 'reset-password' || mode === 'request-reset') {
        setMode('login');
        return;
      }
      setMode('request-reset');
    });

    form?.addEventListener('submit', handleSubmit);

    // 切换账号会先退出当前账号，然后重新展开登录表单。
    switchAccountButton?.addEventListener('click', async () => {
      const { signOut } = await loadAuthModule();
      await signOut();
      writeSessionHint(null);
      setMode('login');
      if (status) {
        status.dataset.locked = 'true';
        status.textContent = '已切换账号，请重新登录。';
        delete status.dataset.locked;
      }
      await refreshSession();
    });

    logoutButton?.addEventListener('click', async () => {
      const { signOut } = await loadAuthModule();
      await signOut();
      writeSessionHint(null);
      if (status) {
        status.dataset.locked = 'true';
        status.textContent = '已退出登录。';
        delete status.dataset.locked;
      }
      setMode('login');
      await refreshSession();
      window.location.assign(resolveBase(''));
    });

    // 监听 Supabase auth state change，保证登录 / 登出 / 恢复密码后当前页同步刷新。
    function startAuthRefresh() {
      if (authRefreshStarted) return;
      authRefreshStarted = true;
      if (authRefreshTimer) {
        window.clearTimeout(authRefreshTimer);
        authRefreshTimer = null;
      }
      refreshSession();
      loadAuthModule()
        .then(({ subscribeAuthState }) => {
          if (unsubscribeAuth) return;
          return subscribeAuthState(() => {
            refreshSession();
          }).then((unsubscribe) => {
            unsubscribeAuth = unsubscribe;
          });
        })
        .catch(() => {});
    }

    function armAuthRefresh() {
      if (authRefreshStarted) return;
      if (readSessionHint() === 'signed-in') {
        startAuthRefresh();
        return;
      }
      authRefreshTimer = window.setTimeout(startAuthRefresh, 1400);
      window.addEventListener('pointerdown', startAuthRefresh, { once: true, passive: true });
      window.addEventListener('keydown', startAuthRefresh, { once: true });
    }

    setMode(mode);
    if (hasSessionHint) {
      showSignedInSkeleton();
    }
    armAuthRefresh();

    window.addEventListener('beforeunload', () => {
      unsubscribeAuth?.();
      if (authRefreshTimer) {
        window.clearTimeout(authRefreshTimer);
      }
    });
  </script>
</BaseLayout>
