---
import BaseLayout from '../layouts/BaseLayout.astro';
import { resolveBase } from '../lib/browser.js';
---
<BaseLayout title="登录 - Aprice" description="Supabase 邮箱魔法链接登录，适合静态站点部署。">
  <section class="section section--first-workspace">
    <div class="shell">
      <div class="section__header section__header--tight">
        <div>
          <div class="eyebrow">Auth · 登录入口</div>
          <h1 class="product-title" style="font-size: clamp(1.8rem, 3.8vw, 3rem);">邮箱登录后，个人数据才会生效。</h1>
          <p class="product-sub">这个页面只负责 Supabase 魔法链接登录和当前会话检查。</p>
        </div>
        <div class="pillrow">
          <span class="pill">Supabase Auth</span>
        </div>
      </div>

      <div class="grid">
        <section class="tile tile--wide tile--flow">
          <div class="section__header section__header--tight">
            <div>
              <h3>发送登录链接</h3>
              <p>输入邮箱，我们会把登录邮件发到你的收件箱。</p>
            </div>
            <span class="pill">Secure</span>
          </div>

          <form class="form" id="login-form">
            <label class="field" for="email">
              <input id="email" type="email" placeholder="name@example.com" autocomplete="email" required />
            </label>
            <button class="button" type="submit">发送登录链接</button>
            <div class="notice notice--compact" id="login-status">登录后可以保存个人价格记录、收藏商品和门店。</div>
          </form>

          <div class="divider"></div>
          <div class="stack">
            <div class="notice notice--compact">登录邮件通常会在几秒内送达。完成跳转后，返回本站即可继续使用个人功能。</div>
            <a class="button button--ghost" href={resolveBase('')}>返回首页继续搜索</a>
          </div>
        </section>

        <section class="tile tile--flow">
          <div class="section__header section__header--tight">
            <div>
              <h3>当前会话</h3>
              <p>这里显示登录状态和 profile 角色。</p>
            </div>
          </div>

          <div class="list" id="session-state">
            <div class="list__item">
              <div>
                <strong>正在检查会话</strong>
                <small>页面会自动检查当前会话。</small>
              </div>
              <span class="meta">status</span>
            </div>
          </div>

          <div class="divider"></div>
          <button class="button button--ghost" id="logout-button" type="button">退出登录</button>
        </section>
      </div>
    </div>
  </section>

  <script type="module" is:inline>
    import { fetchCurrentProfile, getSession, resolveBase, sendMagicLink, signOut } from '/aprice/browser.js';

    const form = document.querySelector('#login-form');
    const input = document.querySelector('#email');
    const status = document.querySelector('#login-status');
    const sessionState = document.querySelector('#session-state');
    const logoutButton = document.querySelector('#logout-button');

    async function refreshSession() {
      try {
        const session = await getSession();
        if (!session?.user) {
          sessionState.innerHTML = `
            <div class="list__item">
              <div>
                <strong>未登录</strong>
                <small>你可以使用邮箱魔法链接继续。</small>
              </div>
              <span class="meta">guest</span>
            </div>
          `;
          return;
        }

        const profile = await fetchCurrentProfile();
        const role = profile?.role || 'member';
        const label = profile?.full_name || session.user.email || '已登录用户';
        const subtitle = role === 'admin' ? '管理员权限已开启' : '可以继续保存个人价格和收藏';
        sessionState.innerHTML = `
          <div class="list__item">
            <div>
              <strong>${label}</strong>
              <small>${subtitle}</small>
            </div>
            <span class="meta">${role}</span>
          </div>
        `;
      } catch (error) {
        sessionState.innerHTML = `
          <div class="list__item">
            <div>
              <strong>无法读取会话</strong>
              <small>${error.message}</small>
            </div>
            <span class="meta">error</span>
          </div>
        `;
      }
    }

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const email = input.value.trim();
      if (!email) return;

      status.textContent = '正在发送登录链接...';
      try {
        await sendMagicLink(email);
        status.textContent = '登录链接已发送。打开邮件完成登录，然后回到本站即可。';
      } catch (error) {
        status.textContent = `发送失败：${error.message}`;
      }
      await refreshSession();
    });

    logoutButton?.addEventListener('click', async () => {
      await signOut();
      status.textContent = '已退出登录。';
      await refreshSession();
      window.location.assign(resolveBase(''));
    });

    refreshSession();
  </script>
</BaseLayout>








