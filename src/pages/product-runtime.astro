---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;
const base = import.meta.env.BASE_URL || '/';
---
<BaseLayout title="正在打开商品详情 - 搜比价" description="正在打开完整商品详情页。" bodyClass="product-page">
  <section class="section section--first-workspace" id="product-runtime-page" data-base={base}>
    <div class="shell">
      <div class="eyebrow">商品</div>
      <div class="tile tile--wide tile--flow">
        <div class="section__header section__header--tight">
          <div>
            <h1 class="product-title" id="runtime-product-title">正在打开完整商品页...</h1>
            <p class="product-sub" id="runtime-product-sub">请稍候，正在转到包含个人记录和收藏状态的商品详情。</p>
          </div>
        </div>
        <div class="pillrow" id="runtime-product-actions">
          <span class="pill">跳转中</span>
        </div>
      </div>
    </div>
  </section>

  <script type="module" is:inline>
    const { resolveBase } = await import(window.__APriceConfig?.browserJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'browser.js');

    const title = document.querySelector('#runtime-product-title');
    const sub = document.querySelector('#runtime-product-sub');
    const actions = document.querySelector('#runtime-product-actions');

    function readProductId() {
      const url = new URL(window.location.href);
      return String(url.searchParams.get('id') || '').trim();
    }

    function isFallbackVisit() {
      const url = new URL(window.location.href);
      return url.searchParams.get('fallback') === '1';
    }

    function escapePathSegment(value) {
      return encodeURIComponent(value).replaceAll('%2F', '');
    }

    const productId = readProductId();
    if (productId) {
      const target = resolveBase(`product/${escapePathSegment(productId)}/`);
      if (actions) {
        actions.innerHTML = `<a class="button" href="${target}">打开完整详情</a>`;
      }
      if (isFallbackVisit()) {
        if (title) title.textContent = '完整商品页暂时没有命中';
        if (sub) sub.textContent = '可以重新打开完整详情，或回到扫码页继续查询。';
        if (actions) {
          actions.innerHTML = `
            <a class="button" href="${target}">重新打开完整详情</a>
            <a class="button button--ghost" href="${resolveBase('scan/')}">去扫码</a>
          `;
        }
      } else {
        window.location.replace(target);
      }
    } else {
      if (title) title.textContent = '缺少商品编号';
      if (sub) sub.textContent = 'URL 里没有商品 id，返回首页或扫码重新打开。';
      if (actions) {
        actions.innerHTML = `
          <a class="button" href="${resolveBase('scan/')}">去扫码</a>
          <a class="button button--ghost" href="${resolveBase('')}">返回首页</a>
        `;
      }
    }
  </script>
</BaseLayout>
