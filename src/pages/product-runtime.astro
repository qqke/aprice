---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;
const base = import.meta.env.BASE_URL || '/';
---
<BaseLayout title="商品详情 - 搜比价" description="商品详情、门店价格与个人记录。" bodyClass="product-page">
  <section class="section section--first-workspace" id="product-runtime-page" data-base={base}>
    <div class="shell">
      <div class="eyebrow">商品</div>
      <div class="product-hero tone-sunset" id="runtime-product-hero">
        <div class="product-hero__overlay">
          <div class="pillrow product-hero__meta" id="runtime-product-meta">
            <span class="pill">读取中</span>
          </div>
          <h1 class="product-title" id="runtime-product-title">正在加载商品...</h1>
          <p class="product-sub" id="runtime-product-sub">请稍候，正在拉取商品信息、门店价格和个人记录。</p>
          <div class="notice notice--compact product-hero__hint">先看最低价，再记买价。</div>
          <div class="product-hero__actions" aria-label="商品页主要操作">
            <button class="button" id="favorite-product-button" type="button">添加商品收藏</button>
            <a class="button button--ghost" href="#product-personal-record">记录买价</a>
          </div>
        </div>
      </div>

      <div class="notice notice--warning" id="product-auth-gate">
        <div class="stack">
          <strong>登录后可保存个人记录</strong>
          <small>登录后可收藏商品、保存个人价格记录，并在不同设备间同步。</small>
        </div>
        <a class="button" id="product-login-link" href={`${base}login/`}>登录</a>
      </div>

      <div class="grid product-grid-top">
        <section class="tile tile--wide tile--flow" id="product-price-flow">
          <div class="section__header section__header--tight">
            <div>
              <h2>价格流</h2>
              <p>同一商品在不同门店和会员条件下的参考价。</p>
            </div>
            <button class="button button--ghost" id="geo-sort" type="button">按当前位置排序</button>
          </div>
          <div class="product-price-flow__lead" aria-label="价格流摘要">
            <div class="product-price-flow__lead-copy">
              <span class="product-price-flow__lead-label">当前最低价</span>
              <strong id="price-flow-min-price">同步中</strong>
              <small id="price-flow-store">等待价格数据</small>
            </div>
            <div class="product-price-flow__lead-aside">
              <span class="pill" id="price-flow-gap-pill">等待价格</span>
              <small id="price-flow-gap-note">补上第一组门店价格后，会显示最低价和次低价差。</small>
            </div>
          </div>
          <div class="notice notice--compact" id="geo-status">价格结果。</div>
          <div class="feed" id="price-list">
            <div class="notice notice--compact">正在加载价格...</div>
          </div>
        </section>

        <section class="tile tile--flow" id="product-personal-record">
          <div class="section__header section__header--tight">
            <div>
              <h3>记录店头价格</h3>
              <p>把实体店货架价记下来，也可以提交给公共比价审核。</p>
            </div>
          </div>
          <div class="pillrow product-secondary-actions" aria-label="收藏操作">
            <button class="button button--ghost" id="favorite-store-button" type="button">添加门店收藏</button>
          </div>
          <div class="store-search">
            <label class="field store-search__input">
              <input id="personal-store-search" name="personal-store-search" type="search" inputmode="search" placeholder="搜索店名或连锁名" autocomplete="off" spellcheck="false" aria-label="搜索门店" />
            </label>
            <button class="button button--ghost store-search__clear" id="personal-store-search-clear" type="button" hidden>清空</button>
          </div>
          <div class="notice notice--compact" id="personal-store-status">正在加载门店...</div>
          <div class="feed" id="personal-store-list">
            <div class="notice notice--compact">正在加载门店...</div>
          </div>
          <button class="button button--ghost store-search__load-more" id="personal-store-load-more" type="button" hidden>加载更多</button>
          <form class="form" id="personal-log-form">
            <input id="personal-store" type="hidden" value="" />
            <div class="grid grid--two">
              <label class="field">
                <input id="personal-price" name="personal-price" type="number" inputmode="numeric" placeholder="你的购买价" />
              </label>
              <label class="field">
                <input id="personal-note" name="personal-note" placeholder="备注" />
              </label>
            </div>
            <label class="field">
              <input id="personal-evidence-url" name="personal-evidence-url" type="url" placeholder="价签或小票图片链接（可选）" />
            </label>
            <label class="field field--inline">
              <input id="personal-share-public" type="checkbox" checked />
              <span>参与公共比价（提交后由管理员审核）</span>
            </label>
            <button class="button" type="submit">提交店头价格</button>
            <div class="notice notice--compact" id="personal-status">登录后可提交真实店头价；参与公共比价的记录会先进入审核。</div>
          </form>
        </section>
      </div>
    </div>
  </section>

  <script type="module" is:inline>
    function readInitialProductId() {
      const url = new URL(window.location.href);
      const fromQuery = String(url.searchParams.get('id') || '').trim();
      if (fromQuery) return fromQuery;
      const match = url.pathname.match(/\/product\/([^/]+)\/?$/);
      return match?.[1] ? decodeURIComponent(match[1]) : '';
    }

    function restoreProductUrlBeforeLoading() {
      const initialProductId = readInitialProductId();
      if (!initialProductId || !window.history?.replaceState) return;
      const runtimeBase = window.__APriceConfig?.baseUrl || '/';
      const base = runtimeBase.endsWith('/') ? runtimeBase : `${runtimeBase}/`;
      const safeProductId = encodeURIComponent(initialProductId).replaceAll('%2F', '');
      const targetPath = `${base.replace(/\/$/, '')}/product/${safeProductId}/`;
      if (window.location.pathname !== targetPath) {
        window.history.replaceState({}, '', targetPath);
      }
    }

    restoreProductUrlBeforeLoading();

    const { recordRecentView, resolveBase, fetchNearbyPrices, fetchPricesForProduct, fetchStoresPage, formatDistance, formatYen, geolocate } = await import(window.__APriceConfig?.browserJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'browser.js');
    const { fetchFavorites, fetchPersonalLogs, getCurrentUser, indexLatestPersonalPricesByStore, submitStorePrice, toggleFavorite } = await import(window.__APriceConfig?.browserAuthJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'browser-auth.js');
    const { buildPrivatePageLoginUrl, redirectToLogin, syncPrivatePageGate } = await import(window.__APriceConfig?.privatePageAuthJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'private-page-auth.js');
    const { restGet } = await import(window.__APriceConfig?.supabaseRestJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'supabase-rest.js');

    const title = document.querySelector('#runtime-product-title');
    const sub = document.querySelector('#runtime-product-sub');
    const meta = document.querySelector('#runtime-product-meta');
    const hero = document.querySelector('#runtime-product-hero');
    const authGate = document.querySelector('#product-auth-gate');
    const authGateLink = document.querySelector('#product-login-link');
    const favoriteButton = document.querySelector('#favorite-product-button');
    const favoriteStoreButton = document.querySelector('#favorite-store-button');
    const geoButton = document.querySelector('#geo-sort');
    const geoStatus = document.querySelector('#geo-status');
    const priceList = document.querySelector('#price-list');
    const priceFlowMinPrice = document.querySelector('#price-flow-min-price');
    const priceFlowStore = document.querySelector('#price-flow-store');
    const priceFlowGapPill = document.querySelector('#price-flow-gap-pill');
    const priceFlowGapNote = document.querySelector('#price-flow-gap-note');
    const storeStatus = document.querySelector('#personal-store-status');
    const storeList = document.querySelector('#personal-store-list');
    const storeSearch = document.querySelector('#personal-store-search');
    const storeSearchClear = document.querySelector('#personal-store-search-clear');
    const storeLoadMore = document.querySelector('#personal-store-load-more');
    const form = document.querySelector('#personal-log-form');
    const store = document.querySelector('#personal-store');
    const price = document.querySelector('#personal-price');
    const note = document.querySelector('#personal-note');
    const evidenceUrl = document.querySelector('#personal-evidence-url');
    const sharePublic = document.querySelector('#personal-share-public');
    const status = document.querySelector('#personal-status');

    let product = null;
    let productId = '';
    const STORE_PAGE_SIZE = 10;
    let storeRows = [];
    let storeSearchTerm = '';
    let storeOffset = 0;
    let storeHasMore = false;
    let storeLoading = false;
    let storeRequestToken = 0;
    let selectedStoreId = '';
    let selectedStoreSnapshot = null;
    let activeStoreId = '';
    let personalPriceIndex = new Map();
    let favoriteProductIds = new Set();
    let favoriteStoreIds = new Set();

    function escapeHtml(value = '') {
      return String(value || '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function readProductId() {
      return readInitialProductId();
    }

    function syncCanonicalProductUrl() {
      if (!productId || !window.history?.replaceState) return;
      const safeProductId = encodeURIComponent(productId).replaceAll('%2F', '');
      const target = resolveBase(`product/${safeProductId}/`);
      const targetUrl = new URL(target, window.location.origin);
      if (window.location.pathname !== targetUrl.pathname) {
        window.history.replaceState({}, '', `${targetUrl.pathname}${targetUrl.search}${targetUrl.hash}`);
      }
    }

    function syncFavoriteButton(button, active, { activeLabel, inactiveLabel, disabled = false }) {
      if (!(button instanceof HTMLButtonElement)) return;
      button.disabled = Boolean(disabled);
      button.textContent = active ? activeLabel : inactiveLabel;
      button.classList.toggle('is-active', Boolean(active));
    }

    function syncFavoriteButtons() {
      syncFavoriteButton(favoriteButton, productId && favoriteProductIds.has(productId), {
        activeLabel: '取消商品收藏',
        inactiveLabel: '添加商品收藏',
        disabled: !productId,
      });
      syncFavoriteButton(favoriteStoreButton, activeStoreId && favoriteStoreIds.has(activeStoreId), {
        activeLabel: '取消门店收藏',
        inactiveLabel: '添加门店收藏',
        disabled: !activeStoreId,
      });
    }

    function getSelectedStore() {
      return storeRows.find((item) => item.id === selectedStoreId) || selectedStoreSnapshot || null;
    }

    function syncStoreLoadMoreButton() {
      if (!(storeLoadMore instanceof HTMLButtonElement)) return;
      storeLoadMore.hidden = !storeHasMore && !storeLoading;
      storeLoadMore.disabled = storeLoading;
      storeLoadMore.textContent = storeLoading ? '加载中...' : '加载更多';
    }

    function renderMissingId() {
      if (title) title.textContent = '缺少商品编号';
      if (sub) sub.textContent = 'URL 里没有商品 id，返回首页或扫码重新打开。';
      if (meta) meta.innerHTML = `<a class="button button--ghost" href="${resolveBase('scan/')}">去扫码</a>`;
      if (priceList) priceList.innerHTML = '<div class="notice notice--compact">未提供商品 id，无法查询价格。</div>';
    }

    function renderNotFound() {
      if (title) title.textContent = '未找到该商品';
      if (sub) sub.textContent = `商品 id: ${productId}`;
      if (meta) meta.innerHTML = `<span class="pill">未命中</span><a class="button button--ghost" href="${resolveBase('scan/')}">去扫码</a>`;
      if (priceList) priceList.innerHTML = '<div class="notice notice--compact">当前数据库里没有这条商品记录。</div>';
    }

    function renderProduct() {
      if (!product) return;
      if (title) title.textContent = product.name || product.id || '商品详情';
      if (sub) sub.textContent = product.description || '查看该商品在不同门店的采样价格。';
      if (meta) {
        meta.innerHTML = `
          ${product.category ? `<span class="pill">${escapeHtml(product.category)}</span>` : ''}
          <span class="pill">JAN ${escapeHtml(product.barcode || product.id || '')}</span>
          <span class="pill">${escapeHtml(product.brand || '品牌未知')}</span>
          <span class="pill">${escapeHtml(product.pack || '规格未知')}</span>
        `;
      }
      if (hero) hero.className = `product-hero tone-${product.tone || 'sunset'}`;
      document.title = `${product.name || product.id} - 搜比价`;
      recordRecentView({
        id: product.id,
        name: product.name,
        brand: product.brand,
        pack: product.pack,
        barcode: product.barcode,
        tone: product.tone,
      });
    }

    function renderPrices(rows) {
      if (!priceList) return;
      if (!rows?.length) {
        if (priceFlowMinPrice) priceFlowMinPrice.textContent = '暂无';
        if (priceFlowStore) priceFlowStore.textContent = '当前还没有价格记录。';
        if (priceFlowGapPill) priceFlowGapPill.textContent = '暂无差距';
        if (priceFlowGapNote) priceFlowGapNote.textContent = '补充第一条价格后，这里会自动显示最低价摘要。';
        priceList.innerHTML = '<div class="notice notice--compact">暂无价格记录。</div>';
        return;
      }

      activeStoreId = rows[0]?.store_id || '';
      syncFavoriteButtons();
      const sortedRows = rows.slice().sort((a, b) => Number(a.price_yen || 0) - Number(b.price_yen || 0));
      const minPrice = Number(sortedRows[0]?.price_yen || 0);
      const nextLowest = sortedRows[1] ? Number(sortedRows[1].price_yen || 0) - minPrice : null;
      if (priceFlowMinPrice) priceFlowMinPrice.textContent = formatYen(minPrice);
      if (priceFlowStore) priceFlowStore.textContent = sortedRows[0]?.stores?.name || 'Unknown store';
      if (priceFlowGapPill) priceFlowGapPill.textContent = nextLowest === null ? '单条价格' : nextLowest === 0 ? '最低价持平' : `次低价差 ${formatYen(nextLowest)}`;
      if (priceFlowGapNote) priceFlowGapNote.textContent = `当前共有 ${rows.length} 条价格，最低价已置顶。`;

      priceList.innerHTML = sortedRows.map((row, index) => {
        const gap = Number(row.price_yen || 0) - minPrice;
        const distanceLabel = row.distance_km !== null && row.distance_km !== undefined ? ` · ${formatDistance(row.distance_km)}` : '';
        return `
          <div class="feed__item ${index === 0 ? 'feed__item--featured' : ''}">
            <div>
              <strong>${escapeHtml(row.stores?.name || 'Unknown store')}</strong>
              <small>${escapeHtml(row.stores?.city || '')}${distanceLabel}${row.is_member_price ? ' · 会员价' : ' · 公开价'}${row.stores?.hours ? ` · ${escapeHtml(row.stores.hours)}` : ''}</small>
            </div>
            <div class="feed__meta">
              <span class="price">${escapeHtml(formatYen(row.price_yen))}</span>
              <span class="pill">${gap === 0 ? '最低价' : `高 ${formatYen(gap)}`}</span>
            </div>
          </div>
        `;
      }).join('');
    }

    function renderStorePicker() {
      if (!storeList) return;
      if (storeLoading && !storeRows.length) {
        storeList.innerHTML = '<div class="notice notice--compact">正在加载门店...</div>';
        if (storeStatus) storeStatus.textContent = '正在加载门店...';
        syncStoreLoadMoreButton();
        return;
      }

      const selectedStore = selectedStoreId ? getSelectedStore() : null;
      if (!storeRows.length && !selectedStore) {
        storeList.innerHTML = `<div class="notice notice--compact">${storeSearchTerm ? '没有匹配到门店，换个关键词试试。' : '暂无门店。'}</div>`;
        if (storeStatus) storeStatus.textContent = storeSearchTerm ? '没有匹配到门店，换个关键词试试。' : '暂无门店可选。';
        syncStoreLoadMoreButton();
        return;
      }

      const visibleStores = selectedStore && !storeRows.some((item) => item.id === selectedStore.id)
        ? [selectedStore, ...storeRows]
        : storeRows;

      if (!selectedStoreId) selectedStoreId = activeStoreId || visibleStores[0]?.id || '';
      if (store) store.value = selectedStoreId;
      if (storeStatus) {
        const selectedMatchesSearch = selectedStore ? storeRows.some((item) => item.id === selectedStore.id) : false;
        storeStatus.textContent = storeSearchTerm
          ? selectedStore && !selectedMatchesSearch
            ? `没有匹配到搜索词，当前选择 ${selectedStore.name} 仍保留。`
            : `已加载 ${storeRows.length} 家匹配门店。${storeHasMore ? '继续加载可查看更多。' : ''}`
          : selectedStoreId ? '点击门店即可回填你的最新价。' : '请选择门店后记录价格。';
      }
      const uniqueStores = Array.from(new Map(visibleStores.map((item) => [item.id, item])).values());
      uniqueStores.sort((a, b) => {
        if (a.id === selectedStoreId && b.id !== selectedStoreId) return -1;
        if (b.id === selectedStoreId && a.id !== selectedStoreId) return 1;
        return String(a.name || '').localeCompare(String(b.name || ''), 'ja-JP');
      });
      storeList.innerHTML = uniqueStores.map((item) => {
        const personalPrice = personalPriceIndex.get(String(item.id || ''));
        const selected = item.id === selectedStoreId;
        const metaBits = [];
        if (item.chain_name) metaBits.push(item.chain_name);
        if (item.city || item.pref) metaBits.push([item.pref, item.city].filter(Boolean).join(' · '));
        if (personalPrice) metaBits.push(`我的价 ${formatYen(personalPrice.price_yen)}`);
        if (item.hours) metaBits.push(item.hours);
        return `
          <button
            class="feed__item store-picker__item${selected ? ' is-active' : ''}"
            type="button"
            data-store-id="${escapeHtml(item.id)}"
            aria-pressed="${selected ? 'true' : 'false'}"
          >
            <div class="feed__copy">
              <strong>${escapeHtml(item.name || 'Unknown store')}</strong>
              <small>${escapeHtml(metaBits.filter(Boolean).join(' · '))}</small>
            </div>
            <div class="feed__meta">
              <span class="pill">${selected ? '已选中' : personalPrice ? '可回填' : '选择'}</span>
              <small>${personalPrice ? formatYen(personalPrice.price_yen) : '暂无我的价'}</small>
            </div>
          </button>
        `;
      }).join('');
      syncStoreLoadMoreButton();
    }

    async function syncAuthGate() {
      const user = await getCurrentUser();
      const loginUrl = buildPrivatePageLoginUrl({
        origin: window.location.origin,
        baseUrl: window.__APriceConfig?.baseUrl || '/',
        currentUrl: `${window.location.pathname}${window.location.search}${window.location.hash}`,
      });
      syncPrivatePageGate({ gateEl: authGate, loginLinkEl: authGateLink, loginUrl, visible: !user });
      return user;
    }

    async function syncFavoriteStates(user) {
      if (!user) {
        favoriteProductIds = new Set();
        favoriteStoreIds = new Set();
        syncFavoriteButtons();
        return;
      }
      const rows = await fetchFavorites(user.id);
      favoriteProductIds = new Set(rows.filter((item) => item.entity_type === 'product').map((item) => String(item.entity_id)));
      favoriteStoreIds = new Set(rows.filter((item) => item.entity_type === 'store').map((item) => String(item.entity_id)));
      syncFavoriteButtons();
    }

    async function refreshPersonalPriceState(user) {
      if (!user) {
        personalPriceIndex = new Map();
        if (status) status.textContent = '登录后可以保存你的购买价。';
        renderStorePicker();
        return;
      }
      const logs = await fetchPersonalLogs(user.id);
      personalPriceIndex = indexLatestPersonalPricesByStore(logs, productId);
      if (status) status.textContent = `已同步 ${logs.filter((item) => String(item.product_id) === productId).length} 条个人价格记录。`;
      renderStorePicker();
    }

    async function loadProduct() {
      const rows = await restGet('products', {
        query: {
          select: '*',
          id: `eq.${productId}`,
          limit: 1,
        },
      });
      product = rows?.[0] || null;
      if (!product) {
        renderNotFound();
        return false;
      }
      renderProduct();
      return true;
    }

    async function loadPrices() {
      const rows = await fetchPricesForProduct(productId);
      renderPrices(rows);
      if (geoStatus) geoStatus.textContent = rows.length ? `已加载 ${rows.length} 条价格记录。` : `当前还没有 ${product?.name || productId} 的价格记录。`;
    }

    async function loadStores({ reset = false } = {}) {
      const requestToken = ++storeRequestToken;
      storeLoading = true;
      syncStoreLoadMoreButton();
      if (reset) {
        storeRows = [];
        storeOffset = 0;
        storeHasMore = false;
        renderStorePicker();
      }
      try {
        const page = await fetchStoresPage({
          term: storeSearchTerm,
          limit: STORE_PAGE_SIZE,
          offset: storeOffset,
        });
        if (requestToken !== storeRequestToken) return;
        const nextRows = reset ? page.rows : [...storeRows, ...page.rows];
        storeRows = Array.from(new Map(nextRows.map((item) => [item.id, item])).values());
        storeOffset = page.nextOffset;
        storeHasMore = page.hasMore;
        renderStorePicker();
      } catch (error) {
        if (requestToken !== storeRequestToken) return;
        if (storeStatus) storeStatus.textContent = `门店加载失败：${error.message}`;
      } finally {
        if (requestToken !== storeRequestToken) return;
        storeLoading = false;
        renderStorePicker();
      }
    }

    storeList?.addEventListener('click', (event) => {
      const target = event.target instanceof HTMLElement ? event.target.closest('[data-store-id]') : null;
      if (!(target instanceof HTMLElement)) return;
      selectedStoreId = target.dataset.storeId || '';
      activeStoreId = selectedStoreId;
      selectedStoreSnapshot = storeRows.find((item) => item.id === selectedStoreId) || selectedStoreSnapshot;
      if (store) store.value = selectedStoreId;
      const personalPrice = personalPriceIndex.get(selectedStoreId);
      if (price) price.value = personalPrice ? String(personalPrice.price_yen) : '';
      if (status) status.textContent = personalPrice ? `已回填你的最新价 ${formatYen(personalPrice.price_yen)}。` : '这家门店还没有你的个人价，输入后就能保存。';
      renderStorePicker();
      syncFavoriteButtons();
    });

    storeSearch?.addEventListener('input', () => {
      storeSearchTerm = storeSearch.value || '';
      if (storeSearchClear) storeSearchClear.hidden = !storeSearchTerm;
      void loadStores({ reset: true });
    });

    storeSearchClear?.addEventListener('click', () => {
      if (storeSearch) storeSearch.value = '';
      storeSearchTerm = '';
      storeSearchClear.hidden = true;
      void loadStores({ reset: true });
      storeSearch?.focus();
    });

    storeLoadMore?.addEventListener('click', () => {
      void loadStores();
    });

    favoriteButton?.addEventListener('click', async () => {
      const user = await getCurrentUser();
      if (!user) {
        redirectToLogin(authGateLink?.href || resolveBase('login/'), authGate);
        return;
      }
      const result = await toggleFavorite('product', productId);
      if (result?.action === 'added') favoriteProductIds.add(productId);
      if (result?.action === 'removed') favoriteProductIds.delete(productId);
      syncFavoriteButtons();
    });

    favoriteStoreButton?.addEventListener('click', async () => {
      const user = await getCurrentUser();
      if (!user) {
        redirectToLogin(authGateLink?.href || resolveBase('login/'), authGate);
        return;
      }
      if (!activeStoreId) return;
      const result = await toggleFavorite('store', activeStoreId);
      if (result?.action === 'added') favoriteStoreIds.add(activeStoreId);
      if (result?.action === 'removed') favoriteStoreIds.delete(activeStoreId);
      syncFavoriteButtons();
    });

    geoButton?.addEventListener('click', async () => {
      if (!geoStatus) return;
      geoStatus.textContent = '获取位置...';
      try {
        const location = await geolocate();
        const rows = await fetchNearbyPrices({ productId, lat: location.lat, lng: location.lng, radiusKm: 20 });
        renderPrices(rows);
        geoStatus.textContent = `已按当前位置排序，定位点：${location.lat.toFixed(4)}, ${location.lng.toFixed(4)}。`;
      } catch (error) {
        geoStatus.textContent = `定位失败：${error.message}`;
      }
    });

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const user = await getCurrentUser();
      if (!user) {
        if (status) status.textContent = '请先登录后再记录店头价格。';
        redirectToLogin(authGateLink?.href || resolveBase('login/'), authGate);
        return;
      }
      try {
        const submittedPrice = Number(price?.value);
        const shouldShare = sharePublic instanceof HTMLInputElement ? sharePublic.checked : false;
        await submitStorePrice({
          product_id: productId,
          store_id: store?.value || selectedStoreId || null,
          price_yen: submittedPrice,
          note: note?.value?.trim() || '',
          evidence_url: evidenceUrl?.value?.trim?.() || '',
          share_to_public: shouldShare,
          purchased_at: new Date().toISOString().slice(0, 10),
        });
        if (price) price.value = '';
        if (note) note.value = '';
        if (evidenceUrl) evidenceUrl.value = '';
        await refreshPersonalPriceState(user);
        if (status) status.textContent = shouldShare
          ? `已提交 ${formatYen(submittedPrice || 0)}，审核后会进入公共比价。`
          : `已保存 ${formatYen(submittedPrice || 0)}。`;
      } catch (error) {
        if (status) status.textContent = `保存失败：${error.message}`;
      }
    });

    productId = readProductId();
    if (!productId) {
      renderMissingId();
    } else if (await loadProduct()) {
      syncCanonicalProductUrl();
      const user = await syncAuthGate();
      await Promise.all([loadPrices(), loadStores({ reset: true }), syncFavoriteStates(user), refreshPersonalPriceState(user)]);
    }
  </script>
</BaseLayout>
