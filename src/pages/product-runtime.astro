---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPrivatePageStatusCopy } from '../lib/private-page-auth.js';

export const prerender = true;
const base = import.meta.env.BASE_URL || '/';
const logPrompt = getPrivatePageStatusCopy('product', 'logPrompt');
---
<BaseLayout title="商品详情 - 搜比价" description="商品详情、门店价格与个人记录。" bodyClass="product-page">
  <section class="section section--first-workspace" id="product-runtime-page" data-base={base}>
    <div class="shell">
      <div class="notice notice--compact">{logPrompt}</div>
    </div>
  </section>

  <script type="module" is:inline define:vars={{ base }}>
    function readProductId() {
      const url = new URL(window.location.href);
      const fromQuery = String(url.searchParams.get('id') || '').trim();
      if (fromQuery) return fromQuery;
      const match = url.pathname.match(/\/product\/([^/]+)\/?$/);
      return match?.[1] ? decodeURIComponent(match[1]) : '';
    }

    const productId = readProductId();
    const basePath = base.endsWith('/') ? base.slice(0, -1) : base;
    if (!productId) {
      window.location.replace(`${basePath}/404/`);
    } else {
      const safeProductId = encodeURIComponent(productId).replaceAll('%2F', '');
      window.location.replace(`${basePath}/product/${safeProductId}/`);
    }
  </script>
</BaseLayout>
