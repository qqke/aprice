---
import BaseLayout from '../layouts/BaseLayout.astro';
import { buildPrivatePageLoginUrl, getPrivatePageGateCopy, getPrivatePageStatusCopy } from '../lib/private-page-auth.js';

export const prerender = true;
const base = import.meta.env.BASE_URL || '/';
const loginUrl = buildPrivatePageLoginUrl({
  origin: Astro.url.origin,
  baseUrl: base,
  currentUrl: `${Astro.url.pathname}${Astro.url.search}${Astro.url.hash}`,
});
const switchAccountHref = loginUrl;
const adminGuestCopy = getPrivatePageGateCopy('admin', 'guest');
---
<BaseLayout title="管理 - 搜比价" description="维护商品、门店和价格记录的后台页面。" bodyClass="admin-page">
  <section class="section section--first-workspace">
    <div class="shell">
      <div class="section__header section__header--tight">
        <div>
          <div class="eyebrow">管理</div>
          <h1 class="product-title">运营后台，一页完成核心维护。</h1>
          <p class="product-sub">{getPrivatePageStatusCopy('admin', 'pageSub')}</p>
        </div>
        <div class="pillrow">
          <a class="button button--ghost" id="admin-switch-account" href={switchAccountHref}>{getPrivatePageStatusCopy('admin', 'actionLabel')}</a>
          <button class="button button--ghost" id="admin-logout" type="button" hidden>退出登录</button>
        </div>
      </div>

      <div class="notice notice--warning" id="admin-auth-gate">
        <div class="stack">
          <strong id="admin-gate-title">{adminGuestCopy.title}</strong>
          <small id="admin-gate-description">{adminGuestCopy.description}</small>
        </div>
        <div class="pillrow">
          <a class="button" id="admin-login-link" href={switchAccountHref}>{adminGuestCopy.primaryButtonLabel}</a>
          <a class="button button--ghost" id="admin-switch-link" href={switchAccountHref}>{adminGuestCopy.secondaryButtonLabel}</a>
        </div>
      </div>

      <div class="notice notice--warning" id="admin-status">检查登录状态与权限。</div>

      <section class="tile tile--flow admin-access-panel">
        <div class="section__header section__header--tight">
          <div>
            <h3>当前权限</h3>
            <p>确认账号级别后加载后台数据。</p>
          </div>
        </div>
        <div class="admin-access-panel__body">
          <div class="notice notice--compact">仅供维护账号使用。普通用户会被权限检查拦截。</div>
          <div class="list" id="admin-access">
            <div class="notice notice--compact">读取登录状态，再检查权限。</div>
          </div>
        </div>
      </section>

      <div class="pillrow" aria-label="管理区导航">
        <a class="button button--ghost" href="#admin-panel-price">价格</a>
        <a class="button button--ghost" href="#admin-panel-product">商品</a>
        <a class="button button--ghost" href="#admin-panel-store">门店</a>
        <a class="button button--ghost" href="#admin-panel-recent-prices">最近价格</a>
        <a class="button button--ghost" href="#admin-panel-commercial">商业化</a>
        <a class="button button--ghost" href="#admin-panel-telemetry">事件看板</a>
      </div>

      <div class="admin-panels">
        <details class="tile tile--wide tile--flow admin-panel" id="admin-panel-price">
          <summary class="admin-panel__summary">
            <span class="admin-panel__chevron" aria-hidden="true"></span>
            <span class="admin-panel__title">
              <strong>价格录入</strong>
              <small>维护公开价与会员价。</small>
            </span>
            <span class="pill" id="admin-price-summary-count">最近价格 0 条</span>
            <span class="meta" id="admin-price-summary-status">未选择</span>
          </summary>
          <div class="admin-panel__body">
            <div class="pillrow admin-toolbar">
              <button class="button button--ghost" id="price-reset" type="button">清空</button>
              <button class="button button--ghost" id="price-delete" type="button">删除</button>
            </div>
            <form class="form admin-form" id="price-form">
              <div class="admin-form__row admin-form__row--two">
                <label class="field"><select id="price-product" aria-label="价格对应商品"></select></label>
                <label class="field"><select id="price-store" aria-label="价格对应门店"></select></label>
              </div>
              <div class="admin-form__row admin-form__row--two">
                <label class="field"><input id="price-yen" type="number" inputmode="numeric" placeholder="价格（円）" aria-label="价格（日元）" /></label>
                <label class="field"><input id="price-source" placeholder="来源，例如 store shelf / community" aria-label="价格来源" /></label>
              </div>
              <div class="admin-form__row admin-form__row--two">
                <label class="field"><input id="price-note" placeholder="备注" aria-label="价格备注" /></label>
                <label class="field"><input id="price-collected" type="datetime-local" aria-label="采集时间" /></label>
              </div>
              <label class="field field--inline">
                <input id="price-member" type="checkbox" />
                <span>会员价</span>
              </label>
              <button class="button admin-form__submit" type="submit">保存价格</button>
            </form>
          </div>
        </details>

        <details class="tile tile--wide tile--flow admin-panel" id="admin-panel-product">
          <summary class="admin-panel__summary">
            <span class="admin-panel__chevron" aria-hidden="true"></span>
            <span class="admin-panel__title">
              <strong>商品档案</strong>
              <small>新增与清理商品基础信息。</small>
            </span>
            <span class="pill" id="admin-product-summary-count">商品 0 条</span>
            <span class="meta" id="admin-product-summary-status">未加载</span>
          </summary>
          <div class="admin-panel__body">
            <div class="pillrow admin-toolbar">
              <button class="button button--ghost" id="product-reset" type="button">清空</button>
              <button class="button button--ghost" id="product-delete" type="button">删除</button>
            </div>
            <form class="form admin-form" id="product-form">
              <div class="admin-form__row admin-form__row--two">
                <label class="field"><input id="product-id" placeholder="id，例如 loxonin-s" aria-label="商品 ID" /></label>
                <label class="field"><input id="product-barcode" placeholder="barcode / JAN" aria-label="商品条码" /></label>
              </div>
              <div class="admin-form__row admin-form__row--two">
                <label class="field"><input id="product-name" placeholder="名称" aria-label="商品名称" /></label>
                <label class="field"><input id="product-brand" placeholder="品牌" aria-label="商品品牌" /></label>
              </div>
              <div class="admin-form__row admin-form__row--two">
                <label class="field"><input id="product-pack" placeholder="规格" aria-label="商品规格" /></label>
                <label class="field"><input id="product-category" placeholder="分类" aria-label="商品分类" /></label>
              </div>
              <div class="admin-form__row admin-form__row--two">
                <label class="field">
                  <select id="product-tone" aria-label="商品色调">
                    <option value="sunset">sunset</option>
                    <option value="mint">mint</option>
                    <option value="azure">azure</option>
                  </select>
                </label>
                <label class="field"><input id="product-description" placeholder="简短描述" aria-label="商品简短描述" /></label>
              </div>
              <label class="field"><input id="product-image-url" type="url" inputmode="url" placeholder="图片 URL（http/https）" aria-label="商品图片 URL" /></label>
              <button class="button admin-form__submit" type="submit">添加商品</button>
            </form>
          </div>
        </details>

        <details class="tile tile--wide tile--flow admin-panel" id="admin-panel-store">
          <summary class="admin-panel__summary">
            <span class="admin-panel__chevron" aria-hidden="true"></span>
            <span class="admin-panel__title">
              <strong>门店资料</strong>
              <small>维护门店位置与营业信息。</small>
            </span>
            <span class="pill" id="admin-store-summary-count">门店 0 条</span>
            <span class="meta" id="admin-store-summary-status">未加载</span>
          </summary>
          <div class="admin-panel__body">
            <div class="pillrow admin-toolbar">
              <button class="button button--ghost" id="store-reset" type="button">清空</button>
              <button class="button button--ghost" id="store-delete" type="button">删除</button>
            </div>
            <form class="form admin-form" id="store-form">
              <div class="admin-form__row admin-form__row--two">
                <label class="field"><input id="store-id" placeholder="id，例如 shibuya-matsumoto" aria-label="门店 ID" /></label>
                <label class="field"><input id="store-name" placeholder="门店名" aria-label="门店名称" /></label>
              </div>
              <div class="admin-form__row admin-form__row--two">
                <label class="field"><input id="store-chain" placeholder="连锁名" aria-label="连锁名称" /></label>
                <label class="field"><input id="store-hours" placeholder="营业时间" aria-label="营业时间" /></label>
              </div>
              <div class="admin-form__row admin-form__row--two">
                <label class="field"><input id="store-address" placeholder="地址" aria-label="门店地址" /></label>
                <label class="field"><input id="store-city" placeholder="城市" aria-label="城市" /></label>
              </div>
              <div class="admin-form__row admin-form__row--two">
                <label class="field"><input id="store-pref" placeholder="都道府县" aria-label="都道府县" /></label>
                <div class="admin-form__row admin-form__row--two admin-form__row--nested">
                  <label class="field"><input id="store-lat" type="number" step="0.000001" placeholder="纬度" aria-label="纬度" /></label>
                  <label class="field"><input id="store-lng" type="number" step="0.000001" placeholder="经度" aria-label="经度" /></label>
                </div>
              </div>
              <button class="button admin-form__submit" type="submit">保存门店</button>
            </form>
          </div>
        </details>

        <details class="tile tile--flow admin-panel" id="admin-panel-recent-products">
          <summary class="admin-panel__summary">
            <span class="admin-panel__chevron" aria-hidden="true"></span>
            <span class="admin-panel__title">
              <strong>最近商品</strong>
              <small>点击即可回填。</small>
            </span>
            <span class="pill" id="admin-recent-products-summary-count">商品 0 条</span>
            <span class="meta" id="admin-recent-products-summary-status">未加载</span>
          </summary>
          <div class="admin-panel__body">
            <div class="list" id="admin-products"></div>
          </div>
        </details>

        <details class="tile tile--flow admin-panel" id="admin-panel-recent-stores">
          <summary class="admin-panel__summary">
            <span class="admin-panel__chevron" aria-hidden="true"></span>
            <span class="admin-panel__title">
              <strong>最近门店</strong>
              <small>点击即可回填。</small>
            </span>
            <span class="pill" id="admin-recent-stores-summary-count">门店 0 条</span>
            <span class="meta" id="admin-recent-stores-summary-status">未加载</span>
          </summary>
          <div class="admin-panel__body">
            <div class="list" id="admin-stores"></div>
          </div>
        </details>

        <details class="tile tile--wide tile--flow admin-panel" id="admin-panel-recent-prices">
          <summary class="admin-panel__summary">
            <span class="admin-panel__chevron" aria-hidden="true"></span>
            <span class="admin-panel__title">
              <strong>最近价格</strong>
              <small>用于快速复核录入结果。</small>
            </span>
            <span class="pill" id="admin-recent-prices-summary-count">价格 0 条</span>
            <span class="meta" id="admin-recent-prices-summary-status">未加载</span>
          </summary>
          <div class="admin-panel__body">
            <div class="list" id="admin-prices"></div>
          </div>
        </details>

        <details class="tile tile--wide tile--flow admin-panel" id="admin-panel-telemetry">
          <summary class="admin-panel__summary">
            <span class="admin-panel__chevron" aria-hidden="true"></span>
            <span class="admin-panel__title">
              <strong>事件看板</strong>
              <small>近 7 天关键行为概览。</small>
            </span>
            <span class="pill" id="admin-telemetry-summary-count">事件 0 条</span>
            <span class="meta" id="admin-telemetry-summary-status">未加载</span>
          </summary>
          <div class="admin-panel__body">
            <div class="list" id="admin-runtime-config"></div>
            <div class="list" id="admin-telemetry-summary"></div>
            <div class="list" id="admin-telemetry-recent"></div>
          </div>
        </details>

        <details class="tile tile--wide tile--flow admin-panel" id="admin-panel-commercial" open>
          <summary class="admin-panel__summary">
            <span class="admin-panel__chevron" aria-hidden="true"></span>
            <span class="admin-panel__title">
              <strong>商业化设置</strong>
              <small>积分充值、扣分规则与共识规则。</small>
            </span>
            <span class="pill" id="admin-commercial-summary-count">积分规则</span>
            <span class="meta" id="admin-commercial-summary-status">未加载</span>
          </summary>
          <div class="admin-panel__body">
            <form class="form admin-form" id="credit-adjust-form">
              <div class="admin-form__row admin-form__row--two">
                <label class="field"><input id="credit-user-id" placeholder="用户 UUID" aria-label="用户 UUID" /></label>
                <label class="field"><input id="credit-amount" type="number" inputmode="numeric" placeholder="积分变化，例如 100 或 -10" aria-label="积分变化" /></label>
              </div>
              <label class="field"><input id="credit-note" placeholder="备注，例如 手动充值" aria-label="积分备注" /></label>
              <button class="button admin-form__submit" type="submit">调整积分</button>
            </form>
            <form class="form admin-form" id="app-setting-form">
              <div class="admin-form__row admin-form__row--two">
                <label class="field">
                  <select id="setting-key" aria-label="设置项">
                    <option value="daily_free_searches">daily_free_searches</option>
                    <option value="daily_free_price_references">daily_free_price_references</option>
                    <option value="search_cost_after_free">search_cost_after_free</option>
                    <option value="price_reference_cost">price_reference_cost</option>
                    <option value="approved_contribution_reward">approved_contribution_reward</option>
                    <option value="consensus_required_users">consensus_required_users</option>
                    <option value="consensus_window_days">consensus_window_days</option>
                    <option value="task_claim_limit_per_day">task_claim_limit_per_day</option>
                    <option value="task_expiry_hours">task_expiry_hours</option>
                    <option value="stale_price_days">stale_price_days</option>
                    <option value="low_balance_threshold">low_balance_threshold</option>
                  </select>
                </label>
                <label class="field"><input id="setting-value" type="number" inputmode="numeric" placeholder="数值" aria-label="设置值" /></label>
              </div>
              <button class="button admin-form__submit" type="submit">保存设置</button>
            </form>
            <div class="list" id="admin-commercial-settings"></div>
          </div>
        </details>
      </div>
    </div>
  </section>

  <script type="module" is:inline define:vars={{ loginUrl }}>
    const { fetchAllProducts, fetchAllStores, fetchRecentPrices } = await import(window.__APriceConfig?.browserJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'browser.js');
    const { adminAdjustCredits, adminDeletePrice, adminDeleteProduct, adminDeleteStore, adminFetchTelemetryRecent, adminFetchTelemetrySummary, adminUpdateAppSetting, adminUpsertPrice, adminUpsertStore, createProduct, fetchAppSettings, fetchCurrentProfile, formatDataError, getCurrentUser, getSession, signOut } = await import(window.__APriceConfig?.browserAuthJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'browser-auth.js');
    const { applyPrivatePageGateCopy, getPrivatePageGateCopy, getPrivatePageStatusCopy, redirectToLogin, syncPrivatePageGate } = await import(window.__APriceConfig?.privatePageAuthJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'private-page-auth.js');
    const { validateCoordinate, validateJanCode, validateOptionalHttpUrl, validatePositiveYen } = await import(window.__APriceConfig?.formValidationJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'form-validation.js');

    const status = document.querySelector('#admin-status');
    const authGate = document.querySelector('#admin-auth-gate');
    const gateTitle = document.querySelector('#admin-gate-title');
    const gateDescription = document.querySelector('#admin-gate-description');
    const loginLink = document.querySelector('#admin-login-link');
    const switchLink = document.querySelector('#admin-switch-link');
    const accessState = document.querySelector('#admin-access');
    const logoutButton = document.querySelector('#admin-logout');
    const switchAccountLink = document.querySelector('#admin-switch-account');
    const productForm = document.querySelector('#product-form');
    const storeForm = document.querySelector('#store-form');
    const priceForm = document.querySelector('#price-form');
    const storePanel = document.querySelector('#admin-panel-store');
    const pricePanel = document.querySelector('#admin-panel-price');
    const productSelect = document.querySelector('#price-product');
    const storeSelect = document.querySelector('#price-store');
    const productList = document.querySelector('#admin-products');
    const storeList = document.querySelector('#admin-stores');
    const priceList = document.querySelector('#admin-prices');
    const runtimeConfigList = document.querySelector('#admin-runtime-config');
    const telemetrySummaryList = document.querySelector('#admin-telemetry-summary');
    const telemetryRecentList = document.querySelector('#admin-telemetry-recent');
    const commercialSettingsList = document.querySelector('#admin-commercial-settings');
    const creditAdjustForm = document.querySelector('#credit-adjust-form');
    const appSettingForm = document.querySelector('#app-setting-form');
    const productReset = document.querySelector('#product-reset');
    const storeReset = document.querySelector('#store-reset');
    const priceReset = document.querySelector('#price-reset');
    const productDelete = document.querySelector('#product-delete');
    const storeDelete = document.querySelector('#store-delete');
    const priceDelete = document.querySelector('#price-delete');
    const summaryEls = {
      productCount: document.querySelector('#admin-product-summary-count'),
      productStatus: document.querySelector('#admin-product-summary-status'),
      storeCount: document.querySelector('#admin-store-summary-count'),
      storeStatus: document.querySelector('#admin-store-summary-status'),
      priceCount: document.querySelector('#admin-price-summary-count'),
      priceStatus: document.querySelector('#admin-price-summary-status'),
      recentProductsCount: document.querySelector('#admin-recent-products-summary-count'),
      recentProductsStatus: document.querySelector('#admin-recent-products-summary-status'),
      recentStoresCount: document.querySelector('#admin-recent-stores-summary-count'),
      recentStoresStatus: document.querySelector('#admin-recent-stores-summary-status'),
      recentPricesCount: document.querySelector('#admin-recent-prices-summary-count'),
      recentPricesStatus: document.querySelector('#admin-recent-prices-summary-status'),
      telemetryCount: document.querySelector('#admin-telemetry-summary-count'),
      telemetryStatus: document.querySelector('#admin-telemetry-summary-status'),
      commercialCount: document.querySelector('#admin-commercial-summary-count'),
      commercialStatus: document.querySelector('#admin-commercial-summary-status'),
    };

    const productFields = {
      id: document.querySelector('#product-id'),
      barcode: document.querySelector('#product-barcode'),
      name: document.querySelector('#product-name'),
      brand: document.querySelector('#product-brand'),
      pack: document.querySelector('#product-pack'),
      category: document.querySelector('#product-category'),
      tone: document.querySelector('#product-tone'),
      description: document.querySelector('#product-description'),
      image_url: document.querySelector('#product-image-url'),
    };

    const storeFields = {
      id: document.querySelector('#store-id'),
      name: document.querySelector('#store-name'),
      chain_name: document.querySelector('#store-chain'),
      address: document.querySelector('#store-address'),
      city: document.querySelector('#store-city'),
      pref: document.querySelector('#store-pref'),
      lat: document.querySelector('#store-lat'),
      lng: document.querySelector('#store-lng'),
      hours: document.querySelector('#store-hours'),
    };

    const priceFields = {
      product_id: productSelect,
      store_id: storeSelect,
      price_yen: document.querySelector('#price-yen'),
      source: document.querySelector('#price-source'),
      note: document.querySelector('#price-note'),
      collected_at: document.querySelector('#price-collected'),
      is_member_price: document.querySelector('#price-member'),
    };

    const creditFields = {
      user_id: document.querySelector('#credit-user-id'),
      amount: document.querySelector('#credit-amount'),
      note: document.querySelector('#credit-note'),
    };

    const settingFields = {
      setting_key: document.querySelector('#setting-key'),
      setting_value: document.querySelector('#setting-value'),
    };

    let products = [];
    let stores = [];
    let prices = [];
    let telemetrySummary = { days: 7, total_events: 0, active_users: 0, top_events: [] };
    let telemetryItems = [];
    let appSettings = {};
    let selectedPriceId = '';

    function elValue(field) {
      if (!field) return '';
      if (field instanceof HTMLInputElement && field.type === 'checkbox') return field.checked ? 'true' : 'false';
      return field.value?.trim?.() ?? '';
    }

    function setValue(field, value = '') {
      if (!field) return;
      if (field instanceof HTMLInputElement && field.type === 'checkbox') {
        field.checked = value === true || value === 'true';
        return;
      }
      field.value = value ?? '';
    }

    function optionHtml(items) {
      return items.map((item) => `<option value="${escapeHtml(item.id)}">${escapeHtml(item.name)}</option>`).join('');
    }

    function escapeHtml(value = '') {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function formatAdminDate(value) {
      if (!value) return '未知时间';
      return new Date(value).toLocaleString('ja-JP', {
        year: 'numeric',
        month: '2-digit',
        day: '2-digit',
        hour: '2-digit',
        minute: '2-digit',
      });
    }

    function setSummaryText(key, value) {
      const el = summaryEls[key];
      if (el) el.textContent = value;
    }

    function updateAdminSummaries() {
      setSummaryText('productCount', `商品 ${products.length} 条`);
      setSummaryText('productStatus', products.length ? '已加载' : '暂无数据');
      setSummaryText('storeCount', `门店 ${stores.length} 条`);
      setSummaryText('storeStatus', stores.length ? '已加载' : '暂无数据');
      setSummaryText('priceCount', `最近价格 ${prices.length} 条`);
      setSummaryText('priceStatus', selectedPriceId ? '正在编辑' : (prices.length ? '已加载' : '暂无数据'));
      setSummaryText('recentProductsCount', `商品 ${products.length} 条`);
      setSummaryText('recentProductsStatus', products.length ? '可回填' : '暂无数据');
      setSummaryText('recentStoresCount', `门店 ${stores.length} 条`);
      setSummaryText('recentStoresStatus', stores.length ? '可回填' : '暂无数据');
      setSummaryText('recentPricesCount', `价格 ${prices.length} 条`);
      setSummaryText('recentPricesStatus', prices.length ? '可检查' : '暂无数据');
      setSummaryText('telemetryCount', `事件 ${telemetrySummary?.total_events || 0} 条`);
      setSummaryText('telemetryStatus', telemetryItems.length ? '已加载' : '暂无数据');
      setSummaryText('commercialCount', `设置 ${Object.keys(appSettings || {}).length} 项`);
      setSummaryText('commercialStatus', Object.keys(appSettings || {}).length ? '已加载' : '未加载');
    }

    function refreshSelectors() {
      if (productSelect) productSelect.innerHTML = optionHtml(products);
      if (storeSelect) storeSelect.innerHTML = optionHtml(stores);
    }

    function fillFields(fields, values, transforms = {}) {
      Object.entries(fields).forEach(([key, field]) => {
        const value = transforms[key] ? transforms[key](values?.[key]) : values?.[key];
        setValue(field, value ?? '');
      });
    }

    function resetFields(fields, defaults = {}) {
      Object.entries(fields).forEach(([key, field]) => {
        const value = Object.prototype.hasOwnProperty.call(defaults, key) ? defaults[key] : '';
        setValue(field, value);
      });
    }

    function populateStoreForm(store) {
      if (!store) return;
      fillFields(storeFields, store, {
        lat: (value) => String(value ?? ''),
        lng: (value) => String(value ?? ''),
      });
    }

    function populatePriceForm(price) {
      if (!price) return;
      selectedPriceId = price.id;
      fillFields(priceFields, price, {
        price_yen: (value) => String(value ?? ''),
        collected_at: (value) => (value ? value.slice(0, 16) : ''),
      });
      updateAdminSummaries();
    }

    function resetProductForm() {
      resetFields(productFields, { tone: 'sunset' });
    }

    function resetStoreForm() {
      resetFields(storeFields);
    }

    function resetPriceForm() {
      selectedPriceId = '';
      resetFields(priceFields);
      updateAdminSummaries();
    }

    function renderRuntimeConfig() {
      if (!runtimeConfigList) return;
      const config = window.__APriceConfig || {};
      runtimeConfigList.innerHTML = `
        <div class="list__item">
          <div>
            <strong>运行配置</strong>
            <small>价格 RPC ${config.useServerPriceRpc ? '已启用' : '未启用'} · 遥测 RPC ${config.enableTelemetryRpc ? '已启用' : '未启用'} · 近 ${escapeHtml(telemetrySummary?.days || 7)} 天事件 ${escapeHtml(telemetrySummary?.total_events || 0)} 条</small>
          </div>
          <span class="meta">${config.useServerPriceRpc ? 'rpc:on' : 'rpc:off'}</span>
        </div>
      `;
    }

    function renderCommercialSettings() {
      if (!commercialSettingsList) return;
      const entries = Object.entries(appSettings || {});
      commercialSettingsList.innerHTML = entries.length
        ? entries.map(([key, value]) => `
          <div class="list__item">
            <div>
              <strong>${escapeHtml(key)}</strong>
              <small>当前值来自 DB 配置，RPC 运行时读取。</small>
            </div>
            <span class="price">${escapeHtml(String(value))}</span>
          </div>
        `).join('')
        : '<div class="notice notice--compact">暂无商业化配置。</div>';
    }

    function renderProducts() {
      if (!productList) return;
      productList.innerHTML = products.length
        ? products.map((item) => `
          <div class="list__item admin-record-item">
            <div>
              <strong>${escapeHtml(item.name)}</strong>
              <small>${escapeHtml(item.barcode)} · ${escapeHtml(item.brand)} · ${escapeHtml(item.pack)}${item.image_url ? ' · 已配置图片' : ''}</small>
            </div>
            <div class="pillrow admin-record-actions">
              <button class="button button--ghost" data-delete-product="${escapeHtml(item.id)}" type="button">删除</button>
            </div>
          </div>
        `).join('')
        : '<div class="list__item"><div><strong>暂无商品</strong><small>请添加一条商品。</small></div><span class="meta">暂无</span></div>';
    }

    function renderStores() {
      if (!storeList) return;
      storeList.innerHTML = stores.length
        ? stores.map((item) => `
          <div class="list__item admin-record-item">
            <div>
              <strong>${escapeHtml(item.name)}</strong>
              <small>${escapeHtml(item.city)} · ${escapeHtml(item.pref)} · ${escapeHtml(item.hours)}</small>
            </div>
            <div class="pillrow admin-record-actions">
              <button class="button button--ghost" data-edit-store="${escapeHtml(item.id)}" type="button">编辑</button>
              <button class="button button--ghost" data-delete-store="${escapeHtml(item.id)}" type="button">删除</button>
            </div>
          </div>
        `).join('')
        : '<div class="list__item"><div><strong>暂无门店</strong><small>请保存一条门店。</small></div><span class="meta">暂无</span></div>';
    }

    function renderPrices() {
      if (!priceList) return;
      priceList.innerHTML = prices.length
        ? prices.map((item) => `
          <div class="list__item admin-record-item admin-record-item--price">
            <div>
              <strong>${escapeHtml(item.products?.name || 'Unknown product')}</strong>
              <small>${escapeHtml(item.stores?.name || 'Unknown store')} · ${escapeHtml(item.stores?.city || '')} · ${item.is_member_price ? '会员价' : '公开价'}</small>
            </div>
            <div class="pillrow admin-record-actions admin-record-actions--price">
              <span class="price admin-record-price">¥${item.price_yen}</span>
              <button class="button button--ghost" data-edit-price="${escapeHtml(item.id)}" type="button">编辑</button>
              <button class="button button--ghost" data-delete-price="${escapeHtml(item.id)}" type="button">删除</button>
            </div>
          </div>
        `).join('')
        : '<div class="list__item"><div><strong>暂无价格</strong><small>请保存一条价格。</small></div><span class="meta">暂无</span></div>';
    }

    function renderTelemetry() {
      if (telemetrySummaryList) {
        const topEvents = Array.isArray(telemetrySummary?.top_events) ? telemetrySummary.top_events : [];
        telemetrySummaryList.innerHTML = `
          <div class="list__item">
            <div>
              <strong>近 ${escapeHtml(telemetrySummary?.days || 7)} 天总事件 ${escapeHtml(telemetrySummary?.total_events || 0)} 条</strong>
              <small>活跃用户 ${escapeHtml(telemetrySummary?.active_users || 0)} 人 · Top 事件：${escapeHtml(topEvents.slice(0, 3).map((item) => `${item.event_name}(${item.total})`).join(' / ') || '暂无')}</small>
            </div>
            <span class="meta">telemetry</span>
          </div>
        `;
      }

      if (telemetryRecentList) {
        telemetryRecentList.innerHTML = telemetryItems.length
          ? telemetryItems.slice(0, 12).map((item) => `
            <div class="list__item">
              <div>
                <strong>${escapeHtml(item.event_name || 'unknown')}</strong>
                <small>${escapeHtml(item.email || item.user_id || 'anonymous')} · ${formatAdminDate(item.occurred_at)} · ${escapeHtml(JSON.stringify(item.payload || {}))}</small>
              </div>
              <span class="meta">event</span>
            </div>
          `).join('')
          : '<div class="list__item"><div><strong>暂无事件</strong><small>启用 telemetry 后会在这里展示最新行为。</small></div><span class="meta">0</span></div>';
      }
      renderRuntimeConfig();
    }

    syncPrivatePageGate({ gateEl: authGate, loginLinkEl: loginLink, loginUrl, visible: false });
    switchAccountLink?.setAttribute('href', loginUrl);

    async function loadData() {
      const [user, profile] = await Promise.all([getCurrentUser(), fetchCurrentProfile()]);
      if (!user) {
        if (logoutButton) logoutButton.hidden = true;
        const copy = getPrivatePageGateCopy('admin', 'guest');
        syncPrivatePageGate({ gateEl: authGate, loginLinkEl: loginLink, loginUrl, visible: true });
        applyPrivatePageGateCopy({ titleEl: gateTitle, descriptionEl: gateDescription, primaryButtonEl: loginLink, secondaryButtonEl: switchLink }, copy);
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'notLoggedIn');
        if (accessState) {
          accessState.innerHTML = `
            <div class="list__item">
              <div>
                <strong>${getPrivatePageStatusCopy('admin', 'accessLoggedOutTitle')}</strong>
                <small>${getPrivatePageStatusCopy('admin', 'accessLoggedOutDescription')}</small>
              </div>
              <span class="meta">guest</span>
            </div>
          `;
        }
        return false;
      }
      if (profile?.role !== 'admin') {
        if (logoutButton) logoutButton.hidden = true;
        const copy = getPrivatePageGateCopy('admin', 'forbidden');
        syncPrivatePageGate({ gateEl: authGate, loginLinkEl: loginLink, loginUrl, visible: true });
        applyPrivatePageGateCopy({ titleEl: gateTitle, descriptionEl: gateDescription, primaryButtonEl: loginLink, secondaryButtonEl: switchLink }, copy);
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'notAdmin');
        if (accessState) {
          accessState.innerHTML = `
            <div class="list__item">
              <div>
                <strong>${profile?.email || user.email || '已登录用户'}</strong>
                <small>${getPrivatePageStatusCopy('admin', 'accessNotAdminDescription')}</small>
              </div>
              <span class="meta">${profile?.role || 'unknown'}</span>
            </div>
          `;
        }
        return false;
      }

      const session = await getSession();
      const [productItems, storeItems, priceItems] = await Promise.all([
        fetchAllProducts(),
        fetchAllStores(),
        fetchRecentPrices(12, { token: session?.access_token || '' }),
      ]);
      try {
        appSettings = await fetchAppSettings();
      } catch {
        appSettings = {};
      }
      let telemetrySummaryResult = { days: 7, total_events: 0, active_users: 0, top_events: [] };
      let telemetryRecentResult = { items: [] };
      try {
        [telemetrySummaryResult, telemetryRecentResult] = await Promise.all([
          adminFetchTelemetrySummary({ days: 7 }),
          adminFetchTelemetryRecent({ limit: 30 }),
        ]);
      } catch {
        telemetrySummaryResult = { days: 7, total_events: 0, active_users: 0, top_events: [] };
        telemetryRecentResult = { items: [] };
      }
      syncPrivatePageGate({ gateEl: authGate, loginLinkEl: loginLink, loginUrl, visible: false });
      if (logoutButton) logoutButton.hidden = false;
      products = productItems;
      stores = storeItems;
      prices = priceItems;
      telemetrySummary = telemetrySummaryResult || { days: 7, total_events: 0, active_users: 0, top_events: [] };
      telemetryItems = Array.isArray(telemetryRecentResult?.items) ? telemetryRecentResult.items : [];

      refreshSelectors();
      renderProducts();
      renderStores();
      renderPrices();
      renderTelemetry();
      renderCommercialSettings();
      updateAdminSummaries();
      if (status) status.textContent = getPrivatePageStatusCopy('admin', 'loaded', { email: profile.email || user.email });
      if (accessState) {
        accessState.innerHTML = `
          <div class="list__item">
            <div>
              <strong>${profile.email || user.email || 'admin'}</strong>
              <small>${getPrivatePageStatusCopy('admin', 'accessAdminDescription')}</small>
            </div>
            <span class="meta">admin</span>
          </div>
        `;
      }
      return true;
    }

    productForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      try {
        const barcode = validateJanCode(elValue(productFields.barcode));
        const imageUrl = validateOptionalHttpUrl(elValue(productFields.image_url));
        if (!barcode.ok) {
          if (status) status.textContent = barcode.message;
          return;
        }
        if (!imageUrl.ok) {
          if (status) status.textContent = imageUrl.message;
          return;
        }
        await createProduct({
          id: elValue(productFields.id),
          barcode: barcode.value,
          name: elValue(productFields.name),
          brand: elValue(productFields.brand),
          pack: elValue(productFields.pack),
          category: elValue(productFields.category),
          tone: elValue(productFields.tone),
          description: elValue(productFields.description),
          image_url: imageUrl.value,
        });
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'saveProductSuccess');
        await loadData();
      } catch (error) {
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'saveProductFailure', { message: formatDataError(error) });
      }
    });

    storeForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      try {
        const lat = validateCoordinate(elValue(storeFields.lat), { label: '纬度', min: -90, max: 90 });
        const lng = validateCoordinate(elValue(storeFields.lng), { label: '经度', min: -180, max: 180 });
        if (!lat.ok || !lng.ok) {
          if (status) status.textContent = !lat.ok ? lat.message : lng.message;
          return;
        }
        await adminUpsertStore({
          id: elValue(storeFields.id),
          name: elValue(storeFields.name),
          chain_name: elValue(storeFields.chain_name),
          address: elValue(storeFields.address),
          city: elValue(storeFields.city),
          pref: elValue(storeFields.pref),
          lat: String(lat.value),
          lng: String(lng.value),
          hours: elValue(storeFields.hours),
        });
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'saveStoreSuccess');
        await loadData();
      } catch (error) {
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'saveStoreFailure', { message: formatDataError(error) });
      }
    });

    priceForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      try {
        const price = validatePositiveYen(elValue(priceFields.price_yen));
        if (!price.ok) {
          if (status) status.textContent = price.message;
          return;
        }
        await adminUpsertPrice({
          id: selectedPriceId,
          product_id: elValue(priceFields.product_id),
          store_id: elValue(priceFields.store_id),
          price_yen: String(price.value),
          source: elValue(priceFields.source),
          note: elValue(priceFields.note),
          collected_at: elValue(priceFields.collected_at),
          is_member_price: elValue(priceFields.is_member_price),
        });
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'savePriceSuccess');
        await loadData();
      } catch (error) {
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'savePriceFailure', { message: formatDataError(error) });
      }
    });

    creditAdjustForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      try {
        const amount = Number(elValue(creditFields.amount));
        if (!elValue(creditFields.user_id) || !Number.isInteger(amount) || amount === 0) {
          if (status) status.textContent = '请填写用户 UUID 和非 0 整数积分。';
          return;
        }
        const result = await adminAdjustCredits({
          user_id: elValue(creditFields.user_id),
          amount: String(amount),
          note: elValue(creditFields.note),
        });
        if (status) status.textContent = `积分已调整，当前余额 ${result.balance ?? '未知'}。`;
        setValue(creditFields.amount, '');
        setValue(creditFields.note, '');
      } catch (error) {
        if (status) status.textContent = `积分调整失败：${formatDataError(error)}`;
      }
    });

    appSettingForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      try {
        const value = Number(elValue(settingFields.setting_value));
        if (!Number.isInteger(value)) {
          if (status) status.textContent = '设置值需要是整数。';
          return;
        }
        await adminUpdateAppSetting({
          setting_key: elValue(settingFields.setting_key),
          setting_value: value,
        });
        if (status) status.textContent = '商业化设置已保存。';
        await loadData();
      } catch (error) {
        if (status) status.textContent = `设置保存失败：${formatDataError(error)}`;
      }
    });

    productReset?.addEventListener('click', resetProductForm);
    storeReset?.addEventListener('click', resetStoreForm);
    priceReset?.addEventListener('click', resetPriceForm);

    productDelete?.addEventListener('click', async () => {
      const targetId = elValue(productFields.id);
      if (!targetId) return;
      if (!window.confirm(`删除商品 ${targetId} ?`)) return;
      try {
        await adminDeleteProduct(targetId);
        resetProductForm();
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'deleteProductSuccess');
        await loadData();
      } catch (error) {
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'deleteProductFailure', { message: error.message });
      }
    });

    storeDelete?.addEventListener('click', async () => {
      const targetId = elValue(storeFields.id);
      if (!targetId) return;
      if (!window.confirm(`删除门店 ${targetId} ?`)) return;
      try {
        await adminDeleteStore(targetId);
        resetStoreForm();
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'deleteStoreSuccess');
        await loadData();
      } catch (error) {
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'deleteStoreFailure', { message: error.message });
      }
    });

    priceDelete?.addEventListener('click', async () => {
      const targetId = selectedPriceId;
      if (!targetId) return;
      if (!window.confirm(`删除价格记录 ${targetId} ?`)) return;
      try {
        await adminDeletePrice(targetId);
        resetPriceForm();
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'deletePriceSuccess');
        await loadData();
      } catch (error) {
        if (status) status.textContent = getPrivatePageStatusCopy('admin', 'deletePriceFailure', { message: error.message });
      }
    });

    productList?.addEventListener('click', async (event) => {
      const target = event.target;
      const button = target instanceof Element ? target.closest('button') : null;
      if (!button) return;
      const deleteId = button.dataset.deleteProduct;
      if (deleteId && window.confirm(`删除商品 ${deleteId} ?`)) {
        try {
          await adminDeleteProduct(deleteId);
          resetProductForm();
          if (status) status.textContent = getPrivatePageStatusCopy('admin', 'deleteProductSuccess');
          await loadData();
        } catch (error) {
          if (status) status.textContent = getPrivatePageStatusCopy('admin', 'deleteProductFailure', { message: error.message });
        }
      }
    });

    storeList?.addEventListener('click', async (event) => {
      const target = event.target;
      const button = target instanceof Element ? target.closest('button') : null;
      if (!button) return;
      const editId = button.dataset.editStore;
      const deleteId = button.dataset.deleteStore;
      if (editId) {
        if (storePanel) storePanel.open = true;
        populateStoreForm(stores.find((item) => item.id === editId));
      }
      if (deleteId && window.confirm(`删除门店 ${deleteId} ?`)) {
        try {
          await adminDeleteStore(deleteId);
          resetStoreForm();
          if (status) status.textContent = getPrivatePageStatusCopy('admin', 'deleteStoreSuccess');
          await loadData();
        } catch (error) {
          if (status) status.textContent = getPrivatePageStatusCopy('admin', 'deleteStoreFailure', { message: error.message });
        }
      }
    });

    priceList?.addEventListener('click', async (event) => {
      const target = event.target;
      const button = target instanceof Element ? target.closest('button') : null;
      if (!button) return;
      const editId = button.dataset.editPrice;
      const deleteId = button.dataset.deletePrice;
      if (editId) {
        const item = prices.find((entry) => entry.id === editId);
        if (item) {
          if (pricePanel) pricePanel.open = true;
          populatePriceForm(item);
        }
      }
      if (deleteId && window.confirm(`删除价格记录 ${deleteId} ?`)) {
        try {
          await adminDeletePrice(deleteId);
          resetPriceForm();
          if (status) status.textContent = getPrivatePageStatusCopy('admin', 'deletePriceSuccess');
          await loadData();
        } catch (error) {
          if (status) status.textContent = getPrivatePageStatusCopy('admin', 'deletePriceFailure', { message: error.message });
        }
      }
    });

    logoutButton?.addEventListener('click', async () => {
      await signOut();
      redirectToLogin(loginUrl, authGate);
    });

    loadData();
  </script>
</BaseLayout>
