---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="扫码查价 - 搜比价" description="使用相机扫描 JAN 条码，或者手动输入编号进行商品搜索。" bodyClass="scan-page">
  <section class="section">
    <div class="shell">
      <div class="hero-banner">
        <div class="hero-banner__inner">
          <div class="hero-banner__eyebrow">扫码</div>
          <h1 class="product-title">扫描 JAN 码，直接进入商品页。</h1>
          <p class="product-sub">
            相机、条码识别和手动输入统一在一个页面里。浏览器不支持时会自动回退到手动输入。
          </p>
        </div>
      </div>

      <div class="grid scan-layout">
        <section class="tile tile--wide">
          <div class="stack">
            <div class="scan-frame">
              <div id="camera" class="scan-video"></div>
              <div class="scan-beam"></div>
            </div>
            <div class="pillrow">
              <button class="button" id="start-scan" type="button">启动相机扫描</button>
              <button class="button button--ghost" id="stop-scan" type="button">停止</button>
            </div>
            <div class="notice notice--compact">先手动输入也可以，只有需要时再启动相机。相机模式需要 HTTPS。</div>
          </div>
        </section>
        <section class="tile">
          <div class="section__header">
            <h3>手动输入</h3>
            <p>拍不到就直接输条码。</p>
          </div>
          <div class="form">
            <label class="field" for="barcode-input">
              <input id="barcode-input" name="barcode-input" autofocus inputmode="numeric" placeholder="例如 4987188161027" spellcheck="false" />
            </label>
            <button class="button" id="barcode-search" type="button">查找商品</button>
            <div class="notice" id="scan-status">扫描条码，或直接输入 JAN 码。</div>
          </div>
        </section>
      </div>

      <section class="section">
        <div class="section__header">
          <div>
            <h2>扫描结果</h2>
            <p>识别到条码后，会自动跳转到商品页。</p>
          </div>
        </div>
        <div class="tile tile--wide">
          <div class="list" id="scan-result-list">
            <div class="list__item">
              <div>
                <strong>尚未识别</strong>
                <small>启动相机或输入条码后，结果会显示在这里。</small>
              </div>
              <span class="meta">待识别</span>
            </div>
          </div>
        </div>
      </section>
    </div>
  </section>

  <script type="module" is:inline>
    const { fetchProductByBarcode, resolveBase } = await import(window.__APriceConfig?.browserJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'browser.js');

    const camera = document.querySelector('#camera');
    const startButton = document.querySelector('#start-scan');
    const stopButton = document.querySelector('#stop-scan');
    const input = document.querySelector('#barcode-input');
    const searchButton = document.querySelector('#barcode-search');
    const status = document.querySelector('#scan-status');
    const resultList = document.querySelector('#scan-result-list');

    let scanner = null;
    let scanning = false;
    let lookupInFlight = false;
    let html5QrcodeLoader = null;

    const setStatus = (message) => {
      if (status) status.textContent = message;
    };

    function loadHtml5Qrcode() {
      if (window.Html5Qrcode && window.Html5QrcodeSupportedFormats) return Promise.resolve();
      if (html5QrcodeLoader) return html5QrcodeLoader;

      html5QrcodeLoader = new Promise((resolve, reject) => {
        const script = document.createElement('script');
        script.src = 'https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js';
        script.async = true;
        script.dataset.html5Qrcode = '1';
        script.onload = () => resolve();
        script.onerror = () => reject(new Error('html5-qrcode 加载失败'));
        document.head.appendChild(script);
      });

      return html5QrcodeLoader;
    }

    function syncCameraControls() {
      if (startButton) {
        startButton.disabled = scanning;
        startButton.textContent = scanning ? '相机已启动' : '启动相机扫描';
      }
      if (stopButton) stopButton.disabled = !scanning;
    }

    function renderProduct(product) {
      if (!product) {
        resultList.innerHTML = `
          <div class="list__item">
            <div>
              <strong>没有找到对应商品</strong>
              <small>请确认条码是否正确，或者去首页做模糊搜索。</small>
            </div>
            <span class="meta">暂无</span>
          </div>
        `;
        return;
      }

      resultList.innerHTML = `
        <a class="list__item" href="${resolveBase(`product/${product.id}/`)}">
          <div>
            <strong>${product.name}</strong>
            <small>${product.brand} · ${product.pack} · ${product.barcode}</small>
          </div>
          <span class="price">打开</span>
        </a>
      `;
    }

    async function lookup(code) {
      if (lookupInFlight) return;
      lookupInFlight = true;
      try {
        const product = await fetchProductByBarcode(code);
        if (product) {
          setStatus(`识别成功：${product.name}`);
          renderProduct(product);
          window.location.assign(resolveBase(`product/${product.id}/`));
          return;
        }

        setStatus(`未找到条码 ${code}`);
        renderProduct(null);
      } finally {
        lookupInFlight = false;
      }
    }

    async function startCamera() {
      if (!camera) {
        setStatus('相机容器加载失败，请刷新后重试。');
        return;
      }
      if (!window.isSecureContext) {
        setStatus('相机扫描需要 HTTPS 或 localhost。请改用手动输入。');
        return;
      }

      try {
        await loadHtml5Qrcode();
        const { Html5Qrcode, Html5QrcodeSupportedFormats } = window;
        if (!Html5Qrcode) {
          throw new Error('html5-qrcode 未初始化');
        }

        scanner = scanner || new Html5Qrcode('camera');
        await scanner.start(
          { facingMode: 'environment' },
          {
            fps: 10,
            rememberLastUsedCamera: true,
            supportedScanTypes: [Html5Qrcode.SCAN_TYPE_CAMERA],
            formatsToSupport: [
              Html5QrcodeSupportedFormats.EAN_13,
              Html5QrcodeSupportedFormats.EAN_8,
              Html5QrcodeSupportedFormats.CODE_128,
            ],
          },
          async (decodedText) => {
            if (!decodedText || lookupInFlight) return;
            const code = decodedText.trim();
            if (!code) return;
            setStatus(`识别到条码：${code}，正在查询...`);
            await lookup(code);
          },
          () => {}
        );

        scanning = true;
        setStatus('相机已启动，正在自动识别条码...');
      } catch (error) {
        setStatus(`相机启动失败：${error.message}。你仍然可以继续手动输入 JAN 码。`);
        scanning = false;
      } finally {
        syncCameraControls();
      }
    }

    async function stopCamera({ silent = false } = {}) {
      if (!scanner || !scanning) {
        scanning = false;
        syncCameraControls();
        return;
      }

      try {
        await scanner.stop();
      } catch {
        // ignore stop errors
      } finally {
        scanning = false;
        if (!silent) setStatus('已停止。');
        syncCameraControls();
      }
    }

    startButton?.addEventListener('click', startCamera);
    stopButton?.addEventListener('click', stopCamera);

    async function submitLookup() {
      const code = input?.value?.trim();
      if (!code) {
        setStatus('请输入条码。');
        return;
      }
      await lookup(code);
    }

    searchButton?.addEventListener('click', submitLookup);

    input?.addEventListener('keydown', async (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        await submitLookup();
      }
    });

    window.addEventListener('beforeunload', () => {
      stopCamera({ silent: true });
    });
    syncCameraControls();
    setStatus('等待手动输入，或点击“启动相机扫描”开始识别。');
  </script>
</BaseLayout>
