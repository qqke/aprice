---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL || '/';
---
<BaseLayout title="Aprice - 日本本地药店比价" description="在手机上快速搜索商品、查看附近价格，并保留扫码入口。" bodyClass="home-page">
  <section class="home-hero">
    <div class="shell home-hero__inner">
      <div class="home-brand">Aprice · 日本药店比价</div>
      <h1 class="home-title">先搜，再比价。</h1>
      <p class="home-copy">
        在手机上输入商品名、品牌或 JAN 码，就能直接查到可比价格。扫码和个人页也都留在这里。
      </p>

      <form class="home-search" id="home-search-form">
        <label class="field home-search__field" for="home-search">
          <input
            id="home-search"
            type="search"
            inputmode="search"
            autocomplete="off"
            placeholder="搜商品名、品牌或 JAN 码"
          />
        </label>
        <button class="button home-search__button" id="home-search-button" type="submit">搜索</button>
      </form>

      <div class="home-actions" aria-label="快速入口">
        <a class="button button--ghost" href={`${base}scan/`}>扫码查价</a>
        <a class="button button--ghost" href={`${base}me/`}>个人页</a>
      </div>

      <div class="home-links" aria-label="辅助入口">
        <button class="home-link" id="geolocate-home" type="button">用当前位置找附近价格</button>
        <span class="home-links__dot" aria-hidden="true">·</span>
        <button class="home-link" id="load-recent-prices" type="button">查看最近采样</button>
      </div>

      <p class="home-meta">支持商品名、品牌、假名片段和 JAN 条码。</p>
    </div>
  </section>

  <section class="home-section">
    <div class="shell home-section__shell">
      <div class="section__header section__header--tight">
        <div>
          <h2>搜索结果</h2>
          <p id="search-status">输入关键词后显示匹配商品。</p>
        </div>
        <span class="pill">搜索</span>
      </div>
      <div class="home-panel">
        <div class="list home-results" id="search-results">
          <div class="notice notice--compact">搜索后显示商品列表。</div>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="shell home-section__shell">
      <div class="section__header section__header--tight">
        <div>
          <h2>附近比价</h2>
          <p>先选中商品，再按当前位置排序。</p>
        </div>
        <span class="pill">附近</span>
      </div>
      <div class="home-panel">
        <div class="notice notice--compact home-status" id="nearby-status">先搜索商品，再查看附近价格。</div>
        <div class="list home-results" id="nearby-results">
          <div class="notice notice--compact">搜索后，附近门店价格会显示在这里。</div>
        </div>
      </div>
    </div>
  </section>

  <section class="home-section home-section--last">
    <div class="shell home-section__shell">
      <div class="section__header section__header--tight">
        <div>
          <h2>最近采样</h2>
          <p>最近录入或更新的价格。</p>
        </div>
        <span class="pill">采样</span>
      </div>
      <div class="home-panel">
        <div class="notice notice--compact home-status" id="recent-status">点击按钮后加载最近采样。</div>
        <div class="list home-results" id="recently-viewed">
          <div class="notice notice--compact">最近采样会按时间显示在这里。</div>
        </div>
      </div>
    </div>
  </section>

  <script type="module" is:inline>
    const {
      fetchNearbyPrices,
      fetchPricesForProduct,
      fetchRecentPrices,
      formatDistance,
      formatYen,
      geolocate,
      resolveBase,
      searchProducts,
    } = await import(window.__APriceConfig?.browserJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'browser.js');

    const form = document.querySelector('#home-search-form');
    const input = document.querySelector('#home-search');
    const results = document.querySelector('#search-results');
    const status = document.querySelector('#search-status');
    const geolocateButton = document.querySelector('#geolocate-home');
    const nearbyStatus = document.querySelector('#nearby-status');
    const nearbyResults = document.querySelector('#nearby-results');
    const recentlyViewed = document.querySelector('#recently-viewed');
    const recentStatus = document.querySelector('#recent-status');
    const loadRecentButton = document.querySelector('#load-recent-prices');

    let activeProduct = null;

    function productHref(productId) {
      return resolveBase(productId ? `product/${productId}/` : '');
    }

    function renderEmptyList(node, title, detail, meta) {
      if (!node) return;
      node.innerHTML = `
        <div class="list__item">
          <div>
            <strong>${title}</strong>
            <small>${detail}</small>
          </div>
          <span class="meta">${meta}</span>
        </div>
      `;
    }

    function renderSearchResults(items) {
      if (!results) return;
      if (!items.length) {
        activeProduct = null;
        renderEmptyList(results, '暂无匹配商品', '换一个更短的关键词、品牌名或 JAN 码再试一次。', '空');
        return;
      }

      activeProduct = items[0];
      results.innerHTML = items.slice(0, 8).map((item) => `
        <a class="list__item" href="${productHref(item.id)}">
          <div>
            <strong>${item.name}</strong>
            <small>${item.brand} · ${item.pack} · ${item.barcode}</small>
          </div>
          <span class="price">查看</span>
        </a>
      `).join('');
    }

    async function renderNearbyForProduct(product) {
      if (!product || !nearbyResults || !nearbyStatus) return;
      nearbyStatus.textContent = `读取 ${product.name} 的门店价格...`;
      try {
        const prices = await fetchPricesForProduct(product.id);
        if (!prices.length) {
          renderEmptyList(nearbyResults, product.name, '当前还没有价格记录。', '暂无');
          nearbyStatus.textContent = `${product.name} 暂无价格记录。`;
          return;
        }

        nearbyResults.innerHTML = prices.slice(0, 4).map((row) => `
          <a class="list__item" href="${productHref(product.id)}">
            <div>
              <strong>${row.stores?.name || 'Unknown store'}</strong>
              <small>${row.stores?.city || ''}${row.stores?.city ? ' · ' : ''}${row.stores?.pref || ''}${row.is_member_price ? ' · 会员价' : ' · 公开价'}</small>
            </div>
            <div class="home-results__meta">
              <div class="price">${formatYen(row.price_yen)}</div>
              <small>${row.stores?.hours || ''}</small>
            </div>
          </a>
        `).join('');

        nearbyStatus.textContent = `${product.name} 已加载 ${prices.length} 条门店价格。`;
      } catch (error) {
        renderEmptyList(nearbyResults, '价格读取失败', '请稍后再试，或换一个商品。', '错误');
        nearbyStatus.textContent = `读取 ${product.name} 的价格失败：${error.message}`;
      }
    }

    async function runSearch(term) {
      const query = term.trim();
      if (!query) {
        status.textContent = '输入关键词后再搜索商品。';
        renderEmptyList(results, '等待搜索', '输入商品名、品牌名或 JAN 条码后再查价。', '空');
        renderEmptyList(nearbyResults, '等待搜索', '选中商品后，这里会显示附近价格。', '空');
        nearbyStatus.textContent = '先搜索商品，再查看附近价格。';
        activeProduct = null;
        return;
      }

      status.textContent = `搜索“${query}”...`;
      try {
        const items = await searchProducts(query);
        renderSearchResults(items);
        if (items.length) {
          status.textContent = `找到 ${items.length} 条匹配结果。默认选中第一项。`;
          void renderNearbyForProduct(activeProduct);
        } else {
          status.textContent = `没有找到“${query}”，可以换个关键词。`;
          nearbyStatus.textContent = '找到商品后才显示附近价格。';
          renderEmptyList(nearbyResults, '没有可比价格', '先找到一个商品，再看附近门店。', '空');
        }
      } catch (error) {
        status.textContent = `搜索失败：${error.message}`;
        renderEmptyList(results, '搜索失败', '请稍后再试。', '错误');
        nearbyStatus.textContent = '搜索失败后仍可重新尝试。';
      }
    }

    async function renderNearbyByLocation() {
      if (!activeProduct) {
        nearbyStatus.textContent = '先搜索并选中一个商品，再按当前位置排序。';
        return;
      }

      nearbyStatus.textContent = `定位中，正在为 ${activeProduct.name} 排序...`;
      try {
        const location = await geolocate();
        const rows = await fetchNearbyPrices({
          productId: activeProduct.id,
          lat: location.lat,
          lng: location.lng,
          radiusKm: 20,
        });

        if (!rows.length) {
          renderEmptyList(nearbyResults, activeProduct.name, '当前位置附近还没有可比价格。', '暂无');
          nearbyStatus.textContent = `${activeProduct.name} 在当前位置附近还没有可比价格。`;
          return;
        }

        nearbyResults.innerHTML = rows.slice(0, 4).map((row) => `
          <a class="list__item" href="${productHref(activeProduct.id)}">
            <div>
              <strong>${row.stores?.name || 'Unknown store'}</strong>
              <small>${row.stores?.city || ''}${row.stores?.city ? ' · ' : ''}${row.stores?.pref || ''}${row.distance_km !== null && row.distance_km !== undefined ? ` · ${formatDistance(row.distance_km)}` : ''}</small>
            </div>
            <div class="home-results__meta">
              <div class="price">${formatYen(row.price_yen)}</div>
              <small>${row.is_member_price ? '会员价' : '公开价'}</small>
            </div>
          </a>
        `).join('');

        nearbyStatus.textContent = `已按当前位置排序 ${rows.length} 条价格。`;
      } catch (error) {
        nearbyStatus.textContent = `定位失败：${error.message}`;
      }
    }

    async function loadRecentPrices() {
      if (!recentStatus || !recentlyViewed) return;
      recentStatus.textContent = '最近价格采样加载中...';
      try {
        const rows = await fetchRecentPrices(6);
        if (!rows.length) {
          renderEmptyList(recentlyViewed, '暂无采样', '插入价格记录后这里会自动更新。', '空');
          recentStatus.textContent = '暂无最近价格采样。';
          return;
        }

        recentlyViewed.innerHTML = rows.slice(0, 6).map((row) => `
          <a class="list__item" href="${productHref(row.products?.id || row.product_id || '')}">
            <div>
              <strong>${row.products?.name || 'Unknown product'}</strong>
              <small>${row.stores?.name || 'Unknown store'}${row.stores?.city ? ` · ${row.stores.city}` : ''}${row.is_member_price ? ' · 会员价' : ' · 公开价'}</small>
            </div>
            <div class="home-results__meta">
              <div class="price">${formatYen(row.price_yen)}</div>
              <small>${row.collected_at ? new Date(row.collected_at).toLocaleDateString('ja-JP') : ''}</small>
            </div>
          </a>
        `).join('');
        recentStatus.textContent = `已读取 ${rows.length} 条最近价格采样。`;
      } catch (error) {
        renderEmptyList(recentlyViewed, '价格读取失败', '请检查后端连接和表权限。', '错误');
        recentStatus.textContent = `最近价格读取失败：${error.message}`;
      }
    }

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      await runSearch(input?.value || '');
    });

    geolocateButton?.addEventListener('click', () => {
      void renderNearbyByLocation();
    });

    loadRecentButton?.addEventListener('click', () => {
      void loadRecentPrices();
    });
  </script>
</BaseLayout>