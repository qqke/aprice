---
import BaseLayout from '../layouts/BaseLayout.astro';

export const prerender = true;

const base = import.meta.env.BASE_URL || '/';
---
<BaseLayout title="搜比价 - 日本本地药店比价" description="在手机上快速搜索商品、查看附近价格，并保留扫码入口。" bodyClass="home-page">
  <div class="home-v2">
    <section class="home-hero">
      <div class="shell home-hero__inner">
        <div class="home-hero__badge">搜比价 · 日常药店比价</div>
        <h1 class="home-title">先搜再比价</h1>
        <form class="home-search" id="home-search-form">
          <label class="field home-search__field" for="home-search">
            <span class="home-search__icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false" aria-hidden="true">
                <circle cx="11" cy="11" r="6.5" fill="none" stroke="currentColor" stroke-width="1.8" />
                <path d="M16 16l4 4" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.8" />
              </svg>
            </span>
            <input
              id="home-search"
              name="home-search"
              type="search"
              inputmode="search"
              autocomplete="off"
              spellcheck="false"
              placeholder="搜索商品名、品牌或 JAN 码"
              aria-controls="search-results"
              aria-describedby="search-status"
              aria-keyshortcuts="Ctrl+K /"
            />
            <a class="home-search__scan" href={`${base}scan/`} aria-label="打开扫码查价">
              <svg viewBox="0 0 24 24" role="presentation" focusable="false" aria-hidden="true">
                <path d="M7.5 8.5h2m5 0h2m-10 7h11m-13-8.25L6 5.75h12l1.5 1.5v9.5a1.5 1.5 0 0 1-1.5 1.5h-12a1.5 1.5 0 0 1-1.5-1.5z" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.7" />
                <circle cx="12" cy="12" r="2.75" fill="none" stroke="currentColor" stroke-width="1.7" />
              </svg>
              <span class="sr-only">扫码查价</span>
            </a>
            <button class="button home-search__button" id="home-search-button" type="submit">搜索</button>
          </label>
          <div class="home-search__hints" aria-hidden="true">
            <span class="home-search__hint">支持商品名</span>
            <span class="home-search__hint">支持品牌名</span>
            <span class="home-search__hint">支持 JAN 条码</span>
            <span class="home-search__hint home-search__hint--accent">可直接扫码</span>
          </div>
        </form>
        <p class="home-meta">快捷键 <code>Ctrl+K</code> 或 <code>/</code> 可直达搜索框。</p>
      </div>
    </section>

    <section class="home-section">
      <div class="shell home-section__shell">
        <div class="home-section__title">
          <h2>搜索结果</h2>
          <small>最多显示 8 条匹配结果</small>
        </div>
        <p id="search-status">输入关键词后显示可选商品。</p>
        <div class="home-panel home-panel--search">
          <div class="home-panel__bar" aria-hidden="true">
            <span class="home-panel__eyebrow">候选商品</span>
            <span class="home-panel__meta">搜索后显示商品列表</span>
          </div>
          <div class="list home-results" id="search-results" role="listbox" aria-live="polite" aria-label="搜索结果列表">
            <div class="notice notice--compact">搜索后显示商品列表。</div>
          </div>
        </div>
      </div>
      <div class="home-quick-dock" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
        <span></span>
      </div>
    </section>

    <section class="home-section">
      <div class="shell home-section__shell">
        <div class="home-section__title">
          <h2>附近比价</h2>
          <small>优先展示最近采样到的附近结果</small>
        </div>
        <div class="home-panel home-panel--nearby">
          <div class="home-nearby-workspace">
            <aside class="home-nearby-context">
              <div class="home-panel__bar home-panel__bar--stacked" aria-hidden="true">
                <span class="home-panel__eyebrow">当前商品</span>
                <span class="home-panel__meta">作为右侧比价结果的固定上下文</span>
              </div>
              <div class="home-selection" aria-live="polite">
                <div class="home-selection-card home-selection-card--empty" id="selected-product-status">
                  <div class="home-selection-card__copy">
                    <strong>当前比价商品：未选择</strong>
                    <small>先在上方搜索并选中一个商品，这里会固定显示当前查看对象。</small>
                  </div>
                </div>
                <a class="button button--ghost home-selection__action" id="selected-product-action" href={`${base}scan/`} hidden>打开详情</a>
              </div>
              <div class="notice notice--compact home-status" id="nearby-status">先搜索商品，再查看附近价格。</div>
            </aside>
            <div class="home-nearby-board">
              <div class="home-map-card">
                <div class="home-map-card__header">
                  <strong>附近门店地图</strong>
                  <small id="nearby-map-status">加载中：等待门店数据。</small>
                </div>
                <div class="home-map" id="nearby-map" aria-live="polite">
                  <div class="notice notice--compact">搜索后，附近门店位置会显示在这里。</div>
                </div>
              </div>
              <div class="list home-results" id="nearby-results" aria-live="polite" aria-label="附近价格结果">
                <div class="notice notice--compact">搜索后，附近门店价格会显示在这里。</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="home-section home-section--last">
      <div class="shell home-section__shell">
        <div class="home-feature-grid">
          <a class="home-feature-card home-feature-card--scan" href={`${base}scan/`}>
            <div class="home-feature-card__icon" aria-hidden="true"></div>
            <div class="home-feature-card__copy">
              <strong>打开即扫</strong>
              <small>识别后立即直达商品，快速开始比价。</small>
            </div>
          </a>
          <a class="home-feature-card home-feature-card--decision" href={`${base}me/`}>
            <div class="home-feature-card__icon" aria-hidden="true"></div>
            <div class="home-feature-card__copy">
              <strong>价格决策中心</strong>
              <small>记录与收藏当前结果，把看到的价格带回仓库。</small>
            </div>
          </a>
          <a class="home-feature-card home-feature-card--profile" href={`${base}me/`}>
            <div class="home-feature-card__icon" aria-hidden="true"></div>
            <div class="home-feature-card__copy">
              <strong>个人中心</strong>
              <small>查看个人价格记录、最近浏览和收藏内容。</small>
            </div>
          </a>
        </div>
      </div>
    </section>
  </div>

  <script type="module" is:inline>
    const {
      fetchPricesForProduct,
      escapeAttribute,
      escapeHtml,
      buildExternalMapUrl,
      buildGoogleMapEmbedUrl,
      buildStoreMapModel,
      formatYen,
      resolveBase,
      searchProducts,
    } = await import(window.__APriceConfig?.browserJsUrl || (window.__APriceConfig?.baseUrl || '/') + 'browser.js');

    const form = document.querySelector('#home-search-form');
    const input = document.querySelector('#home-search');
    const results = document.querySelector('#search-results');
    const status = document.querySelector('#search-status');
    const nearbyStatus = document.querySelector('#nearby-status');
    const selectedProductStatus = document.querySelector('#selected-product-status');
    const selectedProductAction = document.querySelector('#selected-product-action');
    const nearbyResults = document.querySelector('#nearby-results');
    const nearbyMap = document.querySelector('#nearby-map');
    const nearbyMapStatus = document.querySelector('#nearby-map-status');

    let activeProduct = null;
    let searchResults = [];
    let focusedResultIndex = -1;

    function setNearbyStatus(message, emphasized = false) {
      if (!nearbyStatus) return;
      nearbyStatus.textContent = message;
      if ('classList' in nearbyStatus && nearbyStatus.classList?.toggle) {
        nearbyStatus.classList.toggle('home-status--selected', emphasized);
      }
    }

    function productHref(productId) {
      return resolveBase(productId ? `product/${productId}/` : '');
    }

    function renderEmptyList(node, title, detail, meta) {
      if (!node) return;
      node.innerHTML = `
          <div class="list__item">
            <div>
              <strong>${escapeHtml(title)}</strong>
              <small>${escapeHtml(detail)}</small>
            </div>
            <span class="meta">${escapeHtml(meta)}</span>
          </div>
      `;
    }

    function renderSearchIdleState() {
      if (!results) return;
      results.innerHTML = `
        <div class="home-empty-state home-empty-state--search">
          <div class="home-empty-state__copy">
            <strong>先输入商品名、品牌或 JAN 码</strong>
            <small>支持中日文商品名、品牌名和条码直搜。也可以先点一个常见关键词快速开始。</small>
          </div>
          <div class="pillrow home-empty-state__actions">
            <button class="button button--ghost home-suggestion-chip" type="button" data-suggestion="ロキソニン">ロキソニン</button>
            <button class="button button--ghost home-suggestion-chip" type="button" data-suggestion="EVE">EVE</button>
            <button class="button button--ghost home-suggestion-chip" type="button" data-suggestion="4987188161027">JAN 直搜</button>
            <a class="button button--ghost home-suggestion-chip" href="${escapeAttribute(resolveBase('scan/'))}">去扫码</a>
          </div>
        </div>
      `;
    }

    function renderNearbyIdleState() {
      if (!nearbyResults) return;
      nearbyResults.innerHTML = `
        <div class="home-empty-state home-empty-state--nearby">
          <div class="home-empty-state__copy">
            <strong>选中商品后，这里会显示附近可比门店</strong>
            <small>先在上方搜索并选中一个商品，我们会优先展示最近采样到的价格和门店营业信息。</small>
          </div>
          <div class="home-empty-steps" aria-label="使用步骤">
            <div class="home-empty-step">
              <span>1</span>
              <small>搜索商品</small>
            </div>
            <div class="home-empty-step">
              <span>2</span>
              <small>选中结果</small>
            </div>
            <div class="home-empty-step">
              <span>3</span>
              <small>查看附近比价</small>
            </div>
          </div>
        </div>
      `;
    }

    function renderNearbyMapIdleState(title = '选中商品后显示附近门店地图', detail = '加载中：等待门店数据。') {
      if (!nearbyMap) return;
      nearbyMap.innerHTML = `
        <div class="home-map__empty">
          <strong>${escapeHtml(title)}</strong>
          <small>${escapeHtml(detail)}</small>
        </div>
      `;
      if (nearbyMapStatus) nearbyMapStatus.textContent = detail;
    }

    function formatNearbyMapStatus({ mapped = 0, missing = 0, highlightedName = '' } = {}) {
      const mappedLabel = `已显示 ${mapped} 家门店`;
      const missingLabel = missing ? ` · ${missing} 家缺坐标` : '';
      const highlightedLabel = highlightedName ? ` · 已选 ${highlightedName}` : '';
      return `${mappedLabel}${missingLabel}${highlightedLabel}`;
    }

    function syncSelectedProductCard() {
      if (selectedProductStatus) {
        if (activeProduct) {
          selectedProductStatus.className = 'home-selection-card';
          selectedProductStatus.innerHTML = `
            <div class="home-selection-card__media${activeProduct.image_url ? '' : ' is-empty'}">
              ${activeProduct.image_url
                ? `<img class="product-thumb product-thumb--selection" src="${escapeAttribute(activeProduct.image_url)}" alt="${escapeAttribute(activeProduct.name || '商品图片')}" loading="lazy" decoding="async" referrerpolicy="no-referrer" />`
                : `<span class="home-selection-card__fallback" aria-hidden="true">${escapeHtml((activeProduct.name || '?').slice(0, 1))}</span>`}
            </div>
            <div class="home-selection-card__copy">
              <span class="home-selection-card__eyebrow">当前比价商品</span>
              <strong>${escapeHtml(activeProduct.name || '未命名商品')}</strong>
              <small>${escapeHtml(activeProduct.brand || '品牌待补充')}${activeProduct.pack ? ` · ${escapeHtml(activeProduct.pack)}` : ''}</small>
              <div class="home-result__meta-row">
                <span class="home-result__barcode">JAN ${escapeHtml(activeProduct.barcode || activeProduct.id || '')}</span>
              </div>
            </div>
          `;
        } else {
          selectedProductStatus.className = 'home-selection-card home-selection-card--empty';
          selectedProductStatus.innerHTML = `
            <div class="home-selection-card__copy">
              <strong>当前比价商品：未选择</strong>
              <small>先在上方搜索并选中一个商品，这里会固定显示当前查看对象。</small>
            </div>
          `;
        }
      }
      if (!selectedProductAction) return;
      if (activeProduct) {
        selectedProductAction.hidden = false;
        selectedProductAction.href = productHref(activeProduct.id);
        selectedProductAction.textContent = '查看详情';
      } else {
        selectedProductAction.hidden = true;
        selectedProductAction.href = `${productHref('')}`;
      }
    }

    function syncSearchListboxA11y() {
      if (!input) return;
      const visibleResults = getVisibleResults();
      const activeItem = visibleResults[focusedResultIndex] || activeProduct || null;
      const activeId = activeItem ? `home-result-option-${activeItem.id}` : '';
      if (activeId) {
        input.setAttribute('aria-activedescendant', activeId);
      } else {
        input.removeAttribute('aria-activedescendant');
      }
    }

    function clearNearbyState() {
      renderNearbyIdleState();
      setNearbyStatus('选中商品后显示附近门店价格。', false);
      renderNearbyMapIdleState();
    }

    function clearSearchState() {
      activeProduct = null;
      searchResults = [];
      focusedResultIndex = -1;
      if (input) input.value = '';
      syncSelectedProductCard();
      renderSearchIdleState();
      clearNearbyState();
    }

    function getVisibleResults() {
      return searchResults.slice(0, 8);
    }

    function normalizeSearchValue(value) {
      return String(value || '').trim().toLocaleLowerCase('ja-JP').normalize('NFKC');
    }

    function isStrongMatch(query, product) {
      const normalizedQuery = normalizeSearchValue(query);
      if (!normalizedQuery || !product) return false;
      const normalizedName = normalizeSearchValue(product.name);
      const normalizedBrand = normalizeSearchValue(product.brand);
      const normalizedPack = normalizeSearchValue(product.pack);
      const normalizedBarcode = normalizeSearchValue(product.barcode);
      return (
        normalizedQuery === normalizedBarcode ||
        normalizedQuery === normalizedName ||
        normalizedQuery === normalizedBrand ||
        normalizedQuery === `${normalizedBrand} ${normalizedName}`.trim() ||
        normalizedQuery === `${normalizedName} ${normalizedPack}`.trim()
      );
    }

    function findStrongMatch(query, items) {
      return items.find((item) => isStrongMatch(query, item)) || null;
    }

    function setFocusedResultIndex(nextIndex) {
      const visibleResults = getVisibleResults();
      if (!visibleResults.length) {
        focusedResultIndex = -1;
        syncSearchListboxA11y();
        return;
      }
      const maxIndex = visibleResults.length - 1;
      focusedResultIndex = Math.min(Math.max(nextIndex, 0), maxIndex);
      syncSearchListboxA11y();
      renderSearchResults(searchResults);
    }

    function moveActiveResult(delta) {
      const visibleResults = getVisibleResults();
      if (!visibleResults.length) return;
      const fallbackIndex = focusedResultIndex >= 0 ? focusedResultIndex : visibleResults.findIndex((item) => item.id === activeProduct?.id);
      const currentIndex = fallbackIndex >= 0 ? fallbackIndex : 0;
      setFocusedResultIndex(currentIndex + delta);
    }

    function scrollFocusedResultIntoView() {
      if (!results || focusedResultIndex < 0) return;
      const focusedItem = results.querySelector(`[data-result-index="${focusedResultIndex}"]`);
      focusedItem?.scrollIntoView({ block: 'nearest', inline: 'nearest' });
    }

    async function selectProduct(product) {
      if (!product) return;
      activeProduct = product;
      focusedResultIndex = getVisibleResults().findIndex((item) => item.id === product.id);
      syncSelectedProductCard();
      renderSearchResults(searchResults);
      await renderNearbyForProduct(product);
    }

    function renderSearchResults(items) {
      if (!results) return;
      searchResults = items.slice();
      if (!items.length) {
        activeProduct = null;
        focusedResultIndex = -1;
        syncSearchListboxA11y();
        syncSelectedProductCard();
        renderEmptyList(results, '暂无匹配商品', '换一个更短的关键词、品牌名或 JAN 码再试一次。', '空');
        clearNearbyState();
        return;
      }

      const visibleResults = getVisibleResults();
      if (activeProduct) {
        focusedResultIndex = visibleResults.findIndex((item) => item.id === activeProduct.id);
      } else if (focusedResultIndex >= visibleResults.length) {
        focusedResultIndex = visibleResults.length - 1;
      }
      syncSearchListboxA11y();
      syncSelectedProductCard();
      results.innerHTML = visibleResults.map((item, index) => {
        const selected = activeProduct?.id === item.id;
        const focused = focusedResultIndex === index;
        const statusLabel = selected ? '当前选中' : focused ? '当前焦点' : '';
        return `
          <div class="list__item home-result${selected ? ' is-active' : ''}${focused ? ' is-focused' : ''}" data-result-index="${index}">
            <button class="home-result__main" id="home-result-option-${escapeAttribute(item.id)}" type="button" data-select-product="${escapeAttribute(item.id)}" role="option" aria-selected="${selected ? 'true' : 'false'}" aria-pressed="${selected ? 'true' : 'false'}" aria-label="选择 ${escapeAttribute(item.name)}">
              <div class="home-result__media${item.image_url ? '' : ' is-empty'}">
                ${item.image_url ? `<img class="product-thumb product-thumb--home" src="${escapeAttribute(item.image_url)}" alt="${escapeAttribute(item.name || '商品图片')}" loading="lazy" decoding="async" referrerpolicy="no-referrer" />` : `<span class="home-result__media-fallback" aria-hidden="true">${escapeHtml((item.name || '?').slice(0, 1))}</span>`}
              </div>
              <div class="home-result__copy">
                ${statusLabel ? `<span class="home-result__status">${statusLabel}</span>` : ''}
                <strong>${escapeHtml(item.name)}</strong>
                <small class="home-result__details">${escapeHtml(item.brand)}${item.pack ? ` · ${escapeHtml(item.pack)}` : ''}</small>
                <div class="home-result__meta-row">
                  <span class="home-result__barcode">JAN ${escapeHtml(item.barcode)}</span>
                </div>
              </div>
            </button>
            <div class="home-result__actions">
              <a class="button button--ghost home-result__action" href="${escapeAttribute(productHref(item.id))}">详情</a>
            </div>
          </div>
        `;
      }).join('');

      results.querySelectorAll('[data-select-product]').forEach((button) => {
        button.addEventListener('click', async () => {
          const product = items.find((entry) => entry.id === button.dataset.selectProduct);
          if (product) {
            await selectProduct(product);
          }
        });
      });
      requestAnimationFrame(scrollFocusedResultIntoView);
    }

    async function renderNearbyForProduct(product) {
      if (!product || !nearbyResults || !nearbyStatus) return;
      setNearbyStatus(`${product.name} 价格读取中...`, true);
      try {
        const prices = await fetchPricesForProduct(product.id, { limit: 80, sinceDays: 45 });
        if (!prices.length) {
          renderEmptyList(nearbyResults, product.name, '当前还没有价格记录。', '暂无');
          setNearbyStatus(`${product.name} 暂无门店价格。`, true);
          renderNearbyMapIdleState('无坐标：地图待补充', '当前商品暂无可用坐标，可先使用下方外部地图链接。');
          return;
        }

        const stores = Array.from(new Map(prices
          .map((row) => row?.stores ? {
            ...row.stores,
            id: row.store_id || row.stores.id,
            price_yen: row.price_yen,
            is_member_price: row.is_member_price,
          } : null)
          .filter(Boolean)
          .map((store) => [store.id, store])).values());
        const mapModel = buildStoreMapModel(stores, {
          featuredStoreIds: stores[0]?.id ? [stores[0].id] : [],
          highlightedStoreId: stores[0]?.id || '',
        });

        if (nearbyMap) {
          if (!mapModel.points.length) {
            renderNearbyMapIdleState('地图待补充', '当前门店缺少坐标，暂时无法绘制地图。');
          } else {
            const focusPoint = mapModel.points.find((point) => point.isHighlighted)
              || mapModel.points.find((point) => point.isFeatured)
              || mapModel.points[0];
            const mapStatusLabel = formatNearbyMapStatus({
              mapped: mapModel.points.length,
              missing: mapModel.missingCount,
              highlightedName: focusPoint?.name || '',
            });
            nearbyMap.innerHTML = `
              <div class="home-map__canvas-wrap">
                <div class="home-map__canvas" role="img" aria-label="${escapeAttribute(`${product.name} 附近门店地图`)}">
                  <iframe
                    class="home-map__iframe"
                    title="${escapeAttribute(`${focusPoint?.name || product.name} Google 地图`)}"
                    src="${escapeAttribute(buildGoogleMapEmbedUrl(focusPoint, { zoom: 15 }))}"
                    loading="lazy"
                    referrerpolicy="no-referrer-when-downgrade"
                  ></iframe>
                  <div class="home-map__status-pill" aria-hidden="true">${escapeHtml(mapStatusLabel)}</div>
                  <svg class="home-map__grid" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
                    <path d="M0 25H100M0 50H100M0 75H100M25 0V100M50 0V100M75 0V100"></path>
                  </svg>
                  ${mapModel.points.map((point, index) => `
                    <a
                      class="home-map__marker${point.isFeatured ? ' is-featured' : ''}${point.isHighlighted ? ' is-highlighted' : ''}"
                      href="${escapeAttribute(buildExternalMapUrl(point))}"
                      target="_blank"
                      rel="noreferrer"
                      style="left:${point.x.toFixed(2)}%;top:${point.y.toFixed(2)}%;"
                      data-home-map-store-id="${escapeAttribute(point.id)}"
                      aria-label="${escapeAttribute(`${point.name || '未知门店'}，${formatYen(point.price_yen || 0)}`)}"
                      title="${escapeAttribute(`${point.name || '未知门店'} · ${formatYen(point.price_yen || 0)}`)}"
                    >
                      <span>${index + 1}</span>
                    </a>
                  `).join('')}
                </div>
                <div class="home-map__legend" aria-hidden="true">
                  <span class="home-map__legend-item"><span class="home-map__legend-dot is-featured"></span>最近</span>
                  <span class="home-map__legend-item"><span class="home-map__legend-dot is-highlighted"></span>已选</span>
                  <span class="home-map__legend-item"><span class="home-map__legend-dot"></span>附近</span>
                </div>
              </div>
              <div class="home-map__list">
                ${mapModel.points.slice(0, 4).map((point) => `
                  <div class="home-map__list-item">
                    <div class="home-map__list-copy">
                      <strong>${escapeHtml(point.name || '未知门店')}</strong>
                      <small>${escapeHtml([point.city, point.pref].filter(Boolean).join(' · ') || '门店位置已同步')}${point.hours ? ` · ${escapeHtml(point.hours)}` : ''}</small>
                    </div>
                    <a class="home-map__external-link" href="${escapeAttribute(buildExternalMapUrl(point))}" target="_blank" rel="noreferrer">打开地图</a>
                  </div>
                `).join('')}
                ${mapModel.missingCount ? `<small class="home-map__footnote">${mapModel.missingCount} 家门店缺少坐标，未显示在图上。</small>` : ''}
              </div>
            `;
            const canvas = nearbyMap.querySelector('.home-map__canvas');
            if (canvas && !canvas.querySelector('iframe')) {
              const frame = document.createElement('iframe');
              frame.className = 'home-map__iframe';
              frame.title = `${focusPoint?.name || product.name} Google 地图`;
              frame.src = buildGoogleMapEmbedUrl(focusPoint, { zoom: 15 });
              frame.loading = 'lazy';
              frame.referrerPolicy = 'no-referrer-when-downgrade';
              canvas.prepend(frame);
            }
            if (nearbyMapStatus) nearbyMapStatus.textContent = mapModel.missingCount
              ? `可交互：已显示 ${mapModel.points.length} 家门店，另有 ${mapModel.missingCount} 家缺少坐标。`
              : `可交互：已显示 ${mapModel.points.length} 家门店。`;
          }
        }

        nearbyResults.innerHTML = prices.slice(0, 4).map((row) => `
          <a class="list__item home-nearby-result" href="${escapeAttribute(productHref(product.id))}">
            <div class="home-nearby-result__media${row.is_member_price ? ' is-member' : ''}">
              <span class="home-nearby-result__price">${formatYen(row.price_yen)}</span>
              <small>${row.is_member_price ? '会员价' : '公开价'}</small>
            </div>
            <div class="home-nearby-result__copy">
              <strong>${escapeHtml(row.stores?.name || '未知门店')}</strong>
              <small class="home-nearby-result__details">${escapeHtml(row.stores?.city || '')}${row.stores?.city ? ' · ' : ''}${escapeHtml(row.stores?.pref || '')}</small>
              <div class="home-result__meta-row">
                <span class="home-result__barcode">${escapeHtml(row.stores?.hours || '营业时间待补充')}</span>
              </div>
            </div>
            <div class="home-results__meta home-nearby-result__meta">
              <div class="price">${formatYen(row.price_yen)}</div>
              <small>查看详情</small>
            </div>
          </a>
        `).join('');

        setNearbyStatus(`${product.name} · ${prices.length} 条价格`, true);
      } catch (error) {
        renderEmptyList(nearbyResults, '价格读取失败', '请稍后再试，或换一个商品。', '错误');
        setNearbyStatus(`${product.name} 价格读取失败：${error.message}`, true);
        renderNearbyMapIdleState('地图读取失败', `当前无法加载附近门店地图：${error.message}`);
      }
    }

    async function runSearch(term) {
      const query = term.trim();
      if (!query) {
        status.textContent = '输入关键词后再搜索商品。';
        clearSearchState();
        return;
      }

      status.textContent = `搜索“${query}”...`;
      try {
        const items = await searchProducts(query);
        renderSearchResults(items);
        if (items.length) {
          const autoSelect = findStrongMatch(query, items) || (items.length === 1 ? items[0] : null);
          if (autoSelect) {
            await selectProduct(autoSelect);
            status.textContent = `已匹配到 ${autoSelect.name}，正在显示附近价格。`;
          } else if (!activeProduct) {
            focusedResultIndex = 0;
            renderSearchResults(items);
            status.textContent = `找到 ${items.length} 条匹配结果。先选中一个商品，再查看附近价格。`;
            clearNearbyState();
          } else {
            status.textContent = `找到 ${items.length} 条匹配结果。当前商品已保留，可继续切换。`;
          }
        } else {
          status.textContent = `没有找到“${query}”，可以换个关键词。`;
          clearNearbyState();
        }
      } catch (error) {
        status.textContent = `搜索失败：${error.message}`;
        renderEmptyList(results, '搜索失败', '请稍后再试。', '错误');
        setNearbyStatus('搜索失败后仍可重新尝试。', false);
      }
    }

    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      await runSearch(input?.value || '');
    });

    results?.addEventListener('click', async (event) => {
      const target = event.target;
      const button = target instanceof Element ? target.closest('[data-suggestion]') : null;
      if (!button || !input) return;
      const suggestion = button.getAttribute('data-suggestion') || '';
      input.value = suggestion;
      input.focus();
      await runSearch(suggestion);
    });

    input?.addEventListener('keydown', async (event) => {
      if (event.key === 'Escape') {
        event.preventDefault();
        clearSearchState();
        input?.focus();
        status.textContent = '已清空搜索，可以重新输入。';
        return;
      }
      if (!searchResults.length) return;
      if (event.key === 'ArrowDown') {
        event.preventDefault();
        moveActiveResult(1);
      } else if (event.key === 'ArrowUp') {
        event.preventDefault();
        moveActiveResult(-1);
      } else if (event.key === 'Home') {
        event.preventDefault();
        setFocusedResultIndex(0);
      } else if (event.key === 'End') {
        event.preventDefault();
        setFocusedResultIndex(getVisibleResults().length - 1);
      } else if (event.key === 'Enter' && focusedResultIndex >= 0) {
        event.preventDefault();
        await selectProduct(getVisibleResults()[focusedResultIndex]);
      }
    });

    document.addEventListener('keydown', (event) => {
      const target = event.target;
      const isTypingField =
        target instanceof HTMLElement &&
        (target.matches('input, textarea, select') || target.isContentEditable);
      const shortcutKey = event.key === '/' || ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k');
      if (!shortcutKey || isTypingField) return;
      event.preventDefault();
      input?.focus({ preventScroll: true });
      input?.select();
      status.textContent = '搜索框已聚焦，可以直接输入。';
    });

    syncSelectedProductCard();
    renderNearbyMapIdleState();
  </script>
</BaseLayout>
