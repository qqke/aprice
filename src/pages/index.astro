---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Aprice - 日本本地药店比价" description="扫码、搜索、比较附近药店价格，并保存个人价格记录。">
  <section class="hero">
    <div class="shell hero__grid">
      <div class="hero__panel">
        <div class="hero__copy">
          <div class="eyebrow">Japanese drugstore price compare</div>
          <h1 class="headline">扫条码，立刻比日本药店价格。</h1>
          <p class="lead">
            这是一个为日本本地药店设计的轻量比价应用。扫码、模糊搜索、附近门店对比和个人价格记录都放在同一个静态站点里。
          </p>
          <div class="hero__actions">
            <a class="button" href={`${import.meta.env.BASE_URL || '/'}scan/`}>开始扫码查价</a>
            <a class="button button--ghost" href={`${import.meta.env.BASE_URL || '/'}login/`}>邮箱登录</a>
            <a class="button button--ghost" href={`${import.meta.env.BASE_URL || '/'}me/`}>个人价格记录</a>
          </div>
          <div class="hero__stats">
            <div class="stat">
              <strong>JAN 扫码</strong>
              <span>快速查到商品页面</span>
            </div>
            <div class="stat">
              <strong>附近比价</strong>
              <span>按地理位置排序门店价格</span>
            </div>
            <div class="stat">
              <strong>我的价格</strong>
              <span>保存购买价、门店与备注</span>
            </div>
          </div>
        </div>
      </div>

      <aside class="hero__panel">
        <div class="hero__scan">
          <div class="section__header" style="margin:0;">
            <div>
              <h2>即时查价面板</h2>
              <p>先搜商品，再看附近门店，最后存进个人记录。</p>
            </div>
            <span class="pill">Supabase live</span>
          </div>

          <div class="scan-card">
            <div class="scan-card__inner">
              <div class="pillrow">
                <span class="pill">JAN 4987188161027</span>
                <span class="pill">实时搜索</span>
                <span class="pill">会员价可比</span>
              </div>
              <div class="scan-frame" aria-hidden="true"></div>
              <div class="pillrow">
                <span class="pill" id="hero-product-label">加载中</span>
                <span class="pill" id="hero-price-label">¥-- 起</span>
                <span class="pill" id="hero-store-label">-- 家门店</span>
              </div>
            </div>
            <div class="scan-beam"></div>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section__header">
        <div>
          <h2>快速搜索</h2>
          <p>支持商品名、品牌、拼写片段、假名片段和 JAN 条码。</p>
        </div>
      </div>
      <div class="searchbar">
        <label class="field" for="home-search">
          <input id="home-search" type="search" placeholder="输入商品名或条码，例如 ロキソニン / 4987188161027" />
        </label>
        <button class="button" id="home-search-button" type="button">搜索</button>
      </div>
      <div class="divider"></div>
      <div class="grid">
        <section class="tile tile--wide">
          <div class="section__header">
            <h3>搜索结果</h3>
            <p id="search-status">正在读取真实商品。</p>
          </div>
          <div class="list" id="search-results">
            <div class="list__item">
              <div>
                <strong>加载中</strong>
                <small>正在从 Supabase 读取商品。</small>
              </div>
              <span class="meta">loading</span>
            </div>
          </div>
        </section>
        <section class="tile">
          <div class="section__header">
            <h3>热门商品</h3>
            <p>先从最近更新的几款开始。</p>
          </div>
          <div class="list" id="popular-products">
            <div class="list__item">
              <div>
                <strong>加载中</strong>
                <small>Supabase 商品列表正在读取。</small>
              </div>
              <span class="meta">loading</span>
            </div>
          </div>
        </section>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <div class="section__header">
        <div>
          <h2>附近价格</h2>
          <p>打开定位后，会用当前商品的门店价格做附近排序。</p>
        </div>
        <button class="button button--ghost" id="geolocate-home" type="button">使用当前位置</button>
      </div>
      <div class="grid">
        <section class="tile tile--wide">
          <div class="list" id="nearby-results">
            <div class="list__item">
              <div>
                <strong>加载中</strong>
                <small>将在商品数据加载后显示价格分布。</small>
              </div>
              <span class="meta">loading</span>
            </div>
          </div>
        </section>
        <section class="tile">
          <div class="section__header">
            <h3>最近采样</h3>
          </div>
          <div class="list" id="recently-viewed">
            <div class="list__item">
              <div>
                <strong>等待数据</strong>
                <small>正在从 Supabase 读取最近价格。</small>
              </div>
              <span class="meta">ready</span>
            </div>
          </div>
        </section>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell hero-banner">
      <div class="hero-banner__inner">
        <div class="hero-banner__eyebrow">Personal price log</div>
        <h2 class="product-title">把你看到的价，变成你自己的历史。</h2>
        <p class="product-sub">
          记录购买价、门店、时间和备注，之后就能回头比较你自己真正买到的价格。
        </p>
        <div class="pillrow">
          <span class="pill">我的价格记录</span>
          <span class="pill">收藏商品</span>
          <span class="pill">最近查看</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section footer">
    <div class="shell">
      <p>
        这是一个静态站点 MVP。登录、数据与权限由 Supabase 提供，GitHub Pages 只负责托管前端页面。
      </p>
    </div>
  </section>

  <script type="module">
    import {
      fetchNearbyPrices,
      fetchPricesForProduct,
      fetchRecentPrices,
      formatDistance,
      formatYen,
      geolocate,
      resolveBase,
      searchProducts,
    } from '../lib/browser.js';

    const input = document.querySelector('#home-search');
    const button = document.querySelector('#home-search-button');
    const results = document.querySelector('#search-results');
    const status = document.querySelector('#search-status');
    const geolocateButton = document.querySelector('#geolocate-home');
    const popularProducts = document.querySelector('#popular-products');
    const nearbyResults = document.querySelector('#nearby-results');
    const heroProductLabel = document.querySelector('#hero-product-label');
    const heroPriceLabel = document.querySelector('#hero-price-label');
    const heroStoreLabel = document.querySelector('#hero-store-label');
    const recentlyViewed = document.querySelector('#recently-viewed');

    let activeProduct = null;

    function productCard(item) {
      return `
        <a class="list__item" href="${resolveBase(`product/${item.id}/`)}">
          <div>
            <strong>${item.name}</strong>
            <small>${item.brand} · ${item.pack} · ${item.barcode}</small>
          </div>
          <span class="price">查看</span>
        </a>
      `;
    }

    function renderProducts(items) {
      if (!items.length) {
        popularProducts.innerHTML = `
          <div class="list__item">
            <div>
              <strong>暂无商品</strong>
              <small>先在 Supabase 里插入商品数据。</small>
            </div>
            <span class="meta">empty</span>
          </div>
        `;
        results.innerHTML = popularProducts.innerHTML;
        return;
      }

      popularProducts.innerHTML = items.slice(0, 6).map(productCard).join('');
      results.innerHTML = items.slice(0, 8).map(productCard).join('');
      activeProduct = items[0];
      heroProductLabel.textContent = activeProduct.name;
    }

    async function renderNearbyForProduct(product) {
      if (!product) return;
      const prices = await fetchPricesForProduct(product.id);
      if (!prices.length) {
        nearbyResults.innerHTML = `
          <div class="list__item">
            <div>
              <strong>${product.name}</strong>
              <small>当前还没有价格记录。</small>
            </div>
            <span class="meta">empty</span>
          </div>
        `;
        heroPriceLabel.textContent = '¥-- 起';
        heroStoreLabel.textContent = '-- 家门店';
        return;
      }

      nearbyResults.innerHTML = prices.slice(0, 4).map((row) => `
        <div class="list__item">
          <div>
            <strong>${row.stores?.name || 'Unknown store'}</strong>
            <small>${row.stores?.address || ''} · ${row.stores?.hours || ''}</small>
          </div>
          <div style="text-align:right;">
            <div class="price">¥${row.price_yen}</div>
            <small>${row.is_member_price ? '会员价' : '公开价'}</small>
          </div>
        </div>
      `).join('');

      heroPriceLabel.textContent = `¥${Math.min(...prices.map((row) => row.price_yen))} 起`;
      heroStoreLabel.textContent = `${new Set(prices.map((row) => row.store_id)).size} 家门店`;
    }

    async function runSearch(term) {
      const items = await searchProducts(term);
      status.textContent = term ? `${items.length} 条结果` : '正在展示 Supabase 商品。';
      renderProducts(items);
      if (items.length) {
        await renderNearbyForProduct(items[0]);
      }
    }

    button?.addEventListener('click', () => runSearch(input?.value || ''));
    input?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter') {
        event.preventDefault();
        runSearch(input.value);
      }
    });

    geolocateButton?.addEventListener('click', async () => {
      geolocateButton.textContent = '定位中...';
      try {
        const location = await geolocate();
        status.textContent = `当前位置：${location.lat.toFixed(4)}, ${location.lng.toFixed(4)}。`;
        if (activeProduct) {
          const rows = await fetchNearbyPrices({ productId: activeProduct.id, lat: location.lat, lng: location.lng, radiusKm: 20 });
          nearbyResults.innerHTML = rows.length
            ? rows.slice(0, 4).map((row) => `
              <div class="list__item">
                <div>
                  <strong>${row.stores?.name || 'Unknown store'}</strong>
                  <small>${row.stores?.city || ''} · ${row.stores?.pref || ''} · ${row.distance_km !== null && row.distance_km !== undefined ? formatDistance(row.distance_km) : ''}</small>
                </div>
                <div style="text-align:right;">
                  <div class="price">¥${row.price_yen}</div>
                  <small>${row.is_member_price ? '会员价' : '公开价'}</small>
                </div>
              </div>
            `).join('')
            : nearbyResults.innerHTML;
        }
      } catch (error) {
        status.textContent = `定位失败：${error.message}`;
      } finally {
        geolocateButton.textContent = '使用当前位置';
      }
    });

    function renderRecentPrices(rows) {
      if (!recentlyViewed) return;
      recentlyViewed.innerHTML = rows.length
        ? rows.map((row) => `
          <div class="list__item">
            <div>
              <strong>${row.products?.name || 'Unknown product'}</strong>
              <small>${row.stores?.name || 'Unknown store'} · ${row.stores?.city || ''} · ${row.is_member_price ? '会员价' : '公开价'}</small>
            </div>
            <div style="text-align:right;">
              <div class="price">${formatYen(row.price_yen)}</div>
              <small>${row.collected_at ? new Date(row.collected_at).toLocaleDateString('ja-JP') : ''}</small>
            </div>
          </div>
        `).join('')
        : `
          <div class="list__item">
            <div>
              <strong>暂无采样</strong>
              <small>先在 Supabase 里插入价格记录。</small>
            </div>
            <span class="meta">empty</span>
          </div>
        `;
    }
    async function loadRecentPrices() {
      const rows = await fetchRecentPrices(6);
      renderRecentPrices(rows);
    }

    await Promise.all([loadRecentPrices(), runSearch('')]);
  </script>
</BaseLayout>






